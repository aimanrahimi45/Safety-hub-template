# =====================================================================
# AmerisPro — environment variables
#
# Copy this file to `.env` and fill in real values.
# Variables prefixed with PUBLIC_ are exposed to the browser bundle;
# that is intentional for the TENANT Supabase (Project B) — the anon
# key is safe to ship because actual security is enforced by Postgres
# RLS policies (see supabase/migrations/20260712_phase1a_solo_sho.sql).
#
# Server-only secrets (OpenRouter, public-Supabase) must NOT be
# prefixed with PUBLIC_; they stay on the server and are read via
# process.env from src/pages/api/* and src/lib/* server files.
# =====================================================================

# --- Supabase Project B (TENANT, safety data — auth-required) ---------
# This is the SHO's own workspace. Browser client (getSupabase) reads
# these via import.meta.env. Server uses the same URL+anon key but
# forwards the user's session cookie for the RLS-scoped queries.
PUBLIC_SUPABASE_URL=https://YOUR-TENANT-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR-TENANT-ANON-KEY

# (Optional) Service role key — only for server migrations / seeding.
# NEVER ship to the browser. Do NOT add a PUBLIC_ prefix.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Supabase Project A (PUBLIC, legal data — read-only from app) -----
# The shared Malaysian OSH corpus. Two name-pairs:
#   * PUBLIC_SUPABASE_PUBLIC_URL / PUBLIC_SUPABASE_PUBLIC_ANON_KEY
#       These are exposed to the browser bundle. Used by the AI
#       Legal Search tab (a Premium feature) to call the
#       `match_clauses` RPC directly from the browser. RLS is OFF
#       on the public tables; data is global Malaysian law with no
#       secrets, so exposing the anon key to the browser is fine.
#   * SUPABASE_PUBLIC_URL / SUPABASE_PUBLIC_ANON_KEY (no PUBLIC_
#       prefix)
#       Server-only, read via process.env from src/lib/supabasePublic.ts
#       and src/pages/api/* (used by /api/generate-register and
#       /api/ai-summary). Same values as the PUBLIC_* pair.
PUBLIC_SUPABASE_PUBLIC_URL=https://zootofnjqzbblsiptdui.supabase.co
PUBLIC_SUPABASE_PUBLIC_ANON_KEY=YOUR-PUBLIC-LEGAL-ANON-KEY
SUPABASE_PUBLIC_URL=https://zootofnjqzbblsiptdui.supabase.co
SUPABASE_PUBLIC_ANON_KEY=YOUR-PUBLIC-LEGAL-ANON-KEY

# --- OpenRouter (server-side only — never PUBLIC_*) --------------------
# Used by the embeddings helper (openai/text-embedding-3-small) and
# the AI summary endpoint (mistralai/mistral-nemo). Same key as the
# existing AI ingest scripts. NEVER ship to the browser.
OPENROUTER_API_KEY=sk-or-v1-...

# --- License validation (server-side, GAS Web App) -------------------
# The Astro /api/validate-license endpoint calls this URL with:
#   ?action=validateLicense&key=XXXX&spreadsheetId=solo
# and reads back JSON: { valid, planType, expiry, message }
# The spreadsheetId value is the literal string "solo" — it identifies
# the solo-SHO product tier to the GAS Web App. The Web App is the
# user's existing Google Apps Script deployment; we do not migrate
# license storage into Supabase in this phase.
LICENSE_VALIDATION_WEBAPP_URL=https://script.google.com/macros/s/YOUR-DEPLOYMENT-ID/exec
