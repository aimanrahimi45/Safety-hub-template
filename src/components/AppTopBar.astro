---
// AppTopBar — a thin bar that sits above the main site Header on /app/*
// pages. Shows the signed-in user's email on the left and a Sign-out
// button on the right. Uses the same colour palette as the existing
// top-bar in Layout.astro (#F4F4F4 background, muted text).
---
<div class="app-top-bar">
  <div class="container app-top-bar-row">
    <div class="app-top-bar-left">
      <span class="app-top-bar-workspace" id="app-top-bar-workspace" hidden>
        <span class="badge badge-workspace">🏢 <span id="app-top-bar-workspace-name"></span></span>
      </span>
      <span class="app-top-bar-user">
        <span class="badge badge-user">🧑‍💼 <span id="app-top-bar-email">…</span></span>
      </span>
    </div>
    <div class="app-top-bar-right">
      <a href="/app/settings" class="app-top-bar-btn btn-settings">Settings</a>
      <button type="button" id="app-top-bar-signout" class="app-top-bar-btn btn-signout">
        Sign out
      </button>
    </div>
  </div>
</div>

<script>
  import { getSupabase, isSupabaseConfigured } from '../lib/supabase';

  const emailEl = document.getElementById('app-top-bar-email');
  const wsEl = document.getElementById('app-top-bar-workspace');
  const wsNameEl = document.getElementById('app-top-bar-workspace-name');
  const signOutBtn = document.getElementById('app-top-bar-signout') as HTMLButtonElement | null;

  function showWorkspace(name: string | null | undefined): void {
    if (!wsEl || !wsNameEl) return;
    const trimmed = (name ?? '').trim();
    if (!trimmed) {
      wsEl.hidden = true;
      return;
    }
    wsNameEl.textContent = trimmed;
    wsEl.hidden = false;
  }

  if (emailEl) {
    if (!isSupabaseConfigured()) {
      emailEl.textContent = 'Supabase not configured';
    } else {
      // 1. Instant 0ms render from sessionStorage
      const cachedEmail = sessionStorage.getItem('amerispro_user_email');
      const cachedWsName = sessionStorage.getItem('amerispro_ws_name');

      if (cachedEmail) {
        emailEl.textContent = cachedEmail;
      }
      if (cachedWsName) {
        showWorkspace(cachedWsName);
      }

      // 2. Parallel background verification
      const supabase = getSupabase();
      Promise.all([
        supabase.auth.getUser(),
        supabase.from('tenants').select('name').maybeSingle<{ name: string }>()
      ]).then(([userRes, tenantRes]) => {
        const email = userRes.data.user?.email ?? 'unknown user';
        emailEl.textContent = email;
        sessionStorage.setItem('amerispro_user_email', email);

        if (tenantRes.data?.name) {
          showWorkspace(tenantRes.data.name);
          sessionStorage.setItem('amerispro_ws_name', tenantRes.data.name);
        }
      }).catch(() => {
        // Fallback gracefully on network error
      });
    }
  }

  if (signOutBtn) {
    signOutBtn.addEventListener('click', async () => {
      signOutBtn.disabled = true;
      try {
        sessionStorage.clear();
        if (isSupabaseConfigured()) {
          const supabase = getSupabase();
          await supabase.auth.signOut();
        }
      } catch {
        // Even if signOut throws, we still redirect — the user wanted
        // to leave the app either way.
      }
      window.location.href = '/';
    });
  }
</script>

<style>
  .app-top-bar {
    background: #FFF9EC;
    border-bottom: 3px solid #2B2D42;
    padding: 8px 0;
    font-family: 'Fredoka', sans-serif;
    font-size: 0.8rem;
  }
  .app-top-bar-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 0 16px;
  }
  .app-top-bar-left {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }
  
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    font-weight: 700;
    border: 2.5px solid #2B2D42;
    border-radius: 8px;
    box-shadow: 2px 2px 0px #2B2D42;
    white-space: nowrap;
  }
  .badge-workspace {
    background: #FFEED2;
    color: #2B2D42;
  }
  .badge-user {
    background: #FFFFFF;
    color: #2B2D42;
  }
  .app-top-bar-workspace {
    display: inline-flex;
  }
  .app-top-bar-user {
    display: inline-flex;
    min-width: 0;
  }
  #app-top-bar-email {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 240px;
  }

  .app-top-bar-right {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .app-top-bar-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 14px;
    font-family: inherit;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-decoration: none;
    cursor: pointer;
    border: 2.5px solid #2B2D42;
    border-radius: 8px;
    box-shadow: 2px 2px 0px #2B2D42;
    transition: transform 0.1s, box-shadow 0.1s;
    background: #FFFFFF;
    color: #2B2D42;
  }
  .app-top-bar-btn:hover {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0px #2B2D42;
  }
  .app-top-bar-btn:active {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px #2B2D42;
  }
  
  .btn-settings:hover {
    background: #FFEED2;
  }
  .btn-signout {
    background: #FF6B6B;
    color: #FFFFFF;
  }
  .btn-signout:hover {
    background: #FF8585;
  }
  .app-top-bar-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none !important;
    box-shadow: 2px 2px 0px #2B2D42 !important;
  }

  @media (max-width: 768px) {
    .app-top-bar {
      padding: 5px 0;
    }
    .app-top-bar-row {
      flex-direction: row !important;
      justify-content: space-between !important;
      align-items: center !important;
      gap: 6px !important;
      padding: 0 12px !important;
    }
    .app-top-bar-left {
      gap: 6px !important;
      min-width: 0 !important;
    }
    .badge {
      padding: 3px 8px !important;
      font-size: 0.72rem !important;
      border-width: 2px !important;
      box-shadow: 1.5px 1.5px 0px #2B2D42 !important;
    }
    #app-top-bar-email {
      max-width: 120px !important;
    }
    .app-top-bar-btn {
      padding: 4px 8px !important;
      font-size: 0.65rem !important;
      border-width: 2px !important;
      box-shadow: 1.5px 1.5px 0px #2B2D42 !important;
    }
  }
</style>
