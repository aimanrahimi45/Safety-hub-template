---
// Hero Component
---
<!-- Hero Banner Section -->
    <section class="hero-container reveal">
        <div class="hero-text">
            <div class="badge-safety">🛡️ Next-Gen compliance</div>
            <h1>The Modern Way to Manage Site Safety & Compliance</h1>
            <p>Streamline workplace inspections, personnel records, contractor certifications, and first-aid inventories in one centralized, cloud-connected terminal.</p>
            <div class="hero-actions">
                <a href="app/" class="btn-pill btn-primary">Launch Console</a>
                <a href="#modules" class="btn-pill btn-secondary">Explore Modules</a>
            </div>
        </div>
        <div class="hero-image-wrapper">
            <div class="hero-circle-backdrop"></div>
            <img src="mascot_hero.png" alt="AmerisPro Safety Mascot" class="hero-mascot">
        </div>
    </section>