---
// Modules Component
---
<!-- Modules Showcase Section -->
    <section id="modules">
        <div class="section-header">
            <h2>Automated Safety Workflows</h2>
            <p>Ditch paper checklists and clunky forms. Our portal is backed by a serverless database to automate all site functions.</p>
        </div>
        <div class="showcase-grid">
            <!-- Inspection Module Showcase -->
            <div class="showcase-card">
                <div>
                    <div class="showcase-card-header">
                        <div class="showcase-mascot-wrapper">
                            <img src="mascot_inspector.png" alt="Safety Inspector Mascot" class="showcase-mascot">
                        </div>
                        <div class="showcase-title-block">
                            <h3>Workplace Inspections</h3>
                            <p style="color:var(--text-muted); font-size:0.9rem; font-weight:500;">Custom checklist templates creator</p>
                        </div>
                    </div>
                    <ul class="showcase-features-list">
                        <li><span>✔️</span> <span>Import templates directly from Excel sheets</span></li>
                        <li><span>✔️</span> <span>Toggle visual section/category headers</span></li>
                        <li><span>✔️</span> <span>Choose field types (Yes/No, Dropdowns, Text, Numbers)</span></li>
                        <li><span>✔️</span> <span>Digital signatures and relational logs</span></li>
                    </ul>
                </div>
                <a href="app/#inspection" class="btn-pill btn-primary" style="align-self: flex-start;">Open Builder</a>
            </div>

            <!-- Other Portal Modules Showcase -->
            <div class="showcase-card secondary-hover">
                <div>
                    <div class="showcase-card-header">
                        <div class="showcase-mascot-wrapper" style="background:#EEF2F6;">
                            <img src="mascot_hero.png" alt="Portal Modules Mascot" class="showcase-mascot" style="transform: scale(0.85);">
                        </div>
                        <div class="showcase-title-block">
                            <h3>Roster, Kit & Worker Portal</h3>
                            <p style="color:var(--text-muted); font-size:0.9rem; font-weight:500;">Integrated OSH operations suite</p>
                        </div>
                    </div>
                    <ul class="showcase-features-list">
                        <li><span>✔️</span> <span><strong>Staff Roster</strong>: Central sync with quick filters</span></li>
                        <li><span>✔️</span> <span><strong>First Aid Kits</strong>: Log audits & inventory levels</span></li>
                        <li><span>✔️</span> <span><strong>Contractor Inductions</strong>: Check certification validity</span></li>
                        <li><span>✔️</span> <span><strong>Google Sheets DB</strong>: Serverless, private database</span></li>
                    </ul>
                </div>
                <a href="app/" class="btn-pill btn-secondary" style="align-self: flex-start;">Go to Console</a>
            </div>
        </div>
    </section>