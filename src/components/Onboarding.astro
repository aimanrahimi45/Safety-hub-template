---
// Onboarding Component
---
<!-- Interactive Onboarding Guide Section -->
    <section id="onboarding" style="border-top: 2.5px solid var(--border); padding: 80px 40px; background: var(--bg-main);">
        <div style="max-width: 1300px; margin: 0 auto;">
            <div class="section-header" style="text-align: center; max-width: 650px; margin: 0 auto 50px auto;">
                <h2 style="font-family: var(--font-heading); font-weight: 800; font-size: 2.2rem; color: var(--text-main); margin-bottom: 12px;">Getting Started Is Simple</h2>
                <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.5;">Install our extension inside your Google Sheets, run the setup, and connect your new dashboard console in minutes.</p>
            </div>
            <div class="onboarding-grid">
                <!-- Stepper Left -->
                <div class="stepper-col">
                    <div class="step-card active" onclick="switchStep(1)">
                        <div class="step-badge">1</div>
                        <div class="step-info">
                            <h4>Open Google Sheets</h4>
                            <p>Open any of your existing spreadsheets, or create a brand-new blank sheet in your Google Account.</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="switchStep(2)">
                        <div class="step-badge">2</div>
                        <div class="step-info">
                            <h4>Install the AmerisPro Add-on</h4>
                            <p>Go to <strong>Extensions &rarr; Add-ons &rarr; Get Add-ons</strong>, search for <strong>AmerisPro</strong>, and install the extension.</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="switchStep(3)">
                        <div class="step-badge">3</div>
                        <div class="step-info">
                            <h4>Initialize Your Workspace</h4>
                            <p>Once installed, click on <strong>Extensions &rarr; AmerisPro &rarr; Initialize Workspace</strong> to automatically generate all database tabs.</p>
                        </div>
                    </div>
                    <div class="step-card" onclick="switchStep(4)">
                        <div class="step-badge">4</div>
                        <div class="step-info">
                            <h4>Connect to Your Dashboard</h4>
                            <p>Copy the Spreadsheet ID from the URL bar and paste it in the AmerisPro console web portal to log in.</p>
                        </div>
                    </div>
                </div>

                <!-- Mockup Viewport Right -->
                <div class="mockup-col">
                    <div class="mockup-card">
                        <!-- Step 1 Mock: Google Sheets Grid -->
                        <div class="mock-viewport active" id="mock-step-1">
                            <div class="sheets-header">
                                <div class="sheets-green-bar">
                                    <span class="sheets-doc-title">Untitled spreadsheet</span>
                                </div>
                                <div class="sheets-menu-bar">
                                    <span class="menu-extra">File</span><span class="menu-extra">Edit</span><span class="menu-extra">View</span><span class="menu-extra">Insert</span><span class="menu-extra">Format</span><span class="menu-extra">Data</span><span class="menu-extra">Tools</span><span>Extensions</span><span>Help</span>
                                </div>
                            </div>
                            <div class="sheets-grid-container">
                                <table class="sheets-grid-table">
                                    <thead>
                                        <tr>
                                            <th></th>
                                            <th>A</th>
                                            <th>B</th>
                                            <th>C</th>
                                            <th>D</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>1</td>
                                            <td class="cell-active"></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                        </tr>
                                        <tr>
                                            <td>2</td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                        </tr>
                                        <tr>
                                            <td>3</td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="mockup-caption">Blank Google Spreadsheet ready in your account</div>
                        </div>

                        <!-- Step 2 Mock: Google Workspace Marketplace -->
                        <div class="mock-viewport" id="mock-step-2">
                            <div class="marketplace-header">
                                <div class="marketplace-title">Google Workspace Marketplace</div>
                            </div>
                            <div class="marketplace-content">
                                <div class="marketplace-app-card">
                                    <div class="marketplace-logo">🛡️</div>
                                    <div class="marketplace-app-info">
                                        <h3 style="margin: 0;">AmerisPro OSH Add-on</h3>
                                        <p style="margin: 2px 0 6px 0;">By AmerisPro Safety Tech</p>
                                        <button class="marketplace-install-btn" onclick="switchStep(3)">Install</button>
                                    </div>
                                </div>
                                <div class="marketplace-app-details" style="margin-top: 10px;">
                                    <p style="margin: 0;">Automate safety inspection checklists, staff rosters, and compliance logs directly inside Google Sheets.</p>
                                </div>
                            </div>
                            <div class="mockup-caption">Install the extension from the Workspace Marketplace</div>
                        </div>

                        <!-- Step 3 Mock: Extensions Menu Dropdown -->
                        <div class="mock-viewport" id="mock-step-3">
                            <div class="sheets-header">
                                <div class="sheets-green-bar">
                                    <span class="sheets-doc-title">Safety Database</span>
                                </div>
                                <div class="sheets-menu-bar">
                                    <span class="menu-extra">File</span><span class="menu-extra">Edit</span><span class="menu-extra">View</span><span class="menu-extra">Insert</span><span class="menu-extra">Format</span><span class="menu-extra">Data</span><span class="menu-extra">Tools</span><span class="menu-active">Extensions</span><span>Help</span>
                                </div>
                            </div>
                            <div style="position: relative; height: 180px; background: #f8fafc; border-bottom: 1px solid var(--border); flex-grow: 1;">
                                <!-- Mock Dropdown Menu -->
                                <div class="mock-dropdown">
                                    <div class="dropdown-item">Add-ons</div>
                                    <div class="dropdown-item">Macros</div>
                                    <div class="dropdown-item dropdown-has-sub active-sub">
                                        <span>AmerisPro</span>
                                        <span>▶</span>
                                    </div>
                                    <div class="dropdown-item">AppSheet</div>
                                </div>
                                <!-- Mock Sub-dropdown Menu -->
                                <div class="mock-sub-dropdown">
                                    <div class="dropdown-item highlighted-menu">⚙️ Initialize Workspace ⚡</div>
                                    <div class="dropdown-item">📋 Sync Staff Roster</div>
                                    <div class="dropdown-item">🔑 Reset License</div>
                                </div>
                            </div>
                            <div class="mockup-caption">Run the Add-on to automatically generate all database tabs</div>
                        </div>

                        <!-- Step 4 Mock: Console Portal Login -->
                        <div class="mock-viewport" id="mock-step-4">
                            <div class="console-login-mock">
                                <div class="console-header-mock">🛡️ AmerisPro Console</div>
                                <div class="console-body-mock">
                                    <label>Enter Google Spreadsheet ID</label>
                                    <div style="position: relative; display: flex; align-items: center; width: 100%;">
                                        <input type="text" value="1x9B_c2A_fK5Lz4D..." readonly style="width: 100%; padding: 10px; padding-right: 35px; border: 2px solid var(--success); border-radius: 8px; font-size: 0.85rem; font-family: monospace; outline: none; background: white; color: var(--text-main);">
                                        <span style="position: absolute; right: 10px; color: var(--success); font-weight: bold; font-size: 1.1rem;">✓</span>
                                    </div>
                                    <button class="console-btn-mock">Save Connection</button>
                                </div>
                            </div>
                            <div class="mockup-caption">Paste your Spreadsheet ID into the portal to connect!</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>