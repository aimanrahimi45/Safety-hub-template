---
// Testimonials Component
---
<!-- Customer Reviews (Beehaya Testimonial Style) -->
    <section>
        <div class="testimonial-container">
            <div class="testimonial-mascot-col">
                <img src="mascot_hero.png" alt="Reviews Mascot" class="hero-mascot" style="width: 250px;">
            </div>
            <div class="testimonial-card">
                <div class="testimonial-stars">⭐⭐⭐⭐⭐</div>
                <p class="testimonial-comment">"AmerisPro has completely transformed our site compliance audits! The Excel template importer is extremely fast and lets us build custom inspections with our own dropdown options instantly. Highly recommend!"</p>
                <div class="testimonial-author">
                    <div class="testimonial-avatar">AL</div>
                    <div>
                        <strong style="display: block; font-size: 0.95rem; color: var(--text-main);">amyleedsmith</strong>
                        <span style="font-size: 0.8rem; color: var(--text-muted); font-weight: 500;">Safety & Compliance Manager</span>
                    </div>
                </div>
            </div>
        </div>
    </section>