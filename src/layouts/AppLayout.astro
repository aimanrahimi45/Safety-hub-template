---
import Layout from './Layout.astro';
import AppTopBar from '../components/AppTopBar.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;

const isLinkActive = (path: string) => {
  if (path === '/app/dashboard') {
    return pathname === '/app/dashboard';
  }
  return pathname.startsWith(path);
};
---

<Layout title={title}>
  <!-- Import Fredoka font for legacy comic look -->
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

  <div class="app-layout-container">
    <!-- LEFT SIDEBAR -->
    <aside class="app-sidebar">
      <div class="app-brand">
        <img src="/amerispro_128x128.png" alt="AmerisPro Logo" class="app-brand-logo" />
        <span>AmerisPro</span>
      </div>

      <nav class="app-nav">
        <!-- Overview Group -->
        <div class="app-nav-group">
          <a href="/app/dashboard" class={`app-nav-link ${isLinkActive('/app/dashboard') ? 'active' : ''}`}>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="9"></rect>
              <rect x="14" y="3" width="7" height="5"></rect>
              <rect x="14" y="12" width="7" height="9"></rect>
              <rect x="3" y="16" width="7" height="5"></rect>
            </svg>
            Dashboard
          </a>
        </div>

        <!-- First Aid & Gear Group -->
        <div class="app-nav-group">
          <div class="app-nav-group-header">First Aid & Gear</div>
          <div class="app-nav-group-items">
            <a href="/app/first-aid" class={`app-nav-link ${isLinkActive('/app/first-aid') ? 'active' : ''}`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
              </svg>
              Inspect
            </a>
            <a href="/app/inventory" class={`app-nav-link ${isLinkActive('/app/inventory') ? 'active' : ''}`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="16.5" y1="9.4" x2="7.5" y2="4.21"></line>
                <polygon points="12 22.08 12 12 3 6.92 3 17.08 12 22.08"></polygon>
                <polygon points="12 22.08 21 17.08 21 6.92 12 12 12 22.08"></polygon>
                <polygon points="12 12 21 6.92 12 1.92 3 6.92 12 12"></polygon>
              </svg>
              Stock
            </a>
            <a href="/app/ppe" class={`app-nav-link ${isLinkActive('/app/ppe') ? 'active' : ''}`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
              PPE
            </a>
          </div>
        </div>

        <!-- Performance Group -->
        <div class="app-nav-group">
          <div class="app-nav-group-header">Performance</div>
          <div class="app-nav-group-items">
            <a href="/app/incidents" class={`app-nav-link ${isLinkActive('/app/incidents') ? 'active' : ''}`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
              </svg>
              Incident
            </a>
          </div>
        </div>

        <!-- People & Roster Group -->
        <div class="app-nav-group">
          <div class="app-nav-group-header">People & Roster</div>
          <div class="app-nav-group-items">
            <a href="/app/staff" class={`app-nav-link ${isLinkActive('/app/staff') ? 'active' : ''}`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
              Staff
            </a>
            <a href="/app/contractors" class={`app-nav-link ${isLinkActive('/app/contractors') ? 'active' : ''}`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              Contractors
            </a>
          </div>
        </div>

        <!-- Audits & Inspections Group -->
        <div class="app-nav-group">
          <div class="app-nav-group-header">Audits & Inspections</div>
          <div class="app-nav-group-items">
            <a href="/app/inspections" class={`app-nav-link ${isLinkActive('/app/inspections') ? 'active' : ''}`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
                <line x1="16" y1="13" x2="8" y2="13"></line>
                <line x1="16" y1="17" x2="8" y2="17"></line>
                <polyline points="10 9 9 9 8 9"></polyline>
              </svg>
              Inspections
            </a>
          </div>
        </div>

        <!-- System Settings Group -->
        <div class="app-nav-group">
          <div class="app-nav-group-header">System</div>
          <div class="app-nav-group-items">
            <a href="/app/compliance" class={`app-nav-link ${isLinkActive('/app/compliance') ? 'active' : ''}`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
              Compliance
            </a>
            <a href="/app/settings" class={`app-nav-link ${isLinkActive('/app/settings') ? 'active' : ''}`}>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
              </svg>
              Settings
            </a>
          </div>
        </div>
      </nav>
    </aside>

    <!-- RIGHT SIDE CONTENT WORKSPACE -->
    <div class="app-workspace">
      <AppTopBar />
      <main class="app-main-content">
        <slot />
      </main>
    </div>
  </div>
</Layout>

<style is:global>
  /* Global Page Entrance Animation */
  .app-main-content {
    animation: appPageFadeInUp 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes appPageFadeInUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Global Unified Segmented Pill Tab Bar */
  .app-tabs,
  .cmp-tabs,
  .settings-tabs {
    display: flex !important;
    gap: 0px !important;
    margin-bottom: 24px !important;
    border: 3px solid #2B2D42 !important;
    border-radius: 12px !important;
    background: #FFFFFF !important;
    box-shadow: 4px 4px 0px #2B2D42 !important;
    overflow: hidden !important;
    padding: 0 !important;
  }

  .app-tab-btn,
  .cmp-tab-btn,
  .settings-tab-btn {
    flex: 1 !important;
    background: transparent !important;
    border: none !important;
    border-right: 3px solid #2B2D42 !important;
    border-radius: 0px !important;
    box-shadow: none !important;
    margin: 0 !important;
    padding: 12px 10px !important;
    font-family: inherit !important;
    font-size: 0.85rem !important;
    font-weight: 800 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px !important;
    color: #2B2D42 !important;
    cursor: pointer !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 6px !important;
    transition: background 0.15s ease !important;
    transform: none !important;
    outline: none !important;
  }

  .app-tab-btn:last-child,
  .cmp-tab-btn:last-child,
  .settings-tab-btn:last-child {
    border-right: none !important;
  }

  .app-tab-btn:hover,
  .cmp-tab-btn:hover,
  .settings-tab-btn:hover {
    background: #FFF2D1 !important;
    color: #2B2D42 !important;
  }

  .app-tab-btn.active,
  .cmp-tab-btn.active,
  .settings-tab-btn.active {
    background: #FFD166 !important;
    color: #2B2D42 !important;
  }

  /* Playful Neo-brutalist variables scoped to overwrite all child app pages */
  :root {
    --color-primary: #FF6B6B !important;
    --color-primary-hover: #FF8585 !important;
    --color-text: #2B2D42 !important;
    --color-text-muted: #6C757D !important;
    --color-bg: #FFF9EC !important;
    --color-bg-grey: #FFEED2 !important;
    --color-border: #2B2D42 !important;
    --color-border-light: #2B2D42 !important;
    --font-family: 'Fredoka', 'Roboto', sans-serif !important;

    /* Legacy names */
    --primary: #FF6B6B;
    --primary-hover: #FF8585;
    --success: #4ECA64;
    --warning: #FFD166;
    --info: #4EA8DE;
    --bg: #FFF9EC;
    --surface: #FFFFFF;
    --sidebar-bg: #FFEED2;
    --text-main: #2B2D42;
    --border: #2B2D42;
    --shadow-sm: 3px 3px 0px var(--border);
    --shadow-md: 6px 6px 0px var(--border);
    --font-heading: 'Fredoka', sans-serif;
    --font-body: 'Fredoka', sans-serif;
  }

  body {
    background-color: #FFF9EC !important;
    font-family: 'Fredoka', sans-serif !important;
    color: #2B2D42 !important;
    overflow-x: hidden;
  }

  .app-layout-container {
    display: flex;
    min-height: 100vh;
    width: 100%;
    background: #FFF9EC;
    overflow-x: hidden;
  }

  .app-sidebar {
    width: 260px;
    background: #FFEED2;
    border-right: 3px solid #2B2D42;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    padding: 16px 16px 20px 16px;
    font-family: 'Fredoka', sans-serif;
  }

  .app-sidebar::-webkit-scrollbar {
    display: none;
  }

  .app-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    padding-left: 4px;
  }

  .app-brand-logo {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 3px solid #2B2D42;
    box-shadow: 2px 2px 0px #2B2D42;
    background: #FFFFFF;
    object-fit: contain;
    padding: 3px;
  }

  .app-brand span {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 1.3rem;
    color: #2B2D42;
    letter-spacing: -0.5px;
  }

  .app-nav {
    display: flex;
    flex-direction: column;
    gap: 6px;
    list-style: none;
    flex-grow: 1;
  }

  .app-nav-group {
    margin-bottom: 12px;
  }

  .app-nav-group-header {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: #2B2D42;
    margin-bottom: 6px;
    padding-left: 10px;
    opacity: 0.85;
  }

  .app-nav-group-items {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .app-nav-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    color: #2B2D42;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 10px;
    border: 3px solid transparent;
    transition: all 0.1s ease;
    cursor: pointer;
  }

  .app-nav-link svg {
    width: 18px;
    height: 18px;
    color: #2B2D42;
    stroke-width: 2.5px;
    transition: transform 0.15s ease;
  }

  .app-nav-link:hover {
    background: #FFFFFF;
    border-color: #2B2D42;
    transform: translate(-2px, -2px);
    box-shadow: 3px 3px 0px #2B2D42;
  }

  .app-nav-link:hover svg {
    transform: scale(1.1);
  }

  .app-nav-link.active {
    background: #FFD166;
    color: #2B2D42;
    font-weight: 700;
    border: 3px solid #FFFFFF !important;
    outline: 3px solid #2B2D42 !important;
    box-shadow: 4px 4px 0px #2B2D42 !important;
    transform: translate(-2px, -2px) rotate(-1.5deg);
  }

  .app-nav-link.active svg {
    color: #2B2D42;
    transform: scale(1.1) rotate(5deg);
  }

  .app-nav-link.active:hover {
    background: #FFD166;
    transform: translate(-2px, -2px) rotate(-1.5deg);
  }

  .app-workspace {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    min-height: 100vh;
    overflow-x: hidden;
    background: #FFF9EC;
  }

  /* --- Global Neo-Brutalist Layout Components --- */
  .metric-tile, .module-tile, .app-card, .stat-card, .card, .dashboard-page section, .activity-feed, .dash-hero {
    background: #FFFFFF !important;
    border: 3px solid #2B2D42 !important;
    box-shadow: 6px 6px 0px #2B2D42 !important;
    border-radius: 20px !important;
    transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
    padding: 24px !important;
    margin-bottom: 24px !important;
  }

  .metric-tile:hover, .module-tile:hover, .stat-card:hover, .card:hover {
    transform: translate(-4px, -4px) scale(1.01) !important;
    box-shadow: 10px 10px 0px #2B2D42 !important;
    border-color: #FF6B6B !important;
  }

  /* Sketched wobbly border-radii alternators */
  .metric-tile:nth-child(4n+1), .module-tile:nth-child(4n+1) {
    border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px !important;
  }
  .metric-tile:nth-child(4n+2), .module-tile:nth-child(4n+2) {
    border-radius: 20px 240px 20px 220px / 220px 20px 240px 20px !important;
  }
  .metric-tile:nth-child(4n+3), .module-tile:nth-child(4n+3) {
    border-radius: 15px 255px 15px 225px / 225px 15px 255px 15px !important;
  }
  .metric-tile:nth-child(4n+4), .module-tile:nth-child(4n+4) {
    border-radius: 240px 20px 220px 20px / 20px 220px 20px 240px !important;
  }

  /* Sketched outline buttons */
  button, .btn, .btn-primary, .btn-secondary, .launch-btn, .signature-button, .action-btn {
    font-family: 'Fredoka', sans-serif !important;
    font-weight: 700 !important;
    background: #FFFFFF !important;
    color: #2B2D42 !important;
    border: 3px solid #2B2D42 !important;
    border-radius: 12px !important;
    box-shadow: 3px 3px 0px #2B2D42 !important;
    transition: all 0.15s ease !important;
    cursor: pointer !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 8px 16px !important;
  }

  button:hover, .btn:hover, .action-btn:hover {
    transform: translate(-2px, -2px) !important;
    box-shadow: 5px 5px 0px #2B2D42 !important;
    background: #FFD166 !important;
  }

  button:active, .btn:active, .action-btn:active {
    transform: translate(1px, 1px) !important;
    box-shadow: 1px 1px 0px #2B2D42 !important;
  }

  /* Form controls wobbly style */
  input[type="text"], input[type="number"], input[type="email"], input[type="date"], select, textarea {
    border: 3px solid #2B2D42 !important;
    border-radius: 12px !important;
    background: #FFFFFF !important;
    padding: 10px 14px !important;
    font-family: 'Fredoka', sans-serif !important;
    font-weight: 600 !important;
    color: #2B2D42 !important;
    box-shadow: 3px 3px 0px #2B2D42 !important;
    outline: none !important;
    transition: all 0.15s ease !important;
  }

  input:focus, select:focus, textarea:focus {
    border-color: #FF6B6B !important;
    box-shadow: 5px 5px 0px #2B2D42 !important;
  }

  /* Neo brutalist tables */
  table {
    border: 3px solid #2B2D42 !important;
    border-collapse: separate !important;
    border-spacing: 0 !important;
    border-radius: 14px !important;
    overflow: hidden !important;
    box-shadow: 6px 6px 0px #2B2D42 !important;
    background: #FFFFFF !important;
    width: 100% !important;
    margin-bottom: 24px !important;
  }

  th {
    background: #FFEED2 !important;
    border-bottom: 3px solid #2B2D42 !important;
    font-weight: 700 !important;
    color: #2B2D42 !important;
    padding: 12px !important;
  }

  td {
    border-bottom: 2px solid #2B2D42 !important;
    border-right: 2px solid #2B2D42 !important;
    padding: 12px !important;
    color: #2B2D42 !important;
    background: #FFFFFF !important;
  }

  td:last-child {
    border-right: none !important;
  }

  tr:last-child td {
    border-bottom: none !important;
  }

  /* Activity row wobbly stickers */
  .activity-item {
    border: 3px solid #2B2D42 !important;
    border-radius: 12px !important;
    background: #FFFFFF !important;
    margin-bottom: 12px !important;
    box-shadow: 3px 3px 0px #2B2D42 !important;
    transition: all 0.15s ease !important;
    display: flex !important;
    padding: 12px !important;
  }

  .activity-item:hover {
    transform: translate(-2px, -2px) !important;
    box-shadow: 5px 5px 0px #2B2D42 !important;
    border-color: #FF6B6B !important;
  }

  /* Responsive styling */
  @media (max-width: 768px) {
    .app-layout-container {
      flex-direction: column;
    }

    .app-sidebar {
      width: 100%;
      height: auto;
      min-height: 72px;
      flex-direction: row;
      align-items: center;
      padding: 10px 8px;
      border-right: none;
      border-bottom: 3px solid #2B2D42;
      overflow-x: auto;
      overflow-y: hidden;
      gap: 12px;
      position: relative;
    }

    .app-sidebar::after {
      content: '';
      position: absolute;
      right: 0;
      top: 0;
      bottom: 0;
      width: 36px;
      background: linear-gradient(to right, transparent, #FFEED2 80%);
      pointer-events: none;
      z-index: 2;
    }

    .app-brand {
      flex-shrink: 0;
      margin-bottom: 0;
      padding: 4px 6px;
      z-index: 3;
    }

    .app-brand span {
      font-size: 0.95rem;
      white-space: nowrap;
    }

    .app-brand svg,
    .app-brand-logo {
      width: 22px;
      height: 22px;
      border-width: 2px;
      box-shadow: 1px 1px 0px #2B2D42;
      padding: 1px;
    }

    .app-nav {
      flex-direction: row;
      gap: 8px;
      flex-grow: 1;
      flex-shrink: 1;
      overflow-x: auto;
      scrollbar-width: none;
      padding: 8px;
      align-items: center;
    }

    .app-nav::-webkit-scrollbar {
      display: none;
    }

    .app-nav-group {
      margin-bottom: 0;
      flex-shrink: 0;
    }

    .app-nav-group-header {
      display: none !important;
    }

    .app-nav-group-items {
      flex-direction: row;
      gap: 6px;
    }

    .app-nav-link {
      padding: 6px 10px;
      font-size: 0.78rem;
      white-space: nowrap;
      gap: 5px;
      border-width: 2px;
      min-height: 38px;
      border-radius: 10px;
    }

    .app-nav-link svg {
      width: 15px;
      height: 15px;
    }

    .app-nav-link.active {
      transform: translate(-1px, -1px) rotate(-1deg);
      border-width: 2px !important;
      outline-width: 2px !important;
    }
  }

  @media (max-width: 480px) {
    .app-sidebar {
      padding: 8px 6px;
      gap: 6px;
      min-height: 56px;
    }

    .app-brand span {
      font-size: 0.85rem;
    }

    .app-nav-link {
      padding: 5px 8px;
      font-size: 0.72rem;
      min-height: 34px;
    }
  }
</style>

<script is:inline>
  // Safety Hub - Reusable Unified Pagination Helper
  window.PaginationHelper = class {
    constructor(options) {
      this.currentPage = options.currentPage || 1;
      this.pageSize = options.pageSize || 15;
      this.totalRecords = options.totalRecords || 0;
      this.onChange = options.onChange;

      // DOM Elements
      this.elements = {
        prevBtn: document.getElementById(options.prevBtnId || "btn-prev-page"),
        nextBtn: document.getElementById(options.nextBtnId || "btn-next-page"),
        pageInfo: document.getElementById(options.pageInfoId || "page-num-display") || document.getElementById("page-info"),
        start: document.getElementById(options.startId || "pag-start"),
        end: document.getElementById(options.endId || "pag-end"),
        total: document.getElementById(options.totalId || "pag-total"),
        controlsContainer: document.getElementById(options.controlsContainerId || "pagination-controls")
      };

      // Bind events
      if (this.elements.prevBtn) {
        this.elements.prevBtn.onclick = (e) => {
          if (e) e.preventDefault();
          if (this.currentPage > 1) {
            this.currentPage--;
            if (this.onChange) this.onChange(this.currentPage);
          }
        };
      }
      if (this.elements.nextBtn) {
        this.elements.nextBtn.onclick = (e) => {
          if (e) e.preventDefault();
          const totalPages = Math.ceil(this.totalRecords / this.pageSize) || 1;
          if (this.currentPage < totalPages) {
            this.currentPage++;
            if (this.onChange) this.onChange(this.currentPage);
          }
        };
      }
    }

    update(currentPage, totalRecords, pageSize) {
      this.currentPage = currentPage;
      this.totalRecords = totalRecords;
      if (pageSize) this.pageSize = pageSize;

      const totalPages = Math.ceil(this.totalRecords / this.pageSize) || 1;
      if (this.currentPage > totalPages) {
        this.currentPage = totalPages;
      }
      const startIndex = this.totalRecords === 0 ? 0 : (this.currentPage - 1) * this.pageSize + 1;
      const endIndex = Math.min(this.currentPage * this.pageSize, this.totalRecords);

      if (this.elements.start) this.elements.start.innerText = startIndex;
      if (this.elements.end) this.elements.end.innerText = endIndex;
      if (this.elements.total) this.elements.total.innerText = this.totalRecords;
      
      if (this.elements.pageInfo) {
        this.elements.pageInfo.innerText = `Page ${this.currentPage} of ${totalPages}`;
      }

      if (this.elements.prevBtn) {
        this.elements.prevBtn.disabled = (this.currentPage === 1);
        this.elements.prevBtn.style.opacity = (this.currentPage === 1) ? "0.5" : "1";
        this.elements.prevBtn.style.cursor = (this.currentPage === 1) ? "not-allowed" : "pointer";
      }
      if (this.elements.nextBtn) {
        this.elements.nextBtn.disabled = (this.currentPage === totalPages);
        this.elements.nextBtn.style.opacity = (this.currentPage === totalPages) ? "0.5" : "1";
        this.elements.nextBtn.style.cursor = (this.currentPage === totalPages) ? "not-allowed" : "pointer";
      }

      if (this.elements.controlsContainer) {
        this.elements.controlsContainer.style.display = this.totalRecords > 0 ? "flex" : "none";
      }
    }
  };

  // Instant Sidebar Navigation Link Prefetching on Hover
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.app-nav-link').forEach(link => {
      link.addEventListener('mouseenter', () => {
        const href = link.getAttribute('href');
        if (href && !document.querySelector(`link[rel="prefetch"][href="${href}"]`)) {
          const prefetch = document.createElement('link');
          prefetch.rel = 'prefetch';
          prefetch.href = href;
          document.head.appendChild(prefetch);
        }
      }, { once: true });
    });
  });
</script>
