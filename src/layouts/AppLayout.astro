---
import Layout from './Layout.astro';
import AppTopBar from '../components/AppTopBar.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---
<Layout title={title}>
  <div class="app-page">
    <AppTopBar />
    <slot />
  </div>
</Layout>

<style is:global>
  .app-page main {
    padding-top: 32px;
    padding-bottom: 64px;
  }
</style>
