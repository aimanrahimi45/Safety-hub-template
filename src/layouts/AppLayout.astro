---
import AppTopBar from '../components/AppTopBar.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/amerispro_128x128.png">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
</head>
<body class="app-page">
  <AppTopBar />
  <slot />
</body>
</html>

<style is:global>
  .app-page main {
    padding-top: 32px;
    padding-bottom: 64px;
  }
</style>
