---
export interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/amerispro_128x128.png">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
</head>
<body>
    <slot />
    <script is:inline>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

            // Hero indicator sync (12s cycle, 6s per slide)
            const indicators = document.querySelectorAll('.indicator');
            if (indicators.length === 2) {
                let current = 0;
                setInterval(() => {
                    indicators[current].classList.remove('active');
                    current = (current + 1) % 2;
                    indicators[current].classList.add('active');
                }, 6000);
            }

            // Module tab switching
            const listItems = document.querySelectorAll('.module-list-item');
            const tabs = document.querySelectorAll('.module-tab');
            listItems.forEach(item => {
                item.addEventListener('click', () => {
                    const tab = item.dataset.tab;
                    listItems.forEach(i => i.classList.remove('active'));
                    item.classList.add('active');
                    tabs.forEach(t => t.classList.remove('active'));
                    const target = document.querySelector('.module-tab[data-tab="' + tab + '"]');
                    if (target) target.classList.add('active');
                });
            });
        });
    </script>
</body>
</html>

<style is:global>
:root {
    --color-primary: #E58E1A;
    --color-primary-hover: #D07D12;
    --color-text: #1E1E1D;
    --color-text-muted: #6A6A69;
    --color-bg: #FFFFFF;
    --color-bg-grey: #F4F4F4;
    --color-border: #E0E0E0;
    --color-border-light: #F0F0F0;
    --font-family: 'Roboto', sans-serif;
    --container: 1680px;
    --nav-height: 90px;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
[hidden] { display: none !important; }

body {
    font-family: var(--font-family);
    color: var(--color-text);
    background: var(--color-bg);
    line-height: 1.5;
    font-weight: 500;
    font-size: 16px;
    overflow-x: hidden;
}

a { text-decoration: none; color: inherit; }
ul { list-style: none; }
img { max-width: 100%; height: auto; }

.container {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 32px;
}

/* --- Navigation --- */
.site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    background: var(--color-bg);
}
.top-bar {
    background: #F4F4F4;
    padding: 6px 0;
    font-size: 0.75rem;
    font-weight: 600;
}
.top-bar .container {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 24px;
}
.top-bar a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
}
.top-bar a:hover { color: var(--color-primary); }
.top-bar .region {
    display: flex;
    align-items: center;
    gap: 4px;
    color: var(--color-text-muted);
    cursor: pointer;
}
.main-nav {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    height: 80px;
    display: flex;
    align-items: center;
}
.main-nav .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
}
.header-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 900;
    font-size: 1.15rem;
    color: var(--color-text);
}
.header-logo img { height: 32px; }
.nav-main {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
}
.nav-main > li { position: relative; }
.nav-main > li > a {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 8px 18px;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: color 0.15s;
}
.nav-main > li > a:hover { color: var(--color-primary); }
.nav-main > li > a::after {
    content: '▾';
    font-size: 0.6rem;
    margin-top: 2px;
}
.nav-main > li > a:only-child::after { display: none; }
.dropdown {
    position: absolute;
    top: 100%; left: 0;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    min-width: 230px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: all 0.15s ease;
    z-index: 100;
    list-style: none;
}
.nav-main > li:hover .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
}
.dropdown li a {
    display: block;
    padding: 10px 20px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border-light);
    transition: background 0.15s;
}
.dropdown li a:hover { background: var(--color-bg-grey); }
.header-actions {
    display: flex;
    align-items: center;
    gap: 20px;
}
.header-search {
    background: none;
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    color: var(--color-text);
    padding: 8px;
    transition: color 0.15s;
}
.header-search:hover { color: var(--color-primary); }

/* Icon Navigation Style (CASE CE inspired) */
.icon-nav {
    display: flex;
    align-items: center;
    gap: 24px;
    list-style: none;
}
.icon-nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-decoration: none;
    color: var(--color-text);
    transition: color 0.15s;
}
.icon-nav-item:hover { color: var(--color-primary); }
.icon-nav-icon {
    font-size: 1.4rem;
    line-height: 1;
}
.icon-nav-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
}

/* --- Hero with Carousel --- */
.hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
}
.hero-slides {
    position: absolute;
    inset: 0;
    z-index: 0;
}
.hero-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
}
.hero-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
}
.hero-slide-1 {
    opacity: 1;
    animation: heroFade 12s infinite;
}
.hero-slide-2 {
    animation: heroFade 12s infinite;
    animation-delay: 6s;
}
.hero-slide img {
    animation: kenBurns 12s infinite ease-in-out;
}
.hero-slide-2 img {
    animation-delay: 6s;
}
@keyframes heroFade {
    0%, 45% { opacity: 1; }
    50%, 95% { opacity: 0; }
    100% { opacity: 1; }
}
@keyframes kenBurns {
    0% { transform: scale(1) translate(0, 0); }
    50% { transform: scale(1.08) translate(-1%, -1%); }
    100% { transform: scale(1) translate(0, 0); }
}
.hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(135deg, rgba(30,30,29,0.85) 0%, rgba(58,58,57,0.7) 50%, rgba(30,30,29,0.9) 100%);
}
.hero .container {
    position: relative;
    z-index: 2;
    padding: 120px 32px;
    width: 100%;
}
.hero-content { max-width: 620px; }
.hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--color-primary);
    margin-bottom: 16px;
}
.hero-content h1 {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1.1;
    color: white;
    margin-bottom: 20px;
}
.hero-content p {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.75);
    margin-bottom: 36px;
    max-width: 520px;
    line-height: 1.7;
}
.hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
}
.hero-indicators {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 12px;
}
.indicator {
    width: 40px;
    height: 3px;
    background: rgba(255,255,255,0.3);
    transition: all 0.3s;
}
.indicator.active {
    background: var(--color-primary);
    width: 60px;
}

/* --- Buttons --- */
.btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 36px;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.15s;
    border: none;
}
.btn-primary {
    background: var(--color-primary);
    color: white;
}
.btn-primary:hover { background: var(--color-primary-hover); }
.btn-outline {
    background: transparent;
    color: white;
    border: 2px solid rgba(255,255,255,0.3);
}
.btn-outline:hover { border-color: white; }

/* --- Section Common --- */
.section { padding: 80px 0; }
.section-grey { background: var(--color-bg-grey); }

/* Cinematic white-graded section — bg image with a soft white wash
   so the imagery shows through subtly while white module cards
   blend into the surface instead of looking pasted on. */
.section-cinematic {
    position: relative;
    z-index: 1;
    background-image: url('/images/explore-our-module-background.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
}
.section-cinematic::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: rgba(255, 255, 255, 0.62);
    pointer-events: none;
}
.section-cinematic > .container {
    position: relative;
    z-index: 2;
}
.section-cinematic .module-card {
    box-shadow: -6px 2px 8px rgba(0, 0, 0, 0.08), -18px 16px 36px rgba(0, 0, 0, 0.20);
}
.section-header {
    margin-bottom: 40px;
}
.section-header h2 {
    font-size: 2.2rem;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 8px;
}
.section-header p {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 560px;
    line-height: 1.6;
}
.section-header.centered { text-align: center; }
.section-header.centered p { margin: 0 auto; }
.section-header.row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
}
.header-link {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 1px;
    white-space: nowrap;
    transition: opacity 0.15s;
}
.header-link:hover { opacity: 0.7; }

/* --- Module Layout (CASE CE left-list + right-cards) --- */
.module-layout {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 48px;
    align-items: start;
}
.module-list {
    display: flex;
    flex-direction: column;
}
.module-list-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 18px 16px;
    background: none;
    border: none;
    border-bottom: 1px solid var(--color-border);
    cursor: pointer;
    text-align: left;
    transition: all 0.15s;
    font-family: var(--font-family);
    font-size: 0.92rem;
    color: var(--color-text);
}
.module-list-item:first-child {
    border-top: 1px solid var(--color-border);
}
.module-list-item:hover {
    background: var(--color-bg-grey);
}
.module-list-item.active {
    border-bottom: 3px solid var(--color-primary);
    font-weight: 700;
}
.module-list-icon {
    width: 28px;
    height: 28px;
    object-fit: contain;
}
.module-list-label {
    font-size: 0.92rem;
}
.module-cards-wrapper {
    position: relative;
    min-height: 400px;
}
.module-tab {
    display: none;
    animation: tabFadeIn 0.3s ease;
}
.module-tab.active {
    display: block;
}
@keyframes tabFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
}
.module-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-bottom: 32px;
}
.module-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
}
.module-card-img {
    position: relative;
    height: 280px;
    background: var(--color-bg-grey);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}
.module-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: var(--color-primary);
    color: white;
    padding: 6px 14px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 2;
}
.img-placeholder {
    font-size: 4rem;
    opacity: 0.3;
}
.card-icon {
    width: 80px;
    height: 80px;
    object-fit: contain;
    opacity: 0.9;
}
.module-card-preview {
    padding: 0;
    background: #f8fafc;
}
.card-preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
}
.module-card-body {
    padding: 28px;
    flex: 1;
    display: flex;
    flex-direction: column;
}
.module-card-body h3 {
    font-size: 1.3rem;
    font-weight: 900;
    margin-bottom: 12px;
    line-height: 1.3;
}
.module-card-body p {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 24px;
    flex: 1;
}
.btn-card {
    display: block;
    width: 100%;
    padding: 14px;
    background: var(--color-primary);
    color: white;
    text-align: center;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: background 0.15s;
}
.btn-card:hover {
    background: var(--color-primary-hover);
}
.card-accent {
    height: 4px;
    background: var(--color-primary);
}
.prior-link {
    text-align: center;
    padding: 16px 0;
}
.prior-link a {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    transition: color 0.15s;
}
.prior-link a:hover {
    color: var(--color-primary);
}

/* --- How AmerisPro Works (3 cards: hero + 2 supports) --- */
.how-it-works {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 32px;
    align-items: stretch;
}
.how-item {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
}
.how-item h3 {
    font-size: 1.25rem;
    font-weight: 900;
    margin-bottom: 12px;
    line-height: 1.2;
}
.how-item p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.6;
}
.how-icon {
    width: 96px;
    height: 96px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
}
.how-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}
.how-hero {
    background: var(--color-bg-grey);
    border-color: var(--color-primary);
    border-width: 2px;
}
.how-hero h3 {
    font-size: 1.5rem;
    color: var(--color-primary);
}
@media (max-width: 968px) {
    .how-it-works { grid-template-columns: 1fr; }
}

/* --- Updates / News Grid (CASE CE style) --- */
.updates-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 40px;
    padding-bottom: 24px;
    border-bottom: 3px solid var(--color-primary);
}
.updates-header-left h2 {
    font-size: 2.2rem;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 8px;
}
.updates-header-left p {
    font-size: 1rem;
    color: var(--color-text-muted);
    max-width: 560px;
    line-height: 1.6;
    margin-bottom: 12px;
}
.updates-social {
    display: flex;
    align-items: center;
    gap: 12px;
    padding-top: 8px;
}
.social-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 3px solid transparent;
    transition: all 0.15s;
}
.social-icon:hover {
    border-bottom-color: var(--color-primary);
}
.updates-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
}
.update-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    overflow: hidden;
}
.update-card:hover {
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
}
.update-card-img {
    width: 100%;
    height: 240px;
    background: var(--color-bg-grey);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}
.update-card-img .img-placeholder {
    font-size: 3rem;
    opacity: 0.3;
}
.update-card-body {
    padding: 28px;
}
.update-date {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 10px;
}
.update-card h3 {
    font-size: 1.2rem;
    font-weight: 900;
    margin-bottom: 12px;
    line-height: 1.4;
}
.update-card p {
    font-size: 0.92rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 20px;
}
.read-more {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--color-text);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: color 0.15s;
}
.read-more:hover {
    color: var(--color-primary);
}

/* --- Support Split (CASE CE style) --- */
.support-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
}
.support-split-left {
    background: var(--color-bg-grey);
    padding: 64px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}
.support-split-left h2 {
    font-size: 2rem;
    font-weight: 900;
    color: var(--color-primary);
    margin-bottom: 16px;
    line-height: 1.2;
}
.support-split-left p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: 28px;
    max-width: 440px;
}
.support-split-right {
    background: var(--color-text);
    padding: 64px 48px;
    display: flex;
    flex-direction: column;
    justify-content: center;
}
.support-split-right h2 {
    font-size: 2rem;
    font-weight: 900;
    color: white;
    margin-bottom: 16px;
    line-height: 1.2;
}
.support-split-right p {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    margin-bottom: 28px;
    max-width: 440px;
}
.btn-support {
    display: inline-block;
    padding: 14px 32px;
    background: var(--color-primary);
    color: white;
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    transition: background 0.15s;
    align-self: flex-start;
}
.btn-support:hover {
    background: var(--color-primary-hover);
}
.support-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 6px;
    background: var(--color-primary);
}

/* --- Footer --- */
.site-footer {
    background: var(--color-text);
    color: rgba(255,255,255,0.7);
    padding: 60px 0 0;
}
.footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.12);
    margin-bottom: 24px;
}
.footer-col h4 {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: white;
    margin-bottom: 20px;
}
.footer-col a {
    display: block;
    font-size: 0.85rem;
    font-weight: 400;
    color: rgba(255,255,255,0.55);
    padding: 5px 0;
    transition: color 0.15s;
}
.footer-col a:hover { color: white; }
.footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 32px;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
}
.footer-bottom a {
    color: rgba(255,255,255,0.5);
    margin-left: 24px;
    transition: color 0.15s;
