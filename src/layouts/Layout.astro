---
export interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/amerispro_128x128.png">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <slot />
    <script is:inline>
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale, .stagger-children').forEach(el => observer.observe(el));
        });
    </script>
</body>
</html>

<style is:global>
:root {
            --bg-main: #F8FAFC;
            --surface: #FFFFFF;
            --text-main: #0F172A;
            --text-muted: #475569;
            --border: #E2E8F0;
            --border-dark: #cbd5e1;
            
            --primary: #06B6D4; /* Cyan */
            --secondary: #6366F1; /* Indigo */
            --success: #10B981; /* Green */
            --warning: #F59E0B; /* Orange */
            
            --shadow-cyan: rgba(6, 182, 212, 0.25);
            --shadow-indigo: rgba(99, 102, 241, 0.2);
            --shadow-success: rgba(16, 185, 129, 0.2);
            --shadow-soft: rgba(15, 23, 42, 0.04);
            
            --font-heading: 'Plus Jakarta Sans', sans-serif;
            --font-body: 'Inter', sans-serif;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font-body);
            background: var(--bg-main);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
        }

        /* --- Header Navigation --- */
        header {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(248, 250, 252, 0.8);
            backdrop-filter: blur(12px);
            border-bottom: 2.5px solid var(--border);
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: all 0.2s ease;
        }

        .logo-wrapper {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: var(--text-main);
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 1.4rem;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border: 2px solid var(--text-main);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            color: white;
            box-shadow: 2px 2px 0px var(--text-main);
        }

        nav {
            display: flex;
            gap: 30px;
        }

        nav a {
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.95rem;
            transition: color 0.15s ease;
        }

        nav a:hover {
            color: var(--secondary);
        }

        .btn-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-family: var(--font-heading);
            font-weight: 700;
            padding: 10px 24px;
            border-radius: 50px;
            border: 2.5px solid var(--text-main);
            cursor: pointer;
            transition: all 0.2s ease;
            font-size: 0.95rem;
        }

        .updates-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            margin-top: 40px;
        }

        .update-card {
            background: var(--surface);
            border: 2.5px solid var(--border);
            border-radius: 20px;
            padding: 28px;
            transition: all 0.25s ease;
        }

        .update-card:hover {
            transform: translateY(-4px);
            border-color: var(--primary);
            box-shadow: 0 8px 24px var(--shadow-cyan);
        }

        .update-date {
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }

        .update-card h3 {
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 1.1rem;
            margin-bottom: 6px;
        }

        .update-card p {
            color: var(--text-muted);
            font-size: 0.88rem;
            line-height: 1.5;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), #0891b2);
            color: white;
            box-shadow: 0 4px 14px var(--shadow-cyan), 3px 3px 0px var(--text-main);
        }

        .btn-primary:hover {
            transform: translate(-2px, -2px);
            box-shadow: 0 6px 20px var(--shadow-cyan), 5px 5px 0px var(--text-main);
        }

        .btn-secondary {
            background: var(--surface);
            color: var(--text-main);
            box-shadow: 3px 3px 0px var(--text-main);
        }

        .btn-secondary:hover {
            transform: translate(-2px, -2px);
            box-shadow: 5px 5px 0px var(--text-main);
        }

        .btn-success {
            background: var(--success);
            color: white;
            box-shadow: 0 4px 14px var(--shadow-success), 3px 3px 0px var(--text-main);
        }

        .btn-success:hover {
            transform: translate(-2px, -2px);
            box-shadow: 0 6px 20px var(--shadow-success), 5px 5px 0px var(--text-main);
        }

        /* --- Sections Container --- */
        section {
            padding: 80px 40px;
            max-width: 1300px;
            margin: 0 auto;
        }

        /* --- Hero Banner Section --- */
        .hero-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
        }

        .hero-text {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .badge-safety {
            align-self: flex-start;
            background: #E0F2FE;
            color: #0369A1;
            font-weight: 700;
            font-size: 0.75rem;
            padding: 6px 14px;
            border-radius: 30px;
            border: 2px solid #0369A1;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .hero-text h1 {
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 3.2rem;
            line-height: 1.15;
            color: var(--text-main);
        }

        .hero-text p {
            font-size: 1.1rem;
            color: var(--text-muted);
            max-width: 540px;
        }

        .hero-actions {
            display: flex;
            gap: 15px;
            margin-top: 10px;
        }

        .hero-image-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .hero-circle-backdrop {
            position: absolute;
            width: 420px;
            height: 420px;
            background: linear-gradient(135deg, rgba(6, 182, 212, 0.15), rgba(99, 102, 241, 0.15));
            border-radius: 50%;
            z-index: 1;
        }

        .hero-mascot {
            width: 380px;
            height: auto;
            position: relative;
            z-index: 2;
            filter: drop-shadow(0 10px 25px rgba(0,0,0,0.08));
            animation: float 4s ease-in-out infinite;
        }

        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0px); }
        }

        /* --- Modules Split Showcase --- */
        .module-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            margin-top: 40px;
        }

        .module-card {
            background: var(--surface);
            border: 2.5px solid var(--border);
            border-radius: 20px;
            padding: 28px;
            transition: all 0.25s ease;
        }

        .module-card:hover {
            transform: translateY(-4px);
            border-color: var(--primary);
            box-shadow: 0 8px 24px var(--shadow-cyan);
        }

        .module-card-img {
            width: 100%;
            height: 140px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 14px;
            margin-bottom: 16px;
            font-size: 2rem;
        }

        .module-card h3 {
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 1.2rem;
            margin-bottom: 6px;
        }

        .module-card p {
            color: var(--text-muted);
            font-size: 0.88rem;
            line-height: 1.5;
            margin-bottom: 16px;
        }

        .module-link {
            font-weight: 700;
            font-size: 0.9rem;
            color: var(--primary);
            text-decoration: none;
            transition: gap 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .module-link:hover {
            gap: 8px;
        }

        /* --- Why Choose Section --- */
        .section-header {
            text-align: center;
            margin-bottom: 50px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

        .section-header h2 {
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 2.2rem;
            color: var(--text-main);
        }

        .section-header p {
            color: var(--text-muted);
            max-width: 580px;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .feature-item {
            background: var(--surface);
            border: 2.5px solid var(--border);
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            transition: all 0.2s ease;
        }

        .feature-item:hover {
            transform: translateY(-3px);
            border-color: var(--border-dark);
            box-shadow: 0 8px 24px var(--shadow-soft);
        }

        .feature-icon-box {
            font-size: 2.5rem;
            margin-bottom: 15px;
        }

        .feature-item h4 {
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 1.25rem;
            margin-bottom: 10px;
        }

        .feature-item p {
            font-size: 0.9rem;
            color: var(--text-muted);
        }

        /* --- Customer Reviews Section --- */
        .testimonial-container {
            background: var(--surface);
            border: 2.5px solid var(--border);
            border-radius: 24px;
            padding: 50px;
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 50px;
            align-items: center;
            box-shadow: 0 10px 30px var(--shadow-soft);
        }

        .testimonial-mascot-col {
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .testimonial-stars-graphic {
            position: absolute;
            top: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            opacity: 0.85;
        }

        .testimonial-card {
            background: #F8FAFC;
            border: 2.5px solid var(--border);
            border-radius: 20px;
            padding: 40px;
            position: relative;
        }

        .testimonial-stars {
            color: var(--warning);
            font-size: 1.2rem;
            margin-bottom: 15px;
            display: flex;
            gap: 4px;
        }

        .testimonial-comment {
            font-size: 1.15rem;
            font-style: italic;
            font-weight: 500;
            color: var(--text-main);
            margin-bottom: 20px;
        }

        .testimonial-author {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .testimonial-avatar {
            width: 44px;
            height: 44px;
            background: #E2E8F0;
            border: 2px solid var(--text-main);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            color: var(--text-main);
        }

        /* --- Contact Us Section --- */
        .contact-container {
            display: grid;
            grid-template-columns: 1.2fr 1fr;
            gap: 60px;
            align-items: center;
        }

        .contact-mascot-col {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .contact-mascot {
            width: 320px;
            height: auto;
            filter: drop-shadow(0 10px 20px rgba(0,0,0,0.05));
        }

        .contact-form {
            background: var(--surface);
            border: 2.5px solid var(--border);
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 8px 24px var(--shadow-soft);
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .form-group label {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--text-main);
            text-transform: uppercase;
        }

        .form-group input,
        .form-group textarea {
            padding: 12px 16px;
            border: 2px solid var(--border);
            border-radius: 12px;
            font-size: 0.95rem;
            font-family: inherit;
            outline: none;
            transition: all 0.15s ease;
            background: #F8FAFC;
        }

        .form-group input:focus,
        .form-group textarea:focus {
            border-color: var(--primary);
            background: white;
            box-shadow: 0 0 0 4px rgba(6, 182, 212, 0.1);
        }

        /* --- Footer --- */
        footer {
            border-top: 2.5px solid var(--border);
            padding: 50px 40px 30px;
            background: var(--surface);
        }

        .footer-grid {
            max-width: 1100px;
            margin: 0 auto 40px;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 40px;
        }

        .footer-col h4 {
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 0.95rem;
            margin-bottom: 16px;
            color: var(--text-main);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .footer-col a {
            display: block;
            text-decoration: none;
            color: var(--text-muted);
            font-size: 0.88rem;
            font-weight: 500;
            padding: 4px 0;
            transition: color 0.15s;
        }

        .footer-col a:hover {
            color: var(--primary);
        }

        .footer-bottom {
            border-top: 2px solid var(--border);
            padding-top: 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1100px;
            margin: 0 auto;
        }

        .footer-logo {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            color: var(--text-main);
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 1rem;
        }

        .footer-bottom p {
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        /* --- Onboarding Stepper Section --- */
        .onboarding-grid {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 50px;
            align-items: center;
            margin-top: 40px;
        }

        .stepper-col {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .step-card {
            display: flex;
            align-items: flex-start;
            gap: 20px;
            background: var(--surface);
            border: 2.5px solid var(--border);
            border-radius: 20px;
            padding: 24px;
            cursor: pointer;
            transition: all 0.25s ease;
        }

        .step-card:hover {
            transform: translateY(-2px);
            border-color: var(--border-dark);
            box-shadow: 0 6px 15px var(--shadow-soft);
        }

        .step-card.active {
            border-color: var(--primary);
            box-shadow: 0 8px 24px var(--shadow-cyan);
            background: #f0fdfa; /* Soft teal tint */
        }

        .step-badge {
            width: 36px;
            height: 36px;
            background: var(--surface);
            border: 2.5px solid var(--text-main);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 1.1rem;
            color: var(--text-main);
            box-shadow: 2px 2px 0px var(--text-main);
            flex-shrink: 0;
            transition: all 0.2s ease;
        }

        .step-card.active .step-badge {
            background: var(--primary);
            color: white;
            box-shadow: 2px 2px 0px var(--text-main);
        }

        .step-info h4 {
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 1.15rem;
            margin-bottom: 4px;
            color: var(--text-main);
        }

        .step-info p {
            font-size: 0.9rem;
            color: var(--text-muted);
            line-height: 1.45;
        }

        /* --- Mockup Viewport Panel --- */
        .mockup-col {
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .mockup-card {
            background: var(--surface);
            border: 2.5px solid var(--text-main);
            border-radius: 24px;
            width: 100%;
            max-width: 440px;
            height: 380px;
            max-height: 380px;
            min-height: 380px;
            box-shadow: 5px 5px 0px var(--text-main);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            position: relative;
            box-sizing: border-box;
        }

        .mock-viewport {
            display: none;
            flex-direction: column;
            height: 100%;
            max-height: 100%;
            overflow: hidden;
            opacity: 0;
            transform: translateY(10px);
            transition: opacity 0.3s ease, transform 0.3s ease;
            box-sizing: border-box;
        }

        .mock-viewport.active {
            display: flex;
            opacity: 1;
            transform: translateY(0px);
        }

        .mockup-caption {
            margin-top: auto;
            background: var(--bg-main);
            border-top: 2px solid var(--border);
            padding: 12px 20px;
            font-size: 0.8rem;
            font-weight: 700;
            color: var(--text-muted);
            text-align: center;
        }

        /* --- Mockup 1: Google Sheets Grid --- */
        .sheets-header {
            background: #f1f5f9;
            border-bottom: 1.5px solid var(--border);
            padding: 10px 15px 5px 15px;
        }

        .sheets-green-bar {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 6px;
        }

        .sheets-green-bar::before {
            content: "📊";
            font-size: 1rem;
        }

        .sheets-doc-title {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--text-main);
        }

        .sheets-menu-bar {
            display: flex;
            gap: 12px;
            font-size: 0.72rem;
            color: var(--text-muted);
            font-weight: 600;
        }

        .sheets-menu-bar span.menu-active {
            color: #0F9D58;
            font-weight: 700;
            border-bottom: 2px solid #0F9D58;
        }

        .sheets-grid-container {
            padding: 15px;
            background: white;
            flex-grow: 1;
        }

        .sheets-grid-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.75rem;
            color: #64748b;
        }

        .sheets-grid-table th,
        .sheets-grid-table td {
            border: 1px solid #e2e8f0;
            padding: 8px;
            text-align: center;
        }

        .sheets-grid-table th {
            background: #f8fafc;
            font-weight: 600;
        }

        .sheets-grid-table td:first-child {
            background: #f8fafc;
            font-weight: 600;
            width: 30px;
        }

        .sheets-grid-table td.cell-active {
            background: #e2f0d9;
            border: 2px solid #0F9D58;
        }

        /* --- Mockup 2: Google Workspace Marketplace --- */
        .marketplace-header {
            background: white;
            border-bottom: 2px solid var(--border);
            padding: 14px 20px;
            font-weight: 800;
            font-family: var(--font-heading);
            font-size: 0.9rem;
            color: var(--text-main);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .marketplace-header::before {
            content: "🛍️";
        }

        .marketplace-content {
            padding: 24px;
            background: white;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .marketplace-app-card {
            display: flex;
            gap: 18px;
            align-items: center;
        }

        .marketplace-logo {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            border: 2.5px solid var(--text-main);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            box-shadow: 3px 3px 0px var(--text-main);
        }

        .marketplace-app-info h3 {
            font-family: var(--font-heading);
            font-weight: 800;
            font-size: 1.05rem;
            color: var(--text-main);
        }

        .marketplace-app-info p {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-bottom: 6px;
        }

        .marketplace-install-btn {
            background: #2563eb;
            color: white;
            border: 2px solid var(--text-main);
            border-radius: 20px;
            padding: 4px 16px;
            font-size: 0.75rem;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 2px 2px 0px var(--text-main);
            outline: none;
        }

        .marketplace-app-details p {
            font-size: 0.8rem;
            color: var(--text-muted);
            line-height: 1.45;
        }

        /* --- Mockup 3: Menu Dropdowns --- */
        .mock-dropdown {
            position: absolute;
            top: 5px;
            left: 120px;
            background: white;
            border: 2px solid var(--text-main);
            border-radius: 8px;
            box-shadow: 3px 3px 0px var(--text-main);
            width: 140px;
            font-size: 0.72rem;
            z-index: 10;
            padding: 4px 0;
        }

        .mock-sub-dropdown {
            position: absolute;
            top: 45px;
            left: 254px;
            background: white;
            border: 2px solid var(--text-main);
            border-radius: 8px;
            box-shadow: 3px 3px 0px var(--text-main);
            width: 160px;
            font-size: 0.72rem;
            z-index: 11;
            padding: 4px 0;
