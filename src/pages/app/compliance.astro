                  ${escapeHtml(docGroup.docType)}
                </span>
                <span>•</span>
                <span>${sectionsArray.length} matching sections</span>
              </div>
            </div>
            <div style="display: flex; align-items: center; gap: 16px;">
              <span style="font-size: 0.85rem; font-weight: 600; color: var(--primary); background: rgba(15, 118, 110, 0.08); padding: 4px 10px; border-radius: 20px;">
                ${docSimilarityPct}% Match
              </span>
              <span class="cmp-accordion-icon" style="font-size: 1rem; color: var(--text-muted); transition: transform 0.3s; display: inline-block;">▼</span>
            </div>
          </div>
          
          <div class="cmp-accordion-content" style="max-height: 0; overflow: hidden; transition: max-height 0.3s ease-out, padding 0.3s ease-out; background: rgba(0, 0, 0, 0.015); border-top: 0 solid var(--border); padding: 0 20px;">
            <div style="display: flex; flex-direction: column; gap: 16px; padding: 16px 0;">
      `;

      sectionsArray.forEach((section) => {
        const sectionItems = section.items;
        sectionItems.sort((a, b) => (a.section_number || '').localeCompare(b.section_number || '', undefined, { numeric: true, sensitivity: 'base' }));

        let commonTitle = '';
        const firstItemText = sectionItems[0].clause_text || '';
        if (firstItemText.includes(' — ')) {
          commonTitle = firstItemText.split(' — ')[0];
          commonTitle = commonTitle.replace(/^BAHAGIAN\s+[IVXLCDM]+\s+[A-Z\s,\d\(\)]+(?=[A-Z][a-z])/, '');
        }

        html += `
          <div class="cmp-nested-accordion" style="border: 2px solid var(--border); border-radius: 8px; margin-bottom: 12px; background: rgba(255, 255, 255, 0.6); overflow: hidden; display: block;">
            <div class="cmp-nested-header" style="padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; user-select: none; font-weight: 600; color: var(--primary); transition: background 0.2s;" onclick="window.toggleComplianceNestedAccordion(this)">
              <span style="font-size: 0.95rem; display: flex; align-items: center; gap: 6px;">
                📖 ${escapeHtml(section.baseSection)}${commonTitle ? `: ${escapeHtml(commonTitle)}` : ''}
              </span>
