---
import AppLayout from '../../layouts/AppLayout.astro';
---
<AppLayout title="Compliance - AmerisPro">
  <main class="compliance-page">
    <div class="container">
      <div id="cmp-setup-warning" class="cmp-warning" hidden>
        <strong>Setup required.</strong>
        <span>
          Supabase environment variables are not configured. Copy
          <code>.env.example</code> to <code>.env</code>, fill in your
          Supabase credentials, then restart the dev server.
        </span>
      </div>

      <div id="cmp-error" class="cmp-error" hidden></div>

      <header class="cmp-header">
        <div>
          <h1>🛡️ OSH Compliance Register</h1>
          <p class="cmp-sub">Match your site activities to Malaysian OSH law and generate your legal register.</p>
        </div>
      </header>

      <div class="cmp-tabs-wrapper" id="cmp-tabs-wrapper">
        <nav class="cmp-tabs" id="cmp-tabs" role="tablist" aria-label="Compliance tabs">
          <button type="button" class="cmp-tab-btn active" data-tab="profiler" role="tab" aria-selected="true" id="cmp-tab-profiler">
            📋 <span class="tab-text-full">Setup Profiler</span><span class="tab-text-short">Setup</span>
          </button>
          <button type="button" class="cmp-tab-btn" data-tab="register" role="tab" aria-selected="false" id="cmp-tab-register">
            ⚡ <span class="tab-text-full">Legal Register</span><span class="tab-text-short">Register</span>
          </button>
          <button type="button" class="cmp-tab-btn" data-tab="policy" role="tab" aria-selected="false" id="cmp-tab-policy">
            ⚖️ <span class="tab-text-full">OSH Policies</span><span class="tab-text-short">Policies</span>
          </button>
          <button type="button" class="cmp-tab-btn cmp-tab-premium" data-tab="search" role="tab" aria-selected="false" id="cmp-tab-search" hidden>
            🔍 <span class="tab-text-full">AI Legal Search</span><span class="tab-text-short">AI Search</span>
          </button>
        </nav>
        <span class="cmp-tab-arrow" aria-hidden="true">›</span>
      </div>
      <script is:inline>
        if (localStorage.getItem('is_premium') === 'true') {
          const searchTab = document.getElementById('cmp-tab-search');
          if (searchTab) searchTab.hidden = false;
        }
      </script>

      <!-- ====================== TAB: SETUP PROFILER ====================== -->
      <section id="cmp-panel-profiler" class="cmp-panel active" role="tabpanel" aria-labelledby="cmp-tab-profiler">
        <div class="cmp-section-intro">
          <h2>Operational Safety Profiler</h2>
          <p>Enter your facility's baseline metrics and operational activities. The OSH engine will automatically compile and filter your custom compliance register.</p>
        </div>

        <form id="cmp-profile-form" class="cmp-form" novalidate>
          <h3 class="cmp-form-h3">🏢 Site Baseline Profile</h3>
          <div class="cmp-row-2">
            <label class="field">
              <span class="field-label">Employee Headcount</span>
              <input type="number" name="headcount" id="cmp-input-headcount" min="0" placeholder="e.g. 150" />
              <span class="field-hint">Optional. Used to scale certain SHO / committee thresholds.</span>
            </label>
            <label class="field">
              <span class="field-label">Industry Sector</span>
              <select name="industry" id="cmp-input-industry">
                <option value="other">General Offices &amp; Services</option>
                <option value="manufacturing">Manufacturing</option>
                <option value="construction">Construction &amp; Engineering</option>
                <option value="shipbuilding">Ship Building &amp; Repair</option>
                <option value="utilities">Utilities (Water, Gas, Electricity)</option>
                <option value="agriculture">Agriculture / Forestry / Logging</option>
              </select>
            </label>
          </div>

          <h3 class="cmp-form-h3 cmp-mt">⚠️ Environment &amp; Hazard Exposures</h3>
          <div class="cmp-checks">
            <label class="cmp-check">
              <input type="checkbox" name="hazard_noise" id="cmp-hazard-noise" />
              <span>🔊 Excessive Noise Area (employees exposed to &gt;82 dBA or equivalent)</span>
            </label>
            <label class="cmp-check">
              <input type="checkbox" name="hazard_chemicals" id="cmp-hazard-chemicals" />
              <span>🧪 Hazardous Chemical Handling, Storage, or Supply</span>
            </label>
            <label class="cmp-check">
              <input type="checkbox" name="hazard_machinery" id="cmp-hazard-machinery" />
              <span>⚙️ Machinery Requiring Certificate of Fitness (e.g. Boilers, Lifts, Pressure Vessels)</span>
            </label>
            <label class="cmp-check">
              <input type="checkbox" name="hazard_lifting" id="cmp-hazard-lifting" />
              <span>🛗 Lifting Machinery operation (Passenger Lifts, Escalators, Cranes, Hoists)</span>
            </label>
            <label class="cmp-check">
              <input type="checkbox" name="hazard_toxic" id="cmp-hazard-toxic" />
              <span>😷 Specialized Toxic Exposure (Asbestos, Lead, or Silica Dust handling)</span>
            </label>
            <label class="cmp-check">
              <input type="checkbox" name="hazard_radiation" id="cmp-hazard-radiation" />
              <span>☢️ Ionizing or Non-Ionizing Radiation Source handling</span>
            </label>
          </div>

          <h3 class="cmp-form-h3 cmp-mt">🪜 Special Site Operations</h3>
          <div class="cmp-grid-options">
            <button type="button" class="cmp-profile-card" data-id="heights" aria-pressed="false">
              <div class="cmp-card-header"><span class="cmp-card-icon">🪜</span><div class="cmp-checkbox-custom"></div></div>
              <h4>Working at Heights</h4>
              <p>Includes tasks above 2m elevation, scaffolding, or harness installations.</p>
            </button>
            <button type="button" class="cmp-profile-card" data-id="confined" aria-pressed="false">
              <div class="cmp-card-header"><span class="cmp-card-icon">🕳️</span><div class="cmp-checkbox-custom"></div></div>
              <h4>Confined Spaces</h4>
              <p>Work inside tanks, silos, sewers, requiring gas testers and entry permits.</p>
            </button>
            <button type="button" class="cmp-profile-card" data-id="gig" aria-pressed="false">
              <div class="cmp-card-header"><span class="cmp-card-icon">🛵</span><div class="cmp-checkbox-custom"></div></div>
              <h4>Gig Delivery &amp; Riders</h4>
              <p>Employs or manages gig delivery riders or compounding road transport safety rules.</p>
            </button>
            <button type="button" class="cmp-profile-card" data-id="petroleum" aria-pressed="false">
              <div class="cmp-card-header"><span class="cmp-card-icon">🛢️</span><div class="cmp-checkbox-custom"></div></div>
              <h4>Fuel &amp; Petroleum Storage</h4>
              <p>Bulk storage, carriage, pipelines, or handling of petroleum-related fuels.</p>
            </button>
            <button type="button" class="cmp-profile-card" data-id="transport" aria-pressed="false">
              <div class="cmp-card-header"><span class="cmp-card-icon">🚚</span><div class="cmp-checkbox-custom"></div></div>
              <h4>Commercial Vehicle Fleet</h4>
              <p>Company logistics, transport trucks, delivery vehicles, driver fatigue policies.</p>
            </button>
          </div>

          <div class="cmp-form-actions">
            <span id="cmp-profile-saved" class="cmp-saved-hint" hidden></span>
            <button type="submit" id="cmp-profile-save" class="cmp-primary-btn">💾 Save Profile</button>
            <button type="button" id="cmp-profile-generate" class="cmp-primary-btn cmp-primary-btn-accent" hidden>⚡ Generate Legal Register</button>
          </div>
        </form>
      </section>

      <!-- ====================== TAB: ACTIVE CHECKLIST ====================== -->
      <section id="cmp-panel-register" class="cmp-panel" role="tabpanel" aria-labelledby="cmp-tab-register" hidden>
        <div class="cmp-register-header">
          <div>
            <h2>Active Legal Registry</h2>
            <p class="cmp-register-summary" id="cmp-register-summary">Generate your register from the Setup Profiler tab. We'll match your site activities against Malaysian OSH law.</p>
          </div>
          <div class="cmp-register-actions">
            <button type="button" class="cmp-secondary-btn" id="cmp-export-register">📥 Export CSV</button>
            <button type="button" class="cmp-secondary-btn" data-jump="profiler">✏️ Modify Profile</button>
          </div>
        </div>

        <div id="cmp-register-content">
          <div class="cmp-empty">
            <div class="cmp-empty-icon">⚡</div>
            <h3>No register yet</h3>
            <p>Save your profile on the Setup Profiler tab, then click <strong>Generate Legal Register</strong> to match your site activities against Malaysian OSH law.</p>
          </div>
        </div>
      </section>

      <!-- ====================== TAB: POLICY STANDARDS ====================== -->
      <section id="cmp-panel-policy" class="cmp-panel" role="tabpanel" aria-labelledby="cmp-tab-policy" hidden>
        <div class="cmp-register-header">
          <div>
            <h2>Corporate Governance &amp; Policies</h2>
            <p class="cmp-register-summary">Read-only OSH whistleblower protections, employee rights, and company governance standards from the Malaysian OSH corpus.</p>
          </div>
          <button type="button" class="cmp-secondary-btn" data-jump="profiler">✏️ Modify Profile</button>
        </div>

        <div id="cmp-policy-content">
          <div class="cmp-policy-grid">
            <article class="cmp-policy-card">
              <div class="cmp-policy-icon">🛡️</div>
              <h3>Whistleblower Protection</h3>
              <p>Statutory protections for employees who report unsafe work conditions or non-compliance, including prohibitions on retaliation and dismissal.</p>
              <span class="cmp-policy-cite">USECHH 2000 · OSHA 1994</span>
            </article>
            <article class="cmp-policy-card">
              <div class="cmp-policy-icon">📜</div>
              <h3>Employee Rights</h3>
              <p>Right to refuse unsafe work, right to information about workplace hazards, and right to be represented on the Safety &amp; Health Committee.</p>
              <span class="cmp-policy-cite">OSHA 1994 §15</span>
            </article>
            <article class="cmp-policy-card">
              <div class="cmp-policy-icon">👥</div>
              <h3>Safety Committee Requirements</h3>
              <p>Establishment, composition, and operation of workplace safety committees for sites with 40+ employees or as required by sectoral rules.</p>
              <span class="cmp-policy-cite">OSHA 1994 §30</span>
            </article>
            <article class="cmp-policy-card">
              <div class="cmp-policy-icon">🏛️</div>
              <h3>Employer Duties</h3>
              <p>General duty of care to ensure, so far as is reasonably practicable, the safety, health, and welfare at work of all employees.</p>
              <span class="cmp-policy-cite">OSHA 1994 §15(1)</span>
            </article>
            <article class="cmp-policy-card">
              <div class="cmp-policy-icon">📣</div>
              <h3>Reporting Obligations</h3>
              <p>Notification of accidents, dangerous occurrences, and occupational diseases to the Department of Occupational Safety &amp; Health (DOSH/JKKP).</p>
              <span class="cmp-policy-cite">OSHA 1994 §51</span>
            </article>
          </div>
          <p class="cmp-policy-note">Static policy overview. Future versions will pull the actual clause text from the legal corpus and display it inline with citations.</p>
        </div>
      </section>

      <!-- ====================== TAB: AI LEGAL SEARCH (PREMIUM) ====================== -->
      <section id="cmp-panel-search" class="cmp-panel" role="tabpanel" aria-labelledby="cmp-tab-search" hidden>
        <div class="cmp-search-area">
          <h2>AI-Powered OSH Search</h2>
          <p>Type a natural-language question to similarity-match against the Malaysian OSH corpus (e.g. <em>"What are safety duties for crane operators?"</em>).</p>
          <div class="cmp-search-input-group">
            <input type="text" id="cmp-search-query" placeholder="Search safety rules…" autocomplete="off" />
            <button type="button" class="cmp-primary-btn" id="cmp-search-btn">🔎 Search</button>
          </div>
        </div>

        <div id="cmp-search-results"></div>
      </section>
    </div>
  </main>
</AppLayout>

<script>
  import { getSupabase, isSupabaseConfigured, checkPremiumStatus, getCachedPremiumStatus } from '../../lib/supabase';
  import { renderSkeletonCards } from '../../lib/ui';
  import { buildCsv } from '../../lib/csvExport';
  import type { CsvColumn } from '../../lib/csvExport';
  import type { TenantProfile, ComplianceRegisterItem, AiSummaryResponse, LegalSearchResult } from '../../lib/types';

  // Expose the public Supabase URL+anon key to the browser-side AI
  // Search. These PUBLIC_* env vars are intentionally public — the
  // legal data is global Malaysian OSH law with no secrets, and RLS
  // is OFF on Project A's public tables.
  (window as unknown as { __PUBLIC_SUPABASE_URL__: string }).__PUBLIC_SUPABASE_URL__ =
    import.meta.env.PUBLIC_SUPABASE_PUBLIC_URL ?? '';
  (window as unknown as { __PUBLIC_SUPABASE_ANON_KEY__: string }).__PUBLIC_SUPABASE_ANON_KEY__ =
    import.meta.env.PUBLIC_SUPABASE_PUBLIC_ANON_KEY ?? '';

  // -------------------------------------------------------------------
  // Refs
  // -------------------------------------------------------------------
  const setupWarning = document.getElementById('cmp-setup-warning') as HTMLElement;
  const errorEl = document.getElementById('cmp-error') as HTMLElement;
  const tabButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.cmp-tab-btn'));
  const searchTabBtn = document.getElementById('cmp-tab-search') as HTMLButtonElement;

  const tabPanels: Record<'profiler' | 'register' | 'policy' | 'search', HTMLElement> = {
    profiler: document.getElementById('cmp-panel-profiler') as HTMLElement,
    register: document.getElementById('cmp-panel-register') as HTMLElement,
    policy: document.getElementById('cmp-panel-policy') as HTMLElement,
    search: document.getElementById('cmp-panel-search') as HTMLElement,
  };

  const form = document.getElementById('cmp-profile-form') as HTMLFormElement;
  const inputHeadcount = document.getElementById('cmp-input-headcount') as HTMLInputElement;
  const inputIndustry = document.getElementById('cmp-input-industry') as HTMLSelectElement;
  const hazardIds = ['noise', 'chemicals', 'machinery', 'lifting', 'toxic', 'radiation'] as const;
  const hazardChecks: Record<typeof hazardIds[number], HTMLInputElement> = {
    noise: document.getElementById('cmp-hazard-noise') as HTMLInputElement,
    chemicals: document.getElementById('cmp-hazard-chemicals') as HTMLInputElement,
    machinery: document.getElementById('cmp-hazard-machinery') as HTMLInputElement,
    lifting: document.getElementById('cmp-hazard-lifting') as HTMLInputElement,
    toxic: document.getElementById('cmp-hazard-toxic') as HTMLInputElement,
    radiation: document.getElementById('cmp-hazard-radiation') as HTMLInputElement,
  };
  const saveBtn = document.getElementById('cmp-profile-save') as HTMLButtonElement;
  const generateBtn = document.getElementById('cmp-profile-generate') as HTMLButtonElement;
  const savedHint = document.getElementById('cmp-profile-saved') as HTMLElement;
  const profileCards = Array.from(document.querySelectorAll<HTMLButtonElement>('.cmp-profile-card'));
  const registerSummary = document.getElementById('cmp-register-summary') as HTMLElement;
  const registerContent = document.getElementById('cmp-register-content') as HTMLElement;

  const searchQuery = document.getElementById('cmp-search-query') as HTMLInputElement;
  const searchBtn = document.getElementById('cmp-search-btn') as HTMLButtonElement;
  const searchResults = document.getElementById('cmp-search-results') as HTMLElement;

  // -------------------------------------------------------------------
  // State
  // -------------------------------------------------------------------
  const REGISTER_STORAGE_KEY = 'amerispro_compliance_register_v1';
  let supabase: ReturnType<typeof getSupabase> | null = null;
  let tenantId: string | null = null;
  let isPremium = getCachedPremiumStatus();
  let lastSearchResults: LegalSearchResult[] = [];

  // -------------------------------------------------------------------
  // Helpers
  // -------------------------------------------------------------------
  function cleanRequiredAction(action: string, sectionTitle: string): string {
    if (!action) return '';
    let clean = action.trim();
    
    // Split by long dash (em-dash / en-dash / spaced hyphen) to strip any redundant prefixes
    if (clean.includes(' — ')) {
      clean = clean.split(' — ').slice(1).join(' — ').trim();
    } else if (clean.includes(' - ')) {
      clean = clean.split(' - ').slice(1).join(' - ').trim();
    } else if (clean.includes(' – ')) {
      clean = clean.split(' – ').slice(1).join(' – ').trim();
    }

    // 1. Remove leading uppercase "BAHAGIAN [ROMAN] [UPPERCASE TITLE]" block
    clean = clean.replace(/^BAHAGIAN\s+[IVXLCDM]+\s+[A-Z\s,\d\(\)\-\&\/\+]+/g, '').trim();

    // 2. Remove the section title case-insensitively if it repeats at the beginning
    if (sectionTitle) {
      const cleanTitle = sectionTitle.trim();
      const escapedTitle = cleanTitle.replace(/[-\/\\^$*+?.()|[\]{}]/g, '\\$&');
      const regex = new RegExp(`^${escapedTitle}\\s*`, 'i');
      clean = clean.replace(regex, '').trim();
    }
    
    return clean || action;
  }

  function showError(msg: string): void {
    errorEl.hidden = false;
    errorEl.textContent = msg;
  }
  function clearError(): void { errorEl.hidden = true; errorEl.textContent = ''; }

  function escapeHtml(s: string | null | undefined): string {
    return (s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string);
  }

  function profileFromForm(): TenantProfile {
    const operations = profileCards
      .filter((c) => c.classList.contains('selected'))
      .map((c) => c.dataset.id)
      .filter((s): s is string => typeof s === 'string');
    const headcountRaw = inputHeadcount.value.trim();
    const headcount = headcountRaw === '' ? null : Math.max(0, parseInt(headcountRaw, 10) || 0);
    return {
      industry: inputIndustry.value || null,
      headcount,
      hazards: {
        noise: hazardChecks.noise.checked,
        chemicals: hazardChecks.chemicals.checked,
        machinery: hazardChecks.machinery.checked,
        lifting: hazardChecks.lifting.checked,
        toxic: hazardChecks.toxic.checked,
        radiation: hazardChecks.radiation.checked,
      },
      operations,
    };
  }

  function applyProfileToForm(p: {
    industry: string | null;
    headcount: number | null;
    hazard_noise: boolean;
    hazard_chemicals: boolean;
    hazard_machinery: boolean;
    hazard_lifting: boolean;
    hazard_toxic: boolean;
    hazard_radiation: boolean;
    operations: string[];
  }): void {
    inputIndustry.value = p.industry ?? 'other';
    inputHeadcount.value = p.headcount != null ? String(p.headcount) : '';
    hazardChecks.noise.checked = p.hazard_noise;
    hazardChecks.chemicals.checked = p.hazard_chemicals;
    hazardChecks.machinery.checked = p.hazard_machinery;
    hazardChecks.lifting.checked = p.hazard_lifting;
    hazardChecks.toxic.checked = p.hazard_toxic;
    hazardChecks.radiation.checked = p.hazard_radiation;
    const selected = new Set(p.operations ?? []);
    for (const card of profileCards) {
      const id = card.dataset.id ?? '';
      const on = selected.has(id);
      card.classList.toggle('selected', on);
      card.setAttribute('aria-pressed', on ? 'true' : 'false');
    }
  }

  function profileToDbRow(p: TenantProfile) {
    return {
      industry: p.industry,
      headcount: p.headcount,
      hazard_noise: p.hazards.noise,
      hazard_chemicals: p.hazards.chemicals,
      hazard_machinery: p.hazards.machinery,
      hazard_lifting: p.hazards.lifting,
      hazard_toxic: p.hazards.toxic,
      hazard_radiation: p.hazards.radiation,
      operations: p.operations,
    };
  }

  function dbRowToProfile(r: Record<string, unknown>): {
    industry: string | null;
    headcount: number | null;
    hazard_noise: boolean;
    hazard_chemicals: boolean;
    hazard_machinery: boolean;
    hazard_lifting: boolean;
    hazard_toxic: boolean;
    hazard_radiation: boolean;
    operations: string[];
  } {
    return {
      industry: typeof r.industry === 'string' ? r.industry : null,
      headcount: typeof r.headcount === 'number' ? r.headcount : null,
      hazard_noise: r.hazard_noise === true,
      hazard_chemicals: r.hazard_chemicals === true,
      hazard_machinery: r.hazard_machinery === true,
      hazard_lifting: r.hazard_lifting === true,
      hazard_toxic: r.hazard_toxic === true,
      hazard_radiation: r.hazard_radiation === true,
      operations: Array.isArray(r.operations) ? (r.operations as string[]) : [],
    };
  }

  // -------------------------------------------------------------------
  // Tab switching
  // -------------------------------------------------------------------
  function switchTab(tab: 'profiler' | 'register' | 'policy' | 'search'): void {
    if (tab === 'search' && !isPremium) {
      // Defence in depth: the tab button is hidden, but if someone
      // clicks via dev tools we still bail.
      return;
    }
    for (const btn of tabButtons) {
      const isActive = btn.dataset.tab === tab;
      btn.classList.toggle('active', isActive);
      btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
    }
    for (const [key, el] of Object.entries(tabPanels) as Array<[keyof typeof tabPanels, HTMLElement]>) {
      const isActive = key === tab;
      el.hidden = !isActive;
      el.classList.toggle('active', isActive);
    }
    if (tab === 'register') {
      // Render cached register from sessionStorage if present.
      const cached = readRegister();
      if (cached && cached.length > 0) {
        renderRegister(cached);
      }
    }
  }

  for (const btn of tabButtons) {
    btn.addEventListener('click', () => {
      const tab = btn.dataset.tab as 'profiler' | 'register' | 'policy' | 'search';
      switchTab(tab);
    });
  }
  for (const btn of document.querySelectorAll<HTMLButtonElement>('[data-jump]')) {
    btn.addEventListener('click', () => {
      const t = btn.dataset.jump as 'profiler' | 'register' | 'policy';
      switchTab(t);
    });
  }

  // Mobile Tab Bar Scroll Indicator Logic
  const tabsNavEl = document.getElementById('cmp-tabs') as HTMLElement | null;
  const tabsWrapEl = document.getElementById('cmp-tabs-wrapper') as HTMLElement | null;
  if (tabsNavEl && tabsWrapEl) {
    const updateScrollHint = () => {
      const isEnd = tabsNavEl.scrollLeft + tabsNavEl.clientWidth >= tabsNavEl.scrollWidth - 12;
      tabsWrapEl.classList.toggle('scrolled-end', isEnd);
    };
    tabsNavEl.addEventListener('scroll', updateScrollHint, { passive: true });
    window.addEventListener('resize', updateScrollHint, { passive: true });
    setTimeout(updateScrollHint, 100);
  }

  // -------------------------------------------------------------------
  // Profile cards (operations)
  // -------------------------------------------------------------------
  for (const card of profileCards) {
    card.addEventListener('click', () => {
      const on = card.classList.toggle('selected');
      card.setAttribute('aria-pressed', on ? 'true' : 'false');
    });
  }

  // -------------------------------------------------------------------
  // Save profile
  // -------------------------------------------------------------------
  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    if (!supabase || !tenantId) return;
    clearError();

    const profile = profileFromForm();
    if (profile.headcount !== null && profile.headcount < 0) {
      showError('Headcount must be 0 or positive.');
      return;
    }

    saveBtn.disabled = true;
    const original = saveBtn.textContent ?? 'Save';
    saveBtn.textContent = 'Saving…';

    try {
      const { error } = await supabase
        .from('tenants')
        .update(profileToDbRow(profile))
        .eq('id', tenantId);
      if (error) throw error;

      savedHint.hidden = false;
      savedHint.textContent = `✅ Profile saved (${new Date().toLocaleString()}).`;
      generateBtn.hidden = false;
    } catch (e) {
      showError(e instanceof Error ? e.message : 'Failed to save profile.');
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = original;
    }
  });

  async function runGenerateRegister(autoSwitch = true): Promise<void> {
    if (!supabase || !tenantId) return;
    clearError();

    const profile = profileFromForm();
    if (profile.operations.length === 0 &&
        !profile.hazards.noise && !profile.hazards.chemicals &&
        !profile.hazards.machinery && !profile.hazards.lifting &&
        !profile.hazards.toxic && !profile.hazards.radiation) {
      showError('Select at least one operation or hazard before generating.');
      return;
    }

    generateBtn.disabled = true;
    const originalText = generateBtn.textContent ?? 'Generate';
    generateBtn.textContent = '🔄 Generating…';
    registerContent.innerHTML = renderSkeletonCards(3);
    if (autoSwitch) {
      switchTab('register');
    }

    try {
      const resp = await fetch('/api/generate-register', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ profile }),
      });
      if (!resp.ok) {
        const err = await resp.json().catch(() => ({ error: 'Unknown error' }));
        throw new Error(err.error ?? `HTTP ${resp.status}`);
      }
      const data = (await resp.json()) as { items: ComplianceRegisterItem[] };
      const items = Array.isArray(data.items) ? data.items : [];
      writeRegister(items);
      renderRegister(items);
    } catch (e) {
      registerContent.innerHTML = `<div class="cmp-empty" style="color:#8B1A1A;"><div class="cmp-empty-icon">❌</div><h3>Failed to generate register</h3><p>${escapeHtml(e instanceof Error ? e.message : 'Unknown error')}</p></div>`;
    } finally {
      generateBtn.disabled = false;
      generateBtn.textContent = originalText;
    }
  }

