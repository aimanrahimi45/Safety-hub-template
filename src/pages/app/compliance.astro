              <div style="display: flex; flex-direction: column; gap: 12px; padding: 16px;">
        `;

        sectionItems.forEach((item) => {
          let displayText = item.clause_text || '';
          if (displayText.includes(' — ')) {
            displayText = displayText.split(' — ').slice(1).join(' — ');
