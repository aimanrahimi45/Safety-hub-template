          if (displayText.includes(' | Screenshots:')) {
            displayText = displayText.split(' | Screenshots:')[0];
          } else if (displayText.includes(' | Screenshot:')) {
            displayText = displayText.split(' | Screenshot:')[0];
          }

          let imagesHtml = '';
          if (Array.isArray(item.parent_citations) && item.parent_citations.length > 0) {
            imagesHtml += `<div style="display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; margin-bottom: 6px;">`;
            item.parent_citations.forEach((url) => {
              if (typeof url === 'string' && url.startsWith('http')) {
                imagesHtml += `
                  <a href="${escapeHtml(url)}" target="_blank" rel="noopener noreferrer" class="cmp-diagram-link" style="display: block; border: 2px solid var(--border); border-radius: 8px; overflow: hidden; box-shadow: 2px 2px 0 var(--shadow); transition: transform 0.2s; background: white;">
                    <img src="${escapeHtml(url)}" alt="OSH diagram" style="display: block; height: 70px; width: auto; object-fit: contain; padding: 4px;" />
                  </a>
                `;
              }
            });
            imagesHtml += `</div>`;
          }

          html += `
            <div style="padding: 12px; background: rgba(255, 255, 255, 0.5); border-radius: 6px; border: 1px solid rgba(0,0,0,0.05); position: relative;">
              <div class="cmp-match-score" style="position: absolute; top: 10px; right: 10px; font-size: 0.75rem; background: rgba(15, 118, 110, 0.08); padding: 2px 8px; border-radius: 12px; font-weight: 600; color: var(--primary);">
                ${Math.round((item.similarity || 0) * 100)}% match
              </div>
              <div style="font-weight: 600; color: var(--text-main); font-size: 0.85rem; margin-bottom: 6px;">
                Sub-clause ${escapeHtml(item.section_number || '')}
              </div>
              <div style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.45; padding-right: 80px;">
                ${escapeHtml(displayText)}
              </div>
              ${imagesHtml}
              <div class="cmp-obligation-tags" style="margin-top: 8px; display: flex; gap: 6px;">
                <span class="cmp-tag cmp-tag-freq" style="margin: 0; padding: 2px 8px; font-size: 0.75rem;">${escapeHtml(item.frequency)}</span>
                <span class="cmp-tag cmp-tag-${escapeHtml((item.legal_weight || 'mandatory').toLowerCase())}" style="margin: 0; padding: 2px 8px; font-size: 0.75rem;">${escapeHtml((item.legal_weight || 'mandatory').toUpperCase())}</span>
              </div>
            </div>
          `;
        });

        html += `
              </div>
            </div>
          </div>
        `;
      });

      html += `
            </div>
          </div>
        </div>
      `;
    });

    html += `</div>`;
    html += `<div class="cmp-search-actions"><button type="button" class="cmp-primary-btn cmp-primary-btn-accent" id="cmp-ai-summary-btn">🤖 Get AI Summary</button></div>`;
    searchResults.innerHTML = html;

    const btn = document.getElementById('cmp-ai-summary-btn');
    if (btn) btn.addEventListener('click', () => { void runAiSummary(q); });
  }

  async function runAiSummary(q: string): Promise<void> {
    if (lastSearchResults.length === 0) return;
    const box = document.getElementById('cmp-ai-summary-box') as HTMLElement;
    box.hidden = false;
    box.innerHTML = '<h4>🤖 AI Legal Assistant</h4><div class="cmp-ai-summary-text">AI is analyzing the matched references…</div>';
    try {
      const resp = await fetch('/api/ai-summary', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          query: q,
          clause_ids: lastSearchResults.map((r) => r.clause_id),
        }),
      });
      const data = (await resp.json()) as AiSummaryResponse;
      if (data.status === 'SUCCESS' && typeof data.summary === 'string') {
        const textEl = box.querySelector('.cmp-ai-summary-text') as HTMLElement;
        textEl.innerHTML = renderMarkdown(data.summary) +
          '<div class="cmp-ai-copy-row"><button type="button" class="cmp-secondary-btn" id="cmp-ai-copy">📋 Copy to clipboard</button></div>';
        const copyBtn = document.getElementById('cmp-ai-copy');
        if (copyBtn) {
          copyBtn.addEventListener('click', async () => {
            try {
              await navigator.clipboard.writeText(data.summary ?? '');
              copyBtn.textContent = '✅ Copied';
            } catch {
              copyBtn.textContent = '❌ Copy failed';
            }
          });
        }
      } else {
        box.innerHTML = `<h4>🤖 AI Legal Assistant</h4><div class="cmp-ai-summary-text" style="color:#8B1A1A;">⚠️ ${escapeHtml(data.message ?? 'AI summary failed.')}</div>`;
      }
    } catch (e) {
      box.innerHTML = `<h4>🤖 AI Legal Assistant</h4><div class="cmp-ai-summary-text" style="color:#8B1A1A;">⚠️ ${escapeHtml(e instanceof Error ? e.message : 'Connection error.')}</div>`;
    }
  }

  function renderMarkdown(md: string): string {
    // Minimal Markdown: bold + bullet lists + paragraphs.
    const lines = md.split('\n');
    let inList = false;
    let out = '';
    for (const raw of lines) {
      const line = raw.trim();
      if (!line) { if (inList) { out += '</ul>'; inList = false; } continue; }
      const bolded = line.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
      const m = bolded.match(/^[-*+•]\s+(.*)$/);
      if (m) {
        if (!inList) { out += '<ul>'; inList = true; }
        out += `<li>${m[1]}</li>`;
      } else {
        if (inList) { out += '</ul>'; inList = false; }
        out += `<p>${bolded}</p>`;
      }
    }
    if (inList) out += '</ul>';
    return out;
  }

  // -------------------------------------------------------------------
  // Bootstrap
  // -------------------------------------------------------------------
  if (!isSupabaseConfigured()) {
    setupWarning.hidden = false;
    saveBtn.disabled = true;
    generateBtn.disabled = true;
    searchBtn.disabled = true;
  } else {
    supabase = getSupabase();
    (async () => {
      const { data: userData, error: userErr } = await supabase.auth.getUser();
      if (userErr || !userData.user) {
        window.location.replace('/login');
        return;
      }
      const { data: tenant, error: tenantErr } = await supabase
        .from('tenants')
        .select('id, industry, headcount, hazard_noise, hazard_chemicals, hazard_machinery, hazard_lifting, hazard_toxic, hazard_radiation, operations, subscription_plan, subscription_expires_at')
        .eq('owner_user_id', userData.user.id)
        .single();
      if (tenantErr || !tenant) {
        window.location.replace('/app/onboarding');
        return;
      }
      tenantId = tenant.id;
      isPremium =
        tenant.subscription_plan === 'premium' &&
        (tenant.subscription_expires_at === null ||
          new Date(tenant.subscription_expires_at) > new Date());
      localStorage.setItem('is_premium', isPremium ? 'true' : 'false');
      if (isPremium) {
        searchTabBtn.hidden = false;
      } else {
        searchTabBtn.hidden = true;
      }

      // Pre-fill the profiler form from the tenant row.
      applyProfileToForm(dbRowToProfile(tenant as unknown as Record<string, unknown>));
      // If a profile has any non-default data, show "Generate" button.
      const t = tenant as unknown as Record<string, unknown>;
      const hasAny = t.industry != null || t.headcount != null ||
        t.hazard_noise === true || t.hazard_chemicals === true || t.hazard_machinery === true ||
        t.hazard_lifting === true || t.hazard_toxic === true || t.hazard_radiation === true ||
        (Array.isArray(t.operations) && (t.operations as string[]).length > 0);
      if (hasAny) {
        savedHint.hidden = false;
        savedHint.textContent = `Last saved profile loaded. Adjust and re-save, or click Generate to refresh.`;
        generateBtn.hidden = false;

        const existing = readRegister();
        if (!existing || existing.length === 0) {
          void runGenerateRegister(false);
        } else {
          renderRegister(existing);
        }
      }
    })().catch(() => {
      showError('Failed to initialise compliance page.');
    });
  }

  (window as any).toggleComplianceAccordion = function(header: HTMLElement) {
    const item = header.parentElement;
    if (!item) return;
    const content = item.querySelector('.cmp-accordion-content') as HTMLElement;
    const icon = item.querySelector('.cmp-accordion-icon') as HTMLElement;
    if (!content || !icon) return;
    const isOpen = item.classList.contains('active');

    if (isOpen) {
      item.classList.remove('active');
      content.style.maxHeight = content.scrollHeight + 'px';
      content.offsetHeight; // force reflow
      content.style.maxHeight = '0';
      content.style.borderTop = '0px solid transparent';
      icon.style.transform = 'rotate(0deg)';
      header.style.background = 'transparent';
    } else {
      item.classList.add('active');
      content.style.maxHeight = content.scrollHeight + 'px';
      content.style.borderTop = '3px solid var(--border)';
      icon.style.transform = 'rotate(180deg)';
      header.style.background = 'rgba(15, 118, 110, 0.02)';

      setTimeout(() => {
        if (item.classList.contains('active')) {
          content.style.maxHeight = 'none';
        }
      }, 300);
    }
  };

  (window as any).toggleComplianceNestedAccordion = function(header: HTMLElement) {
    const item = header.parentElement;
    if (!item) return;
    const content = header.nextElementSibling as HTMLElement;
    const icon = header.querySelector('.cmp-nested-icon') as HTMLElement;
    if (!content || !icon) return;
    const isOpen = item.classList.contains('active');

    if (isOpen) {
      item.classList.remove('active');
      content.style.maxHeight = '0';
      icon.style.transform = 'rotate(0deg)';
      header.style.background = 'transparent';
    } else {
      item.classList.add('active');
      content.style.maxHeight = content.scrollHeight + 'px';
      icon.style.transform = 'rotate(180deg)';
      header.style.background = 'rgba(15, 118, 110, 0.02)';
    }
  };
</script>

