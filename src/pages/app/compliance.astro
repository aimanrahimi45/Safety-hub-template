      if ((it.similarity || 0) > docGroups[docName].maxSimilarity) {
        docGroups[docName].maxSimilarity = it.similarity || 0;
      }

      const sectionNum = it.section_number || '';
      const baseMatch = sectionNum.match(/^([A-Za-z\s-]+\s+\d+[A-Za-z]*|[A-Za-z\s-]+\s+[A-Z0-9]+|\d+[A-Za-z]*)/i);
      const baseSection = baseMatch ? baseMatch[0] : sectionNum || 'General';

      if (!docGroups[docName].sections[baseSection]) {
        docGroups[docName].sections[baseSection] = {
          baseSection,
          maxSimilarity: it.similarity || 0,
          items: []
        };
      }

      if ((it.similarity || 0) > docGroups[docName].sections[baseSection].maxSimilarity) {
        docGroups[docName].sections[baseSection].maxSimilarity = it.similarity || 0;
      }
      docGroups[docName].sections[baseSection].items.push(it);
    }

    let html = `<div id="cmp-ai-summary-box" class="cmp-ai-summary-box" hidden></div>`;
