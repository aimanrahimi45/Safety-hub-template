      sectionsArray.sort((a, b) => b.maxSimilarity - a.maxSimilarity);

      html += `
        <div class="cmp-search-accordion" style="margin-bottom: 16px; border: 3px solid var(--border); border-radius: 14px; background: white; box-shadow: 3px 3px 0 var(--shadow); overflow: hidden; display: block; position: relative;">
          <div class="cmp-accordion-header" style="padding: 16px 20px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; user-select: none; transition: background 0.2s;" onclick="window.toggleComplianceAccordion(this)">
            <div style="display: flex; flex-direction: column; gap: 4px;">
              <h4 style="margin: 0; color: var(--primary); font-size: 1.1rem; font-weight: 600; display: flex; align-items: center; gap: 8px;">
                📂 ${escapeHtml(docGroup.docDisplayName)}
              </h4>
              <div style="color: var(--text-muted); font-size: 0.8rem; display: flex; gap: 8px; align-items: center; margin-top: 4px;">
