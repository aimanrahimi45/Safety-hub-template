  });

  // -------------------------------------------------------------------
  // Register rendering
  // -------------------------------------------------------------------
  function readRegister(): ComplianceRegisterItem[] | null {
    try {
      const raw = sessionStorage.getItem(REGISTER_STORAGE_KEY);
      if (!raw) return null;
      const parsed = JSON.parse(raw);
      if (!Array.isArray(parsed)) return null;
      return parsed as ComplianceRegisterItem[];
    } catch {
      return null;
    }
  }
  function writeRegister(items: ComplianceRegisterItem[]): void {
    try {
      sessionStorage.setItem(REGISTER_STORAGE_KEY, JSON.stringify(items));
    } catch {
      // sessionStorage full or disabled — ignore.
    }
  }

