---
// Induct a new worker for a specific contractor company.
//
// Uses the shared imageResize + storage helpers for the optional
// photo + signature. On submit:
//   1. client-side validation
//   2. upload photo + signature to Supabase Storage (if provided)
//   3. insert induction_records row
//   4. if this is the contractor's first induction, auto-flip
//      contractors.status to 'inducted'
//   5. redirect to /app/contractors/<id>
//
// Added legacy features:
//   - Inline IC lookup (worker verification)
//   - 3 safety declaration checkboxes
//   - Live camera capture alongside file upload
//   - Group induction mode with batch queue
import AppLayout from '../../../../layouts/AppLayout.astro';

export function getStaticPaths() {
  return [{ params: { id: '_' } }];
}
---
<AppLayout title="Induct Worker - AmerisPro">
  <main class="ct-induct-page">
    <div class="container">
      <div id="ct-setup-warning" class="ct-warning" hidden>
        <strong>Setup required.</strong>
        <span>
          Supabase environment variables are not configured. Copy
          <code>.env.example</code> to <code>.env</code>, fill in your
          Supabase credentials, then restart the dev server.
        </span>
      </div>

      <div id="ct-error" class="ct-error" hidden></div>

      <header class="ct-header">
        <div>
          <h1>Induct worker</h1>
          <p class="ct-sub" id="ct-sub">Loading contractor…</p>
        </div>
        <a id="ct-back-link" href="/app/contractors" class="ct-link-btn">← Back</a>
      </header>

      <!-- Group induction toggle -->
      <div class="ct-toggle-container">
        <span class="ct-toggle-label">Induct a Group of Contractors?</span>
        <label class="ct-switch">
          <input type="checkbox" id="ct-group-toggle">
          <span class="ct-slider"></span>
        </label>
      </div>

      <form id="ct-form" novalidate>

        <!-- Worker verification (IC lookup) -->
        <fieldset class="ct-fieldset">
          <legend>Worker verification</legend>
          <p class="ct-hint">Check if the worker has been inducted before at this site.</p>
          <div class="ct-search-bar">
            <input type="text" id="ct-search-ic" placeholder="IC or Passport No.">
            <button type="button" id="ct-lookup-btn" class="ct-secondary-btn">Check Status</button>
          </div>
          <div id="ct-lookup-result" hidden></div>
        </fieldset>

        <!-- A. Worker info -->
        <fieldset class="ct-fieldset">
          <legend>A. Worker information</legend>

          <div class="ct-row-2">
            <label class="field">
              <span class="field-label">Worker name <em>*</em></span>
              <input type="text" name="worker_name" id="ct-worker-name" required placeholder="e.g. Ahmad bin Ali" />
            </label>
            <label class="field">
              <span class="field-label">IC number <em>*</em></span>
              <input type="text" name="worker_ic" id="ct-worker-ic" required placeholder="e.g. 880515-14-5678" />
            </label>
          </div>

          <div class="ct-row-2">
            <label class="field">
              <span class="field-label">Induction date <em>*</em></span>
              <input type="date" name="induction_date" id="ct-induction-date" required />
            </label>
            <label class="field">
              <span class="field-label">Expires at</span>
              <input type="date" name="expires_at" id="ct-expires-at" />
              <span class="field-hint">Optional. Used by the IC lookup to flag expired inductions.</span>
            </label>
          </div>

          <!-- Safety Declaration checkboxes -->
          <label class="field" style="margin-top: 4px;">
            <span class="field-label">Safety Declaration <em>*</em></span>
          </label>
          <div class="ct-checklist-group">
            <label class="ct-checkbox-container">
              <input type="checkbox" class="ct-iso-check" data-topic="Emergency Evacuation Plan" required>
              <span>I understand the site Emergency Evacuation Plan & Assembly Points.</span>
            </label>
            <label class="ct-checkbox-container">
              <input type="checkbox" class="ct-iso-check" data-topic="PPE Requirements" required>
              <span>I understand the mandatory PPE requirements for my work area.</span>
            </label>
            <label class="ct-checkbox-container">
              <input type="checkbox" class="ct-iso-check" data-topic="Hazard Reporting" required>
              <span>I agree to report all hazards, near-misses, and accidents immediately.</span>
            </label>
          </div>
        </fieldset>

        <!-- B. Photo upload + camera capture -->
        <fieldset class="ct-fieldset">
          <legend>B. Photo (optional)</legend>
          <p class="ct-hint">Take a live photo or choose a file. Resized to max 800×800 before upload.</p>

          <!-- Live camera capture -->
          <div id="ct-camera-container" class="ct-camera-container">
            <video id="ct-video-feed" class="ct-video-feed" autoplay playsinline></video>
            <img id="ct-captured-photo" class="ct-captured-photo" alt="Captured identity photo">
            <canvas id="ct-photo-canvas" style="display:none"></canvas>
            <div class="ct-camera-btn-group">
              <button type="button" id="ct-open-camera" class="ct-secondary-btn">Open Camera</button>
              <button type="button" id="ct-switch-camera" class="ct-secondary-btn" style="display:none;">Switch Camera</button>
              <button type="button" id="ct-capture" class="ct-primary-btn" style="display:none;">Take Photo</button>
              <button type="button" id="ct-retake" class="ct-secondary-btn" style="display:none;">Retake</button>
            </div>
          </div>

          <p class="ct-hint" style="margin-top: 14px;">Or upload a file…</p>
          <label class="field">
            <span class="field-label">Worker photo</span>
            <input type="file" id="ct-photo-input" accept="image/*" capture="environment" />
            <span class="field-hint" id="ct-photo-info">No file selected.</span>
          </label>
          <div id="ct-photo-preview-wrap" hidden>
            <img id="ct-photo-preview" class="ct-photo-preview" alt="Worker photo preview" />
            <button type="button" id="ct-photo-remove" class="ct-secondary-btn">Remove photo</button>
          </div>
          <input type="hidden" name="photo_data_url" id="ct-photo-data" />
        </fieldset>

        <!-- C. Signature -->
        <fieldset class="ct-fieldset">
          <legend>C. Signature (optional)</legend>
          <p class="ct-hint">Worker signs below with mouse or finger. Resized to 200×100 before upload.</p>
          <div class="ct-sig-controls">
            <button type="button" id="ct-sig-save" class="ct-secondary-btn">Save signature</button>
            <button type="button" id="ct-sig-clear" class="ct-secondary-btn">Clear</button>
          </div>
          <canvas id="ct-sig-pad" class="ct-sig-pad" width="600" height="160" aria-label="Signature pad"></canvas>
          <input type="hidden" name="signature_data_url" id="ct-sig-data" />
          <div id="ct-sig-preview-wrap" hidden>
            <p class="ct-hint">Saved signature:</p>
            <img id="ct-sig-preview" class="ct-sig-preview" alt="Signature preview" />
          </div>
        </fieldset>

        <!-- D. Declaration -->
        <fieldset class="ct-fieldset">
          <legend>D. Declaration</legend>
          <div class="ct-callout" id="ct-declaration">Loading…</div>
          <label class="field-check">
            <input type="checkbox" name="ack" id="ct-ack" required />
            <span>The worker acknowledges the above declaration. <em>*</em></span>
          </label>
        </fieldset>

        <div class="ct-form-actions">
          <a id="ct-cancel-link" href="/app/contractors" class="ct-secondary-btn">Cancel</a>
          <button type="submit" id="ct-submit" class="ct-primary-btn">Save induction</button>
        </div>
      </form>

      <!-- Batch queue (group induction) -->
      <div id="ct-batch-section" class="ct-batch-card" hidden>
        <h2>Queued Workers (<span id="ct-queue-count">0</span>)</h2>
        <p class="ct-hint">These workers will be submitted as a group once you click "Submit Group".</p>
        <div id="ct-batch-queue" class="ct-batch-list"></div>
        <button type="button" id="ct-submit-group" class="ct-primary-btn ct-btn-green" disabled>Submit Group Induction</button>
      </div>
    </div>
  </main>
</AppLayout>

<script>
  import { getSupabase, isSupabaseConfigured } from '../../../../lib/supabase';
  import { resizeImage, formatBytes, ResizeError } from '../../../../lib/imageResize';
  import { uploadToStorage } from '../../../../lib/storage';
  import type { Contractor, ContractorDeclaration, InductionRecord, WorkerLookupResult } from '../../../../lib/types';

  const setupWarning = document.getElementById('ct-setup-warning') as HTMLElement;
  const errorEl = document.getElementById('ct-error') as HTMLElement;
  const formEl = document.getElementById('ct-form') as HTMLFormElement;
  const submitBtn = document.getElementById('ct-submit') as HTMLButtonElement;
  const subEl = document.getElementById('ct-sub') as HTMLElement;
  const backLinkEl = document.getElementById('ct-back-link') as HTMLAnchorElement;
  const cancelLinkEl = document.getElementById('ct-cancel-link') as HTMLAnchorElement;

  const photoInput = document.getElementById('ct-photo-input') as HTMLInputElement;
  const photoInfo = document.getElementById('ct-photo-info') as HTMLElement;
  const photoPreviewWrap = document.getElementById('ct-photo-preview-wrap') as HTMLElement;
  const photoPreview = document.getElementById('ct-photo-preview') as HTMLImageElement;
  const photoRemove = document.getElementById('ct-photo-remove') as HTMLButtonElement;
  const photoData = document.getElementById('ct-photo-data') as HTMLInputElement;

  const sigPad = document.getElementById('ct-sig-pad') as HTMLCanvasElement;
  const sigSave = document.getElementById('ct-sig-save') as HTMLButtonElement;
  const sigClear = document.getElementById('ct-sig-clear') as HTMLButtonElement;
  const sigData = document.getElementById('ct-sig-data') as HTMLInputElement;
  const sigPreviewWrap = document.getElementById('ct-sig-preview-wrap') as HTMLElement;
  const sigPreview = document.getElementById('ct-sig-preview') as HTMLImageElement;

  const declarationEl = document.getElementById('ct-declaration') as HTMLElement;
  const ackEl = document.getElementById('ct-ack') as HTMLInputElement;

  // Group induction refs
  const groupToggle = document.getElementById('ct-group-toggle') as HTMLInputElement;
  const batchSection = document.getElementById('ct-batch-section') as HTMLElement;
  const batchQueue = document.getElementById('ct-batch-queue') as HTMLElement;
  const queueCount = document.getElementById('ct-queue-count') as HTMLElement;
  const submitGroupBtn = document.getElementById('ct-submit-group') as HTMLButtonElement;

  // IC lookup refs
  const searchIcEl = document.getElementById('ct-search-ic') as HTMLInputElement;
  const lookupResult = document.getElementById('ct-lookup-result') as HTMLElement;

  // Camera refs
  const videoFeed = document.getElementById('ct-video-feed') as HTMLVideoElement;
  const capturedPhoto = document.getElementById('ct-captured-photo') as HTMLImageElement;
  const photoCanvas = document.getElementById('ct-photo-canvas') as HTMLCanvasElement;
  const btnOpenCamera = document.getElementById('ct-open-camera') as HTMLButtonElement;
  const btnSwitchCamera = document.getElementById('ct-switch-camera') as HTMLButtonElement;
  const btnCapture = document.getElementById('ct-capture') as HTMLButtonElement;
  const btnRetake = document.getElementById('ct-retake') as HTMLButtonElement;

  function showError(msg: string): void {
    errorEl.hidden = false;
    errorEl.textContent = msg;
    errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
  function clearError(): void { errorEl.hidden = true; errorEl.textContent = ''; }

  function today(): string {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string);
  }

  function getContractorId(): string {
    const path = window.location.pathname;
    const m = path.match(/\/app\/contractors\/([^/]+)\/induct/);
    return m ? m[1] : '';
  }

  function readQueryIc(): string {
    const params = new URLSearchParams(window.location.search);
    return params.get('ic') ?? '';
  }

  // --- Signature pad -----------------------------------------------------
  let drawing = false;
  function getCtx(): CanvasRenderingContext2D | null { return sigPad.getContext('2d'); }
  function clearCanvas(): void {
    const ctx = getCtx();
    if (ctx) ctx.clearRect(0, 0, sigPad.width, sigPad.height);
  }
  function pos(ev: MouseEvent | TouchEvent): { x: number; y: number } {
    const rect = sigPad.getBoundingClientRect();
    const scaleX = sigPad.width / rect.width;
    const scaleY = sigPad.height / rect.height;
    if (ev instanceof TouchEvent) {
      const t = ev.touches[0] ?? ev.changedTouches[0];
      return { x: (t.clientX - rect.left) * scaleX, y: (t.clientY - rect.top) * scaleY };
    }
    return { x: (ev.clientX - rect.left) * scaleX, y: (ev.clientY - rect.top) * scaleY };
  }
  function bindPad(): void {
    const ctx = getCtx();
    if (!ctx) return;
    ctx.lineWidth = 2;
    ctx.lineCap = 'round';
    ctx.strokeStyle = '#1E1E1D';
    sigPad.addEventListener('mousedown', (e) => { drawing = true; const p = pos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); });
    sigPad.addEventListener('mousemove', (e) => { if (!drawing) return; const p = pos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); });
    sigPad.addEventListener('mouseup', () => { drawing = false; });
    sigPad.addEventListener('mouseleave', () => { drawing = false; });
    sigPad.addEventListener('touchstart', (e) => { e.preventDefault(); drawing = true; const p = pos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); }, { passive: false });
    sigPad.addEventListener('touchmove', (e) => { e.preventDefault(); if (!drawing) return; const p = pos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); }, { passive: false });
    sigPad.addEventListener('touchend', () => { drawing = false; });
  }
  sigClear.addEventListener('click', () => {
    clearCanvas();
    sigData.value = '';
    sigPreviewWrap.hidden = true;
    sigLocalDataUrl = null;
  });
  sigSave.addEventListener('click', () => {
    sigLocalDataUrl = sigPad.toDataURL('image/png');
    sigPreview.src = sigLocalDataUrl;
    sigPreviewWrap.hidden = false;
    sigData.value = 'pending-upload';
  });

  // --- IC lookup ----------------------------------------------------------
  const lookupBtn = document.getElementById('ct-lookup-btn') as HTMLButtonElement;
  lookupBtn.addEventListener('click', () => {
    if (!supabase) return;
    const ic = searchIcEl.value.trim();
    if (!ic) { lookupResult.hidden = false; lookupResult.innerHTML = `<div class="ct-lookup-msg ct-lookup-msg--warn">Enter IC number first.</div>`; return; }
    lookupResult.hidden = false;
    lookupResult.innerHTML = `<div class="ct-lookup-msg">Checking status…</div>`;
    (async () => {
      try {
        const { data, error } = await supabase.rpc('lookup_worker_by_ic', { p_ic: ic }) as { data: WorkerLookupResult[] | null; error: any };
        if (error) throw error;
        if (!data || data.length === 0) {
          lookupResult.innerHTML = `<div class="ct-lookup-msg ct-lookup-msg--bad">Not found. New induction needed.</div>`;
        } else {
          const r = data[0];
          if (r.is_expired) {
            lookupResult.innerHTML = `<div class="ct-lookup-msg ct-lookup-msg--warn">EXPIRED. Re-induction required!<br><small>Inducted: ${escapeHtml(r.induction_date)} at ${escapeHtml(r.company_name)}</small></div>`;
          } else if (r.worker_name) {
            (document.getElementById('ct-worker-name') as HTMLInputElement).value = r.worker_name;
            lookupResult.innerHTML = `<div class="ct-lookup-msg ct-lookup-msg--ok">VALID. Induction is current.<br><small>Inducted: ${escapeHtml(r.induction_date)} at ${escapeHtml(r.company_name)}</small></div>`;
          }
        }
      } catch (e) {
        lookupResult.innerHTML = `<div class="ct-lookup-msg ct-lookup-msg--bad">Error checking status.</div>`;
      }
    })();
  });

  // Auto-lookup when IC field changes (debounced via lookup button)
  // Also sync IC field to lookup field
  const workerIcEl = document.getElementById('ct-worker-ic') as HTMLInputElement;
  workerIcEl.addEventListener('input', () => {
    searchIcEl.value = workerIcEl.value;
  });
  searchIcEl.addEventListener('input', () => {
    workerIcEl.value = searchIcEl.value;
  });

  // --- Camera capture -----------------------------------------------------
  let cameraStream: MediaStream | null = null;
  let cameraPhotoData: string | null = null;
  let currentFacingMode: string = 'user';

  async function startCamera(): Promise<void> {
    if (cameraStream) {
      cameraStream.getTracks().forEach(track => track.stop());
    }
    try {
      cameraStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: currentFacingMode } });
      videoFeed.srcObject = cameraStream;
      videoFeed.style.display = 'block';
      capturedPhoto.style.display = 'none';
      btnOpenCamera.style.display = 'none';
      btnSwitchCamera.style.display = 'inline-flex';
      btnCapture.style.display = 'inline-flex';
      btnRetake.style.display = 'none';
    } catch (err: any) {
      showError('Camera access denied or unavailable: ' + (err.message || ''));
    }
  }

  btnOpenCamera.addEventListener('click', startCamera);

  btnSwitchCamera.addEventListener('click', () => {
    currentFacingMode = (currentFacingMode === 'user') ? 'environment' : 'user';
    startCamera();
  });

  btnCapture.addEventListener('click', () => {
    const MAX_WIDTH = 800;
    const scale = Math.min(MAX_WIDTH / videoFeed.videoWidth, 1);
    photoCanvas.width = videoFeed.videoWidth * scale;
    photoCanvas.height = videoFeed.videoHeight * scale;
    const ctx = photoCanvas.getContext('2d');
    if (ctx) ctx.drawImage(videoFeed, 0, 0, photoCanvas.width, photoCanvas.height);
    cameraPhotoData = photoCanvas.toDataURL('image/jpeg', 0.6);
    capturedPhoto.src = cameraPhotoData;
    capturedPhoto.style.display = 'block';
    videoFeed.style.display = 'none';
    if (cameraStream) {
      cameraStream.getTracks().forEach(track => track.stop());
      cameraStream = null;
    }
    btnCapture.style.display = 'none';
    btnSwitchCamera.style.display = 'none';
    btnRetake.style.display = 'inline-flex';
    btnOpenCamera.style.display = 'none';
    // Also set the hidden photo data field for submission
    photoData.value = cameraPhotoData;
    photoPreview.src = cameraPhotoData;
    photoPreviewWrap.hidden = false;
    photoInfo.textContent = 'Photo captured from camera.';
  });

  btnRetake.addEventListener('click', () => {
    cameraPhotoData = null;
    photoData.value = '';
    photoPreviewWrap.hidden = true;
    startCamera();
  });

  // --- Photo handling (file upload) ---------------------------------------
  photoInput.addEventListener('change', async () => {
    clearError();
    const file = photoInput.files?.[0];
    if (!file) return;
    photoInfo.textContent = `Resizing ${file.name} (${formatBytes(file.size)})…`;
    try {
      const result = await resizeImage(file, {
        maxWidth: 800,
        maxHeight: 800,
        quality: 0.7,
        outputType: 'image/jpeg',
      });
      photoData.value = result.dataUrl;
      photoPreview.src = result.dataUrl;
      photoPreviewWrap.hidden = false;
      photoInfo.textContent = `${file.name}: ${formatBytes(result.originalSize)} → ${formatBytes(result.newSize)} (${result.width}×${result.height})`;
    } catch (e) {
      photoInfo.textContent = 'Resize failed; the original file will be uploaded.';
      photoData.value = '';
      photoPreviewWrap.hidden = true;
      if (e instanceof ResizeError) {
        photoInfo.textContent = `Resize failed: ${e.message}. Original file will be uploaded.`;
      } else {
        photoInfo.textContent = 'Resize failed; the original file will be uploaded.';
      }
    }
  });
  photoRemove.addEventListener('click', () => {
    photoInput.value = '';
    photoData.value = '';
    photoPreviewWrap.hidden = true;
    photoInfo.textContent = 'No file selected.';
    cameraPhotoData = null;
    capturedPhoto.style.display = 'none';
    videoFeed.style.display = 'none';
  });

  // --- Init + submit ----------------------------------------------------
  let currentContractor: Contractor | null = null;
  let authUserId: string | null = null;
  let supabase: ReturnType<typeof getSupabase> | null = null;
  let sigLocalDataUrl: string | null = null;

  if (!isSupabaseConfigured()) {
    setupWarning.hidden = false;
    submitBtn.disabled = true;
  } else {
    supabase = getSupabase();
    (document.getElementById('ct-induction-date') as HTMLInputElement).value = today();
    setTimeout(bindPad, 50);
  }

  async function loadContractor(): Promise<void> {
    if (!supabase) return;
    const id = getContractorId();
    if (!id || id === '_') {
      showError('Invalid contractor id.');
      submitBtn.disabled = true;
      return;
    }
    const prefillIc = readQueryIc();
    if (prefillIc) {
      workerIcEl.value = prefillIc;
      searchIcEl.value = prefillIc;
    }
    try {
      const { data: userData, error: userErr } = await supabase.auth.getUser();
      if (userErr || !userData.user) {
        window.location.replace('/login');
        return;
      }
      authUserId = userData.user.id;

      const { data: contractor, error: cErr } = await supabase
        .from('contractors')
        .select('*')
        .eq('id', id)
        .maybeSingle<Contractor>();
      if (cErr || !contractor) {
        showError('Contractor not found.');
        submitBtn.disabled = true;
        return;
      }
      currentContractor = contractor;
      subEl.textContent = `For ${contractor.company_name}`;
      backLinkEl.href = `/app/contractors/${contractor.id}`;
      cancelLinkEl.href = `/app/contractors/${contractor.id}`;

      try {
        const { data: decl } = await supabase.rpc<ContractorDeclaration>('get_contractor_declaration');
        declarationEl.textContent = (decl && String(decl).trim()) || 'No declaration text configured. Set one in /app/settings.';
      } catch {
        declarationEl.textContent = 'Failed to load declaration text.';
      }
    } catch (e) {
      showError(e instanceof Error ? e.message : 'Failed to load contractor.');
      submitBtn.disabled = true;
    }
  }

  // --- Group induction logic ----------------------------------------------
  let batchWorkers: Array<{
    workerName: string;
    workerIc: string;
    inductionDate: string;
    expiresAt: string | null;
    topicsCovered: string[];
    photoDataUrl: string | null;
    signatureDataUrl: string | null;
  }> = [];

  function renderBatchQueue(): void {
    batchQueue.innerHTML = '';
    queueCount.textContent = String(batchWorkers.length);
    batchWorkers.forEach((w, index) => {
      const item = document.createElement('div');
      item.className = 'ct-batch-item';
      item.innerHTML = `
        <div class="ct-batch-item-info">
          <span class="ct-batch-item-name">${index + 1}. ${escapeHtml(w.workerName)}</span>
          <span class="ct-batch-item-ic">IC/Passport: ${escapeHtml(w.workerIc)}</span>
        </div>
        <button type="button" class="ct-batch-remove" data-index="${index}">Remove</button>
      `;
      batchQueue.appendChild(item);
    });
    submitGroupBtn.disabled = batchWorkers.length === 0;
    // Lock company-level fields when at least one worker is queued
    const shouldLock = batchWorkers.length > 0;
    (document.getElementById('ct-induction-date') as HTMLInputElement).disabled = shouldLock;
    (document.getElementById('ct-expires-at') as HTMLInputElement).disabled = shouldLock;
    document.querySelectorAll('.ct-iso-check').forEach(cb => (cb as HTMLInputElement).disabled = shouldLock);
  }

  batchQueue.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.ct-batch-remove') as HTMLButtonElement | null;
    if (!btn) return;
    const idx = parseInt(btn.dataset.index ?? '', 10);
    if (!isNaN(idx) && idx >= 0 && idx < batchWorkers.length) {
      batchWorkers.splice(idx, 1);
    }
    renderBatchQueue();
  });

  groupToggle.addEventListener('change', () => {
    if (groupToggle.checked) {
      batchSection.hidden = false;
      submitBtn.textContent = '➕ Add Worker to Group';
    } else {
      if (batchWorkers.length > 0) {
        if (!confirm('You have workers in the queue. Turning off group mode will discard them. Discard?')) {
          groupToggle.checked = true;
          return;
        }
        batchWorkers = [];
        renderBatchQueue();
      }
      batchSection.hidden = true;
      submitBtn.textContent = 'Save induction';
      (document.getElementById('ct-induction-date') as HTMLInputElement).disabled = false;
      (document.getElementById('ct-expires-at') as HTMLInputElement).disabled = false;
      document.querySelectorAll('.ct-iso-check').forEach(cb => (cb as HTMLInputElement).disabled = false);
    }
  });

  async function submitInductionRecords(records: typeof batchWorkers): Promise<void> {
    if (!supabase || !authUserId || !currentContractor) return;
    submitBtn.disabled = true;
    submitGroupBtn.disabled = true;
    let successCount = 0;

    for (let i = 0; i < records.length; i++) {
      const w = records[i];
      if (records.length > 1) {
        submitBtn.textContent = `Saving ${i + 1}/${records.length}…`;
      }

      try {
        let photoUrl: string | null = null;
        let signatureUrl: string | null = null;

        if (w.photoDataUrl) {
          const photoBlob = await (await fetch(w.photoDataUrl)).blob();
          const photoResult = await uploadToStorage('induction-photos', photoBlob, 'photo', 'jpg');
          if (photoResult.error) throw new Error(`Photo upload failed: ${photoResult.error}`);
          photoUrl = photoResult.url;
        }

        if (w.signatureDataUrl) {
          const sigBlob = await (await fetch(w.signatureDataUrl)).blob();
          const sigResized = await resizeImage(sigBlob, {
            maxWidth: 200,
            maxHeight: 100,
            quality: 0.7,
            outputType: 'image/png',
          });
          const sigResult = await uploadToStorage('signatures', sigResized.blob, 'sig', 'png');
          if (sigResult.error) throw new Error(`Signature upload failed: ${sigResult.error}`);
          signatureUrl = sigResult.url;
        }

        const insertPayload: Omit<InductionRecord, 'id' | 'tenant_id' | 'created_at'> = {
          contractor_id: currentContractor.id,
          inducted_by: authUserId!,
          worker_name: w.workerName,
          worker_ic: w.workerIc,
          induction_date: w.inductionDate,
          topics_covered: w.topicsCovered,
          signature_url: signatureUrl,
          photo_url: photoUrl,
          expires_at: w.expiresAt,
        };
        const { error: createErr } = await supabase
          .from('induction_records')
          .insert(insertPayload)
          .select('id')
          .single();
        if (createErr) throw createErr;

        successCount++;
      } catch (e) {
        showError(e instanceof Error ? e.message : `Failed to save induction for worker "${w.workerName}".`);
        submitBtn.disabled = false;
        submitGroupBtn.disabled = batchWorkers.length > 0;
        return;
      }
    }

    if (currentContractor.status === 'pending_induction') {
      await supabase
        .from('contractors')
        .update({ status: 'inducted' })
        .eq('id', currentContractor.id);
    }

    if (records.length > 1) {
      alert(`Successfully saved ${successCount} induction record(s)!`);
    }
    window.location.href = `/app/contractors/${currentContractor.id}`;
  }

  submitGroupBtn.addEventListener('click', () => {
    if (batchWorkers.length === 0) return;
    if (!confirm(`Submit safety induction logs for this group of ${batchWorkers.length} worker(s)?`)) return;
    submitInductionRecords(batchWorkers);
  });

  formEl.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    if (!supabase || !authUserId || !currentContractor) return;
    clearError();

    const workerName = (document.getElementById('ct-worker-name') as HTMLInputElement).value.trim();
    const workerIc   = workerIcEl.value.trim();
    const inductionDate = (document.getElementById('ct-induction-date') as HTMLInputElement).value;
    const expiresAt = (document.getElementById('ct-expires-at') as HTMLInputElement).value || null;

    if (!workerName) { showError('Worker name is required.'); return; }
    if (!workerIc)   { showError('IC number is required.'); return; }
    if (!inductionDate) { showError('Induction date is required.'); return; }
    if (!ackEl.checked) { showError('The worker must acknowledge the declaration before submitting.'); return; }
    if (expiresAt && expiresAt < inductionDate) {
      showError('Expiry date cannot be earlier than the induction date.');
      return;
    }

    // Validate all 3 declaration checkboxes are checked
    const isoChecks = document.querySelectorAll<HTMLInputElement>('.ct-iso-check');
    const checkedTopics: string[] = [];
    for (const cb of isoChecks) {
      if (!cb.checked) {
        showError('Please check all Safety Declaration items before submitting.');
        return;
      }
      checkedTopics.push(cb.dataset.topic ?? '');
    }

    const workerData = {
      workerName,
      workerIc,
      inductionDate,
      expiresAt,
      topicsCovered: checkedTopics,
      photoDataUrl: photoData.value || cameraPhotoData || null,
      signatureDataUrl: sigLocalDataUrl || null,
    };

    if (groupToggle.checked) {
      // Group mode: queue the worker
      batchWorkers.push(workerData);
      renderBatchQueue();
      // Clear worker fields
      (document.getElementById('ct-worker-name') as HTMLInputElement).value = '';
      workerIcEl.value = '';
      searchIcEl.value = '';
      sigClear.click();
      clearCanvas();
      photoData.value = '';
      photoPreviewWrap.hidden = true;
      photoInput.value = '';
      photoInfo.textContent = 'No file selected.';
      cameraPhotoData = null;
      capturedPhoto.style.display = 'none';
      videoFeed.style.display = 'none';
      if (cameraStream) {
        cameraStream.getTracks().forEach(track => track.stop());
        cameraStream = null;
      }
      btnOpenCamera.style.display = 'inline-flex';
      btnCapture.style.display = 'none';
      btnSwitchCamera.style.display = 'none';
      btnRetake.style.display = 'none';
    } else {
      // Single mode: submit immediately
      submitInductionRecords([workerData]);
    }
  });

  if (supabase) {
    loadContractor().catch(() => {
      showError('Failed to load contractor.');
    });
  }
</script>

