---
// Induct a new worker for a specific contractor company.
//
// Uses the shared imageResize + storage helpers for the optional
// photo + signature. On submit:
//   1. client-side validation
//   2. upload photo + signature to Supabase Storage (if provided)
//   3. insert induction_records row
//   4. if this is the contractor's first induction, auto-flip
//      contractors.status to 'inducted'
//   5. redirect to /app/contractors/<id>
import AppLayout from '../../../../layouts/AppLayout.astro';

export function getStaticPaths() {
  return [{ params: { id: '_' } }];
}
---
<AppLayout title="Induct Worker - AmerisPro">
  <main class="ct-induct-page">
    <div class="container">
      <div id="ct-setup-warning" class="ct-warning" hidden>
        <strong>Setup required.</strong>
        <span>
          Supabase environment variables are not configured. Copy
          <code>.env.example</code> to <code>.env</code>, fill in your
          Supabase credentials, then restart the dev server.
        </span>
      </div>

      <div id="ct-error" class="ct-error" hidden></div>

      <header class="ct-header">
        <div>
          <h1>Induct worker</h1>
          <p class="ct-sub" id="ct-sub">Loading contractor…</p>
        </div>
        <a id="ct-back-link" href="/app/contractors" class="ct-link-btn">← Back</a>
      </header>

      <form id="ct-form" novalidate>
        <!-- A. Worker info -->
        <fieldset class="ct-fieldset">
          <legend>A. Worker information</legend>

          <div class="ct-row-2">
            <label class="field">
              <span class="field-label">Worker name <em>*</em></span>
              <input type="text" name="worker_name" id="ct-worker-name" required placeholder="e.g. Ahmad bin Ali" />
            </label>
            <label class="field">
              <span class="field-label">IC number <em>*</em></span>
              <input type="text" name="worker_ic" id="ct-worker-ic" required placeholder="e.g. 880515-14-5678" />
            </label>
          </div>

          <div class="ct-row-2">
            <label class="field">
              <span class="field-label">Induction date <em>*</em></span>
              <input type="date" name="induction_date" id="ct-induction-date" required />
            </label>
            <label class="field">
              <span class="field-label">Expires at</span>
              <input type="date" name="expires_at" id="ct-expires-at" />
              <span class="field-hint">Optional. Used by the IC lookup to flag expired inductions.</span>
            </label>
          </div>
        </fieldset>

        <!-- B. Photo upload -->
        <fieldset class="ct-fieldset">
          <legend>B. Photo (optional)</legend>
          <p class="ct-hint">Take or choose a photo of the worker. Resized to max 800×800 before upload.</p>
          <label class="field">
            <span class="field-label">Worker photo</span>
            <input type="file" id="ct-photo-input" accept="image/*" capture="environment" />
            <span class="field-hint" id="ct-photo-info">No file selected.</span>
          </label>
          <div id="ct-photo-preview-wrap" hidden>
            <img id="ct-photo-preview" class="ct-photo-preview" alt="Worker photo preview" />
            <button type="button" id="ct-photo-remove" class="ct-secondary-btn">Remove photo</button>
          </div>
          <input type="hidden" name="photo_data_url" id="ct-photo-data" />
        </fieldset>

        <!-- C. Signature -->
        <fieldset class="ct-fieldset">
          <legend>C. Signature (optional)</legend>
          <p class="ct-hint">Worker signs below with mouse or finger. Resized to 200×100 before upload.</p>
          <div class="ct-sig-controls">
            <button type="button" id="ct-sig-save" class="ct-secondary-btn">Save signature</button>
            <button type="button" id="ct-sig-clear" class="ct-secondary-btn">Clear</button>
          </div>
          <canvas id="ct-sig-pad" class="ct-sig-pad" width="600" height="160" aria-label="Signature pad"></canvas>
          <input type="hidden" name="signature_data_url" id="ct-sig-data" />
          <div id="ct-sig-preview-wrap" hidden>
            <p class="ct-hint">Saved signature:</p>
            <img id="ct-sig-preview" class="ct-sig-preview" alt="Signature preview" />
          </div>
        </fieldset>

        <!-- D. Declaration -->
        <fieldset class="ct-fieldset">
          <legend>D. Declaration</legend>
          <div class="ct-callout" id="ct-declaration">Loading…</div>
          <label class="field-check">
            <input type="checkbox" name="ack" id="ct-ack" required />
            <span>The worker acknowledges the above declaration. <em>*</em></span>
          </label>
        </fieldset>

        <div class="ct-form-actions">
          <a id="ct-cancel-link" href="/app/contractors" class="ct-secondary-btn">Cancel</a>
          <button type="submit" id="ct-submit" class="ct-primary-btn">Save induction</button>
        </div>
      </form>
    </div>
  </main>
</AppLayout>

<script>
  import { getSupabase, isSupabaseConfigured } from '../../../../lib/supabase';
  import { resizeImage, formatBytes, ResizeError } from '../../../../lib/imageResize';
  import { uploadToStorage } from '../../../../lib/storage';
  import type { Contractor, ContractorDeclaration, InductionRecord } from '../../../../lib/types';

  const setupWarning = document.getElementById('ct-setup-warning') as HTMLElement;
  const errorEl = document.getElementById('ct-error') as HTMLElement;
  const formEl = document.getElementById('ct-form') as HTMLFormElement;
  const submitBtn = document.getElementById('ct-submit') as HTMLButtonElement;
  const subEl = document.getElementById('ct-sub') as HTMLElement;
  const backLinkEl = document.getElementById('ct-back-link') as HTMLAnchorElement;
  const cancelLinkEl = document.getElementById('ct-cancel-link') as HTMLAnchorElement;

  const photoInput = document.getElementById('ct-photo-input') as HTMLInputElement;
  const photoInfo = document.getElementById('ct-photo-info') as HTMLElement;
  const photoPreviewWrap = document.getElementById('ct-photo-preview-wrap') as HTMLElement;
  const photoPreview = document.getElementById('ct-photo-preview') as HTMLImageElement;
  const photoRemove = document.getElementById('ct-photo-remove') as HTMLButtonElement;
  const photoData = document.getElementById('ct-photo-data') as HTMLInputElement;

  const sigPad = document.getElementById('ct-sig-pad') as HTMLCanvasElement;
  const sigSave = document.getElementById('ct-sig-save') as HTMLButtonElement;
  const sigClear = document.getElementById('ct-sig-clear') as HTMLButtonElement;
  const sigData = document.getElementById('ct-sig-data') as HTMLInputElement;
  const sigPreviewWrap = document.getElementById('ct-sig-preview-wrap') as HTMLElement;

  const declarationEl = document.getElementById('ct-declaration') as HTMLElement;
  const ackEl = document.getElementById('ct-ack') as HTMLInputElement;

  function showError(msg: string): void {
    errorEl.hidden = false;
    errorEl.textContent = msg;
    errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
  function clearError(): void { errorEl.hidden = true; errorEl.textContent = ''; }

  function today(): string {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  }

  function getContractorId(): string {
    const path = window.location.pathname;
    const m = path.match(/\/app\/contractors\/([^/]+)\/induct/);
    return m ? m[1] : '';
  }

  function readQueryIc(): string {
    const params = new URLSearchParams(window.location.search);
    return params.get('ic') ?? '';
  }

  // --- Signature pad -----------------------------------------------------
  let drawing = false;
  function getCtx(): CanvasRenderingContext2D | null { return sigPad.getContext('2d'); }
  function clearCanvas(): void {
    const ctx = getCtx();
    if (ctx) ctx.clearRect(0, 0, sigPad.width, sigPad.height);
  }
  function pos(ev: MouseEvent | TouchEvent): { x: number; y: number } {
    const rect = sigPad.getBoundingClientRect();
    const scaleX = sigPad.width / rect.width;
    const scaleY = sigPad.height / rect.height;
    if (ev instanceof TouchEvent) {
      const t = ev.touches[0] ?? ev.changedTouches[0];
      return { x: (t.clientX - rect.left) * scaleX, y: (t.clientY - rect.top) * scaleY };
    }
    return { x: (ev.clientX - rect.left) * scaleX, y: (ev.clientY - rect.top) * scaleY };
  }
  function bindPad(): void {
    const ctx = getCtx();
    if (!ctx) return;
    ctx.lineWidth = 2;
    ctx.lineCap = 'round';
    ctx.strokeStyle = '#1E1E1D';
    sigPad.addEventListener('mousedown', (e) => { drawing = true; const p = pos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); });
    sigPad.addEventListener('mousemove', (e) => { if (!drawing) return; const p = pos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); });
    sigPad.addEventListener('mouseup', () => { drawing = false; });
    sigPad.addEventListener('mouseleave', () => { drawing = false; });
    sigPad.addEventListener('touchstart', (e) => { e.preventDefault(); drawing = true; const p = pos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); }, { passive: false });
    sigPad.addEventListener('touchmove', (e) => { e.preventDefault(); if (!drawing) return; const p = pos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); }, { passive: false });
    sigPad.addEventListener('touchend', () => { drawing = false; });
  }
  sigClear.addEventListener('click', () => {
    clearCanvas();
    sigData.value = '';
    sigPreviewWrap.hidden = true;
    sigLocalDataUrl = null;
  });
  sigSave.addEventListener('click', () => {
    sigLocalDataUrl = sigPad.toDataURL('image/png');
    sigPreview.src = sigLocalDataUrl;
    sigPreviewWrap.hidden = false;
    sigData.value = 'pending-upload';
  });

  // --- Photo handling ---------------------------------------------------
  photoInput.addEventListener('change', async () => {
    clearError();
    const file = photoInput.files?.[0];
    if (!file) return;
    photoInfo.textContent = `Resizing ${file.name} (${formatBytes(file.size)})…`;
    try {
      const result = await resizeImage(file, {
        maxWidth: 800,
        maxHeight: 800,
        quality: 0.7,
        outputType: 'image/jpeg',
      });
      photoData.value = result.dataUrl;
      photoPreview.src = result.dataUrl;
      photoPreviewWrap.hidden = false;
      photoInfo.textContent = `${file.name}: ${formatBytes(result.originalSize)} → ${formatBytes(result.newSize)} (${result.width}×${result.height})`;
    } catch (e) {
      photoInfo.textContent = 'Resize failed; the original file will be uploaded.';
      photoData.value = '';
      photoPreviewWrap.hidden = true;
      if (e instanceof ResizeError) {
        photoInfo.textContent = `Resize failed: ${e.message}. Original file will be uploaded.`;
      } else {
        photoInfo.textContent = 'Resize failed; the original file will be uploaded.';
      }
    }
  });
  photoRemove.addEventListener('click', () => {
    photoInput.value = '';
    photoData.value = '';
    photoPreviewWrap.hidden = true;
    photoInfo.textContent = 'No file selected.';
  });

  // --- Init + submit ----------------------------------------------------
  let currentContractor: Contractor | null = null;
  let authUserId: string | null = null;
  let supabase: ReturnType<typeof getSupabase> | null = null;
  const sigPreview = document.getElementById('ct-sig-preview') as HTMLImageElement;
  let sigLocalDataUrl: string | null = null;

  if (!isSupabaseConfigured()) {
    setupWarning.hidden = false;
    submitBtn.disabled = true;
  } else {
    supabase = getSupabase();
    (document.getElementById('ct-induction-date') as HTMLInputElement).value = today();
    setTimeout(bindPad, 50);
  }

  async function loadContractor(): Promise<void> {
    if (!supabase) return;
    const id = getContractorId();
    if (!id || id === '_') {
      showError('Invalid contractor id.');
      submitBtn.disabled = true;
      return;
    }
    const prefillIc = readQueryIc();
    if (prefillIc) {
      (document.getElementById('ct-worker-ic') as HTMLInputElement).value = prefillIc;
    }
    try {
      const { data: userData, error: userErr } = await supabase.auth.getUser();
      if (userErr || !userData.user) {
        window.location.replace('/login');
        return;
      }
      authUserId = userData.user.id;

      const { data: contractor, error: cErr } = await supabase
        .from('contractors')
        .select('*')
        .eq('id', id)
        .maybeSingle<Contractor>();
      if (cErr || !contractor) {
        showError('Contractor not found.');
        submitBtn.disabled = true;
        return;
      }
      currentContractor = contractor;
      subEl.textContent = `For ${contractor.company_name}`;
      backLinkEl.href = `/app/contractors/${contractor.id}`;
      cancelLinkEl.href = `/app/contractors/${contractor.id}`;

      try {
        const { data: decl } = await supabase.rpc<ContractorDeclaration>('get_contractor_declaration');
        declarationEl.textContent = (decl && String(decl).trim()) || 'No declaration text configured. Set one in /app/settings.';
      } catch {
        declarationEl.textContent = 'Failed to load declaration text.';
      }
    } catch (e) {
      showError(e instanceof Error ? e.message : 'Failed to load contractor.');
      submitBtn.disabled = true;
    }
  }

  formEl.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    if (!supabase || !authUserId || !currentContractor) return;
    clearError();

    const workerName = (document.getElementById('ct-worker-name') as HTMLInputElement).value.trim();
    const workerIc   = (document.getElementById('ct-worker-ic') as HTMLInputElement).value.trim();
    const inductionDate = (document.getElementById('ct-induction-date') as HTMLInputElement).value;
    const expiresAt = (document.getElementById('ct-expires-at') as HTMLInputElement).value || null;

    if (!workerName) { showError('Worker name is required.'); return; }
    if (!workerIc)   { showError('IC number is required.'); return; }
    if (!inductionDate) { showError('Induction date is required.'); return; }
    if (!ackEl.checked) { showError('The worker must acknowledge the declaration before submitting.'); return; }
    if (expiresAt && expiresAt < inductionDate) {
      showError('Expiry date cannot be earlier than the induction date.');
      return;
    }

    submitBtn.disabled = true;
    const original = submitBtn.textContent;
    submitBtn.textContent = 'Saving…';

    try {
      let photoUrl: string | null = null;
      let signatureUrl: string | null = null;

      if (photoData.value) {
        const photoBlob = await (await fetch(photoData.value)).blob();
        const photoResult = await uploadToStorage('induction-photos', photoBlob, 'photo', 'jpg');
        if (photoResult.error) throw new Error(`Photo upload failed: ${photoResult.error}`);
        photoUrl = photoResult.url;
      } else if (photoInput.files && photoInput.files[0]) {
        const photoBlob = photoInput.files[0];
        const photoResult = await uploadToStorage('induction-photos', photoBlob, 'photo', 'jpg');
        if (photoResult.error) throw new Error(`Photo upload failed: ${photoResult.error}`);
        photoUrl = photoResult.url;
      }

      if (sigLocalDataUrl) {
        const sigBlob = await (await fetch(sigLocalDataUrl)).blob();
        const sigResized = await resizeImage(sigBlob, {
          maxWidth: 200,
          maxHeight: 100,
          quality: 0.7,
          outputType: 'image/png',
        });
        const sigResult = await uploadToStorage('signatures', sigResized.blob, 'sig', 'png');
        if (sigResult.error) throw new Error(`Signature upload failed: ${sigResult.error}`);
        signatureUrl = sigResult.url;
      }

      const insertPayload: Omit<InductionRecord, 'id' | 'tenant_id' | 'created_at'> = {
        contractor_id: currentContractor.id,
        inducted_by: authUserId!,
        worker_name: workerName,
        worker_ic: workerIc,
        induction_date: inductionDate,
        topics_covered: [],
        signature_url: signatureUrl,
        photo_url: photoUrl,
        expires_at: expiresAt,
      };
      const { error: createErr } = await supabase
        .from('induction_records')
        .insert(insertPayload)
        .select('id')
        .single();
      if (createErr) throw createErr;

      if (currentContractor.status === 'pending_induction') {
        await supabase
          .from('contractors')
          .update({ status: 'inducted' })
          .eq('id', currentContractor.id);
      }

      window.location.href = `/app/contractors/${currentContractor.id}`;
    } catch (e) {
      showError(e instanceof Error ? e.message : 'Failed to save induction.');
      submitBtn.disabled = false;
      submitBtn.textContent = original;
    }
  });

  if (supabase) {
    loadContractor().catch(() => {
      showError('Failed to load contractor.');
    });
  }
</script>

<style>
  .ct-induct-page { padding: 32px 0 64px; }
  .ct-warning,
  .ct-error {
    padding: 14px 18px;
    margin-bottom: 24px;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .ct-warning { background: #FFF7E6; border: 1px solid #E58E1A; color: #6A4A0F; }
  .ct-warning code { background: rgba(0,0,0,0.06); padding: 1px 4px; font-size: 0.85rem; }
  .ct-error { background: #FDECEC; border: 1px solid #C0392B; color: #8B1A1A; }

  .ct-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .ct-header h1 { font-size: 1.8rem; font-weight: 900; margin-bottom: 4px; }
  .ct-sub { color: var(--color-text-muted, #6A6A69); font-size: 0.9rem; }
  .ct-link-btn {
    background: transparent;
    border: 1px solid var(--color-border, #E0E0E0);
    color: var(--color-text, #1E1E1D);
    padding: 9px 14px;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
  .ct-link-btn:hover { color: var(--color-primary, #E58E1A); border-color: var(--color-primary, #E58E1A); }

  .ct-fieldset {
    background: var(--color-bg, #fff);
    border: 1px solid var(--color-border, #E0E0E0);
    padding: 20px 24px;
    margin-bottom: 20px;
  }
  .ct-fieldset legend {
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 0 8px;
  }
  .ct-hint {
    font-size: 0.85rem;
    color: var(--color-text-muted, #6A6A69);
    margin-bottom: 12px;
  }
  .ct-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  @media (max-width: 600px) { .ct-row-2 { grid-template-columns: 1fr; } }

  .field { display: block; margin-bottom: 16px; }
  .field-label {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
  }
  .field-label em { color: var(--color-primary, #E58E1A); font-style: normal; }
  .field-hint {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted, #6A6A69);
    margin-top: 4px;
  }
  .field input, .field textarea, .field select {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--color-border, #E0E0E0);
    font-family: inherit;
    font-size: 0.9rem;
    background: var(--color-bg, #fff);
  }
  .field input:focus, .field textarea:focus, .field select:focus {
    outline: 2px solid var(--color-primary, #E58E1A);
    outline-offset: 1px;
    border-color: var(--color-primary, #E58E1A);
  }
  .field-check {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-top: 8px;
    font-size: 0.9rem;
  }
  .field-check em { color: var(--color-primary, #E58E1A); font-style: normal; }

  .ct-photo-preview {
    display: block;
    max-width: 240px;
    height: auto;
    border: 1px solid var(--color-border, #E0E0E0);
    margin: 8px 0;
  }
  .ct-sig-pad {
    border: 1px solid var(--color-border, #E0E0E0);
    background: #fff;
    display: block;
    width: 100%;
    max-width: 600px;
    height: 160px;
    touch-action: none;
    margin-bottom: 8px;
    cursor: crosshair;
  }
  .ct-sig-preview {
    border: 1px solid var(--color-border, #E0E0E0);
    background: #fff;
    max-width: 320px;
    height: auto;
  }
  .ct-sig-controls { margin-bottom: 8px; }

  .ct-callout {
    background: var(--color-bg-grey, #F4F4F4);
    border: 1px solid var(--color-border-light, #F0F0F0);
    border-left: 4px solid var(--color-primary, #E58E1A);
    padding: 14px 18px;
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .ct-secondary-btn {
    background: transparent;
    border: 1px solid var(--color-border, #E0E0E0);
    color: var(--color-text, #1E1E1D);
    padding: 8px 14px;
    font-family: inherit;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
  .ct-secondary-btn:hover:not(:disabled) { color: var(--color-primary, #E58E1A); border-color: var(--color-primary, #E58E1A); }
  .ct-secondary-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .ct-primary-btn {
    background: var(--color-primary, #E58E1A);
    color: #fff;
    border: none;
    padding: 12px 24px;
    font-family: inherit;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
  }
  .ct-primary-btn:hover:not(:disabled) { background: var(--color-primary-hover, #D07D12); }
  .ct-primary-btn:disabled { opacity: 0.6; cursor: not-allowed; }

  .ct-form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-top: 8px;
  }
</style>
