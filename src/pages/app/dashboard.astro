---
import AppLayout from '../../layouts/AppLayout.astro';

const setupWarning = !import.meta.env.PUBLIC_SUPABASE_URL || !import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---
<AppLayout title="Dashboard - AmerisPro">


  <main class="dashboard-page">
    <div class="container">
      <div id="dash-setup-warning" class="dash-warning" hidden={!setupWarning}>
        <strong>Setup required.</strong>
        <span>
          Supabase environment variables are not configured. Copy
          <code>.env.example</code> to <code>.env</code>, fill in your
          Supabase credentials, then restart the dev server.
        </span>
      </div>

      <section id="dash-hero" class="dash-hero" hidden>
        <h1>Welcome, <span id="dash-tenant-name">…</span></h1>
        <p class="dash-company" id="dash-company-name">…</p>
        <div class="dash-meta">
          <span id="dash-plan-badge" class="plan-badge plan-free">Free</span>
          <span class="dash-expiry" id="dash-expiry">No expiry set</span>
        </div>
      </section>

      <section id="dash-error" class="dash-error" hidden>
        Failed to load workspace data. Please refresh the page.
      </section>

      <div id="dash-mobile-tabs" class="dash-mobile-tabs">
        <button type="button" id="dash-tab-overview" class="dash-tab-btn active">📊 Overview</button>
        <button type="button" id="dash-tab-activity" class="dash-tab-btn">⚡ Activity Feed</button>
      </div>

      <div class="dash-grid-layout">
        <section id="dash-metrics" hidden>
          <h2 class="dash-section-title">Overview</h2>
          <div class="metric-grid">
            <a href="/app/first-aid" class="metric-tile" id="metric-first-aid">
              <div class="metric-tile-head">
                <span class="metric-tile-icon" aria-hidden="true">⛑️</span>
                <span class="metric-tile-label">First Aid Boxes</span>
              </div>
              <div class="metric-tile-value" data-role="value">—</div>
              <div class="metric-tile-sub" data-role="sub">…</div>
            </a>
            <a href="/app/ppe" class="metric-tile" id="metric-ppe">
              <div class="metric-tile-head">
                <span class="metric-tile-icon" aria-hidden="true">🦺</span>
                <span class="metric-tile-label">PPE Issues</span>
              </div>
              <div class="metric-tile-value" data-role="value">—</div>
              <div class="metric-tile-sub" data-role="sub">…</div>
            </a>
            <a href="/app/contractors" class="metric-tile" id="metric-contractors">
              <div class="metric-tile-head">
                <span class="metric-tile-icon" aria-hidden="true">👷</span>
                <span class="metric-tile-label">Contractors</span>
              </div>
              <div class="metric-tile-value" data-role="value">—</div>
              <div class="metric-tile-sub" data-role="sub">…</div>
            </a>
            <a href="/app/incidents" class="metric-tile" id="metric-incidents">
              <div class="metric-tile-head">
                <span class="metric-tile-icon" aria-hidden="true">🚨</span>
                <span class="metric-tile-label">Incidents</span>
              </div>
              <div class="metric-tile-value" data-role="value">—</div>
              <div class="metric-tile-sub" data-role="sub">…</div>
            </a>
            <a href="/app/staff" class="metric-tile" id="metric-staff">
              <div class="metric-tile-head">
                <span class="metric-tile-icon" aria-hidden="true">🧑‍💼</span>
                <span class="metric-tile-label">Staff Active</span>
              </div>
              <div class="metric-tile-value" data-role="value">—</div>
              <div class="metric-tile-sub" data-role="sub">…</div>
            </a>
            <a href="/app/inspections" class="metric-tile" id="metric-inspections">
              <div class="metric-tile-head">
                <span class="metric-tile-icon" aria-hidden="true">📋</span>
                <span class="metric-tile-label">Inspections</span>
              </div>
              <div class="metric-tile-value" data-role="value">—</div>
              <div class="metric-tile-sub" data-role="sub">…</div>
            </a>
          </div>
        </section>

        <section id="dash-activity" class="activity-feed" hidden>
          <h2>Recent Activity</h2>
          <div id="dash-activity-list"></div>
          <div id="dash-activity-empty" class="activity-empty" hidden>
            No recent activity yet. Start by logging a First Aid inspection, reporting an incident, or scheduling an inspection.
          </div>
        </section>
      </div>
    </div>
  </main>
</AppLayout>

<script>
  import { getSupabase, isSupabaseConfigured } from '../../lib/supabase';
  import type { Tenant } from '../../lib/types';

  // -------------------------------------------------------------------
  // Refs
  // -------------------------------------------------------------------
  const heroEl = document.getElementById('dash-hero') as HTMLElement;
  const metricsEl = document.getElementById('dash-metrics') as HTMLElement;
  const activityEl = document.getElementById('dash-activity') as HTMLElement;
  const activityListEl = document.getElementById('dash-activity-list') as HTMLElement;
  const activityEmptyEl = document.getElementById('dash-activity-empty') as HTMLElement;
  const errorEl = document.getElementById('dash-error') as HTMLElement;
  const tenantNameEl = document.getElementById('dash-tenant-name') as HTMLElement;
  const companyNameEl = document.getElementById('dash-company-name') as HTMLElement;
  const planBadgeEl = document.getElementById('dash-plan-badge') as HTMLElement;
  const expiryEl = document.getElementById('dash-expiry') as HTMLElement;

  // -------------------------------------------------------------------
  // Helpers
  // -------------------------------------------------------------------
  function showError(): void {
    errorEl.hidden = false;
  }

  function escapeHtml(s: string | null | undefined): string {
    return (s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string);
  }

  function formatDate(iso: string | null | undefined): string {
    if (!iso) return '';
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '';
    return d.toLocaleDateString(undefined, {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
  }

  /**
   * Relative time formatter. Matches the spec:
   *   < 1 min  -> "just now"
   *   < 60 min -> "{N} min ago"
   *   < 24 hr  -> "{N} hours ago"
   *   < 7 days -> "{N} days ago"
   *   else     -> "DD MMM YYYY"
   */
  function relativeTime(iso: string | null | undefined): string {
    if (!iso) return '';
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '';
    const diffSec = Math.floor((Date.now() - d.getTime()) / 1000);
    if (diffSec < 60) return 'just now';
    if (diffSec < 3600) {
      const m = Math.floor(diffSec / 60);
      return `${m} min ago`;
    }
    if (diffSec < 86400) {
      const h = Math.floor(diffSec / 3600);
      return `${h} hour${h === 1 ? '' : 's'} ago`;
    }
    if (diffSec < 604800) {
      const dys = Math.floor(diffSec / 86400);
      return `${dys} day${dys === 1 ? '' : 's'} ago`;
    }
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return `${String(d.getDate()).padStart(2, '0')} ${months[d.getMonth()]} ${d.getFullYear()}`;
  }

  // -------------------------------------------------------------------
  // Metric tile rendering
  // -------------------------------------------------------------------
  type Metric = {
    id: string;
    value: number | null;
    sub: string;
  };

  function renderMetric(m: Metric): void {
    const tile = document.getElementById(`metric-${m.id}`);
    if (!tile) return;
    const valueEl = tile.querySelector('[data-role="value"]') as HTMLElement | null;
    const subEl = tile.querySelector('[data-role="sub"]') as HTMLElement | null;
    if (valueEl) valueEl.textContent = m.value == null ? '—' : String(m.value);
    if (subEl) subEl.textContent = m.sub;
  }

  // -------------------------------------------------------------------
  // Activity feed rendering
  // -------------------------------------------------------------------
  type ActivityKind = 'first_aid' | 'ppe' | 'contractor' | 'incident' | 'staff' | 'inspection';

  type ActivityItem = {
    id: string;
    kind: ActivityKind;
    icon: string;
    title: string;
    sub: string;
    createdAt: string;
    href: string;
  };

  function getDateGroupHeader(iso: string | null | undefined): string {
    if (!iso) return 'EARLIER';
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return 'EARLIER';
    const now = new Date();
    const isToday = d.toDateString() === now.toDateString();
    if (isToday) return 'TODAY';
    
    const yesterday = new Date(now);
    yesterday.setDate(now.getDate() - 1);
    if (d.toDateString() === yesterday.toDateString()) return 'YESTERDAY';

    return 'EARLIER THIS WEEK';
  }

  function renderActivity(items: ActivityItem[]): void {
    activityListEl.innerHTML = '';
    if (items.length === 0) {
      activityEmptyEl.hidden = false;
      return;
    }
    activityEmptyEl.hidden = true;

    let currentGroup = '';

    for (const a of items) {
      const group = getDateGroupHeader(a.createdAt);
      if (group !== currentGroup) {
        currentGroup = group;
        const groupEl = document.createElement('div');
        groupEl.className = 'activity-group-label';
        groupEl.textContent = currentGroup;
        activityListEl.appendChild(groupEl);
      }

      const row = document.createElement('a');
      row.className = `activity-item activity-kind-${a.kind}`;
      row.href = a.href;
      row.innerHTML = `
        <div class="activity-item-icon act-icon-${a.kind}" aria-hidden="true">${escapeHtml(a.icon)}</div>
        <div class="activity-item-body">
          <div class="activity-item-title">${escapeHtml(a.title)}</div>
          <div class="activity-item-sub">${escapeHtml(a.sub)}</div>
        </div>
        <div class="activity-item-right">
          <span class="activity-item-time">${escapeHtml(relativeTime(a.createdAt))}</span>
          <span class="activity-item-arrow" aria-hidden="true">→</span>
        </div>
      `;
      activityListEl.appendChild(row);
    }
  }

  // Mobile Tab Switcher Handler
  const tabOverview = document.getElementById('dash-tab-overview') as HTMLButtonElement | null;
  const tabActivity = document.getElementById('dash-tab-activity') as HTMLButtonElement | null;

  function applyMobileTabState(): void {
    if (window.innerWidth <= 768) {
      const isActivityActive = tabActivity?.classList.contains('active');
      if (isActivityActive) {
        if (metricsEl) metricsEl.style.display = 'none';
        if (activityEl) activityEl.style.display = 'block';
      } else {
        if (metricsEl) metricsEl.style.display = 'block';
        if (activityEl) activityEl.style.display = 'none';
      }
    } else {
      if (metricsEl) metricsEl.style.display = '';
      if (activityEl) activityEl.style.display = '';
    }
  }

  if (tabOverview && tabActivity && metricsEl && activityEl) {
    tabOverview.addEventListener('click', () => {
      tabOverview.classList.add('active');
      tabActivity.classList.remove('active');
      applyMobileTabState();
    });

    tabActivity.addEventListener('click', () => {
      tabActivity.classList.add('active');
      tabOverview.classList.remove('active');
      applyMobileTabState();
    });

    window.addEventListener('resize', applyMobileTabState);
  }

  // -------------------------------------------------------------------
  // Boot
  // -------------------------------------------------------------------
  if (!isSupabaseConfigured()) {
    showError();
  } else {
    const supabase = getSupabase();

    (async () => {
      let user = (await supabase.auth.getUser()).data.user;
      if (!user) {
        user = (await supabase.auth.getSession()).data.session?.user ?? null;
      }
      if (!user) {
        window.location.replace('/login');
        return;
      }

      const { data: tenant, error: tenantErr } = await supabase
        .from('tenants')
        .select('*')
        .eq('owner_user_id', user.id)
        .single<Tenant>();

      if (tenantErr || !tenant) {
        // Middleware normally handles this redirect, but in a static
        // build middleware does not run, so do it client-side too.
        window.location.replace('/app/onboarding');
        return;
      }

      tenantNameEl.textContent = tenant.name;
      companyNameEl.textContent = tenant.company_name ?? '';

      if (tenant.subscription_plan === 'premium') {
        planBadgeEl.textContent = 'Premium';
        planBadgeEl.classList.remove('plan-free');
        planBadgeEl.classList.add('plan-premium');
      } else {
        planBadgeEl.textContent = 'Free';
      }

      if (tenant.subscription_expires_at) {
        expiryEl.textContent = 'Expires: ' + formatDate(tenant.subscription_expires_at);
      } else {
        expiryEl.textContent = 'No expiry set';
      }

      // ---- Fire all 16 queries in parallel -----------------------------
      // RLS auto-scopes every .from(...) to the caller's tenant, so we
      // don't need to pass tenant_id explicitly.
      const now = new Date();
      const year = now.getFullYear();
      const month = now.getMonth();
      const monthStart = `${year}-${String(month + 1).padStart(2, '0')}-01`;
      const yearStart = `${year}-01-01T00:00:00.000Z`;
      const nextYearStart = `${year + 1}-01-01T00:00:00.000Z`;
      const qStartMonth = Math.floor(month / 3) * 3;
      const quarterStart = new Date(year, qStartMonth, 1);
      const quarterStartIso = quarterStart.toISOString().slice(0, 10);

      type CountRes = { count: number | null; error: unknown };
      type RowsRes<T> = { data: T[] | null; error: unknown };

      const safe = async <T,>(p: PromiseLike<T>): Promise<T | null> => {
        try { return await p; } catch { return null; }
      };

      const [
        faMonthRes,
        ppeApprovedRes,
        ppePendingRes,
        ctInductedRes,
        ctPendingRes,
        incYearRes,
        incAwaitingRes,
        staffActiveRes,
        staffInactiveRes,
        insQuarterRes,
        insOverdueRes,
        faRecentRes,
        ppeRecentRes,
        ctRecentRes,
        incRecentRes,
        staffRecentRes,
        insRecentRes,
      ] = await Promise.all([
        // -- Metric counts (10) --------------------------------------------
        safe(supabase.from('first_aid_logs').select('*', { count: 'exact', head: true })
          .gte('incident_date', monthStart)),
        safe(supabase.from('ppe_requests').select('*', { count: 'exact', head: true })
          .eq('status', 'approved_dispatched')),
        safe(supabase.from('ppe_requests').select('*', { count: 'exact', head: true })
          .eq('status', 'pending_approval')),
        safe(supabase.from('contractors').select('*', { count: 'exact', head: true })
          .eq('status', 'inducted')),
        safe(supabase.from('contractors').select('*', { count: 'exact', head: true })
          .eq('status', 'pending_induction')),
        safe(supabase.from('incidents').select('*', { count: 'exact', head: true })
          .gte('incident_date', yearStart).lt('incident_date', nextYearStart)),
        safe(supabase.from('incidents').select('*', { count: 'exact', head: true })
          .gte('incident_date', yearStart).lt('incident_date', nextYearStart)
          .eq('investigation_submitted', false)),
        safe(supabase.from('staff').select('*', { count: 'exact', head: true })
          .eq('is_active', true)),
        safe(supabase.from('staff').select('*', { count: 'exact', head: true })
          .eq('is_active', false)),
        safe(supabase.from('inspections').select('*', { count: 'exact', head: true })
          .not('completed_date', 'is', null)
          .gte('completed_date', quarterStartIso)),
        safe(supabase.from('inspections').select('*', { count: 'exact', head: true })
          .eq('status', 'overdue')),
        // -- Activity rows (6) — top 5 from each module --------------------
        safe(supabase.from('first_aid_logs')
          .select('id, created_at, injured_person_name, injury_type')
          .order('created_at', { ascending: false })
          .limit(5)),
        safe(supabase.from('ppe_requests')
          .select('id, created_at, request_code, ppe_type, staff_name')
          .order('created_at', { ascending: false })
          .limit(5)),
        safe(supabase.from('contractors')
          .select('id, created_at, company_name')
          .order('created_at', { ascending: false })
          .limit(5)),
        safe(supabase.from('incidents')
          .select('id, created_at, incident_code, victim_name, severity_type')
          .order('created_at', { ascending: false })
          .limit(5)),
        safe(supabase.from('staff')
          .select('id, created_at, full_name, employee_id')
          .order('created_at', { ascending: false })
          .limit(5)),
        safe(supabase.from('inspections')
          .select('id, created_at, audit_code, location')
          .order('created_at', { ascending: false })
          .limit(5)),
      ]);

      // -- Render metric tiles -------------------------------------------
      const monthName = now.toLocaleDateString(undefined, { month: 'long' });
      const renderCount = (r: unknown): number | null => {
        const res = r as CountRes | null;
        if (!res || res.error) return null;
        return res.count ?? 0;
      };
      const renderRows = <T,>(r: unknown): T[] => {
        const res = r as RowsRes<T> | null;
        if (!res || res.error) return [];
        return res.data ?? [];
      };

      renderMetric({
        id: 'first-aid',
        value: renderCount(faMonthRes),
        sub: `this month (${monthName})`,
      });
      renderMetric({
        id: 'ppe',
        value: renderCount(ppeApprovedRes),
        sub: `${renderCount(ppePendingRes) ?? '—'} pending approval`,
      });
      const ctInductedN = renderCount(ctInductedRes);
      renderMetric({
        id: 'contractors',
        value: ctInductedN,
        sub: `${renderCount(ctPendingRes) ?? '—'} pending induction`,
      });
      renderMetric({
        id: 'incidents',
        value: renderCount(incYearRes),
        sub: `${renderCount(incAwaitingRes) ?? '—'} awaiting investigation`,
      });
      const staffActiveN = renderCount(staffActiveRes);
      renderMetric({
        id: 'staff',
        value: staffActiveN,
        sub: `${renderCount(staffInactiveRes) ?? '—'} inactive`,
      });
      renderMetric({
        id: 'inspections',
        value: renderCount(insQuarterRes),
        sub: `${renderCount(insOverdueRes) ?? '—'} overdue`,
      });

      // -- Build activity feed -------------------------------------------
      type Raw = { id: string; created_at: string };
      const items: ActivityItem[] = [];

      for (const r of renderRows<Raw & { injured_person_name: string; injury_type: string }>(faRecentRes)) {
        items.push({
          id: r.id,
          kind: 'first_aid',
          icon: '⛑️',
          title: r.injury_type ? `First Aid: ${r.injury_type}` : 'First Aid Box Inspection',
          sub: r.injured_person_name ? `Reported by ${r.injured_person_name}` : 'Log recorded',
          createdAt: r.created_at,
          href: `/app/first-aid/${encodeURIComponent(r.id)}`,
        });
      }
      for (const r of renderRows<Raw & { request_code: string; ppe_type: string; staff_name: string }>(ppeRecentRes)) {
        items.push({
          id: r.id,
          kind: 'ppe',
          icon: '🦺',
          title: `${r.request_code} — ${r.ppe_type}`,
          sub: r.staff_name ? `Requested by ${r.staff_name}` : 'PPE Issue recorded',
          createdAt: r.created_at,
          href: `/app/ppe/${encodeURIComponent(r.id)}`,
        });
      }
      for (const r of renderRows<Raw & { company_name: string }>(ctRecentRes)) {
        items.push({
          id: r.id,
          kind: 'contractor',
          icon: '👷',
          title: r.company_name || 'New contractor',
          sub: 'Contractor registered',
          createdAt: r.created_at,
          href: `/app/contractors/${encodeURIComponent(r.id)}`,
        });
      }
      for (const r of renderRows<Raw & { incident_code: string; victim_name: string; severity_type: string }>(incRecentRes)) {
        items.push({
          id: r.id,
          kind: 'incident',
          icon: '🚨',
          title: `${r.incident_code} — ${r.victim_name || 'Incident reported'}`,
          sub: `Severity: ${r.severity_type || 'Standard'}`,
          createdAt: r.created_at,
          href: `/app/incidents/new?id=${encodeURIComponent(r.id)}`,
        });
      }
      for (const r of renderRows<Raw & { full_name: string; employee_id: string }>(staffRecentRes)) {
        items.push({
          id: r.id,
          kind: 'staff',
          icon: '🧑‍💼',
          title: r.full_name || 'New staff member',
          sub: r.employee_id ? `Employee ID: ${r.employee_id}` : 'Staff added to directory',
          createdAt: r.created_at,
          href: `/app/staff?id=${encodeURIComponent(r.id)}`,
        });
      }
      for (const r of renderRows<Raw & { audit_code: string | null; location: string }>(insRecentRes)) {
        items.push({
          id: r.id,
          kind: 'inspection',
          icon: '📋',
          title: r.audit_code || 'Safety Inspection',
          sub: r.location ? `Location: ${r.location}` : 'Inspection recorded',
          createdAt: r.created_at,
          href: `/app/inspections/${encodeURIComponent(r.id)}`,
        });
      }

      items.sort((a, b) => {
        const ta = new Date(a.createdAt).getTime();
        const tb = new Date(b.createdAt).getTime();
        return tb - ta;
      });

      renderActivity(items.slice(0, 10));

      heroEl.hidden = false;
      metricsEl.hidden = false;
      activityEl.hidden = false;
      applyMobileTabState();
    })().catch(() => {
      showError();
    });
  }
</script>

<style>
  .dashboard-page {
    padding: 16px 0 32px;
  }
  .dash-warning,
  .dash-error {
    padding: 12px 16px;
    margin-bottom: 16px;
    font-size: 0.85rem;
    line-height: 1.4;
  }
  .dash-warning {
    background: #FFF7E6;
    border: 3px solid var(--border);
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
    color: #6A4A0F;
  }
  .dash-warning code {
    background: rgba(0,0,0,0.06);
    padding: 1px 4px;
    font-size: 0.8rem;
  }
  .dash-error {
    background: #FDECEC;
    border: 3px solid var(--border);
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
    color: #8B1A1A;
  }
  .dash-hero {
    margin-bottom: 24px;
  }
  .dash-hero h1 {
    font-size: 1.7rem;
    font-weight: 900;
    margin-bottom: 2px;
  }
  .dash-company {
    color: var(--color-text-muted, #6A6A69);
    font-size: 0.95rem;
    margin-bottom: 8px;
  }
  .dash-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .plan-badge {
    display: inline-block;
    padding: 3px 8px;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border: 2px solid var(--border);
    border-radius: 6px;
  }
  .plan-free {
    background: var(--warning);
    color: var(--text-main);
  }
  .plan-premium {
    background: var(--success);
    color: var(--text-main);
  }
  .dash-expiry {
    font-size: 0.8rem;
    color: var(--color-text-muted, #6A6A69);
  }
  .dash-section-title {
    font-size: 1.15rem;
    font-weight: 900;
    margin-bottom: 12px;
  }

  /* Split grid layout for desktop */
  @media (min-width: 1024px) {
    .dash-grid-layout {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 24px;
      align-items: start;
    }
  }

  /* Metric tiles */
  .metric-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
    margin: 0;
  }
  .metric-tile {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 12px 14px !important;
  }
  /* Metric Tile Header Layout */
