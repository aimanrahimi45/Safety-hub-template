---
import AppLayout from '../../../layouts/AppLayout.astro';

export function getStaticPaths() {
  return [{ params: { id: '_' } }];
}
---
<AppLayout title="First Aid Record - AmerisPro">
  <main class="fa-detail-page">
    <div class="container">
      <div id="fa-setup-warning" class="fa-warning" hidden>
        <strong>Setup required.</strong>
        <span>
          Supabase environment variables are not configured. Copy
          <code>.env.example</code> to <code>.env</code>, fill in your
          Supabase credentials, then restart the dev server.
        </span>
      </div>

      <div id="fa-error" class="fa-error" hidden></div>

      <section id="fa-loading" class="fa-loading">
        <div class="skel-row"></div>
        <div class="skel-row"></div>
        <div class="skel-row"></div>
      </section>

      <section id="fa-not-found" class="fa-not-found" hidden>
        <h1>Record not found</h1>
        <p>This first aid record doesn't exist, or you don't have permission to view it.</p>
        <a href="/app/first-aid" class="fa-link-btn">← Back to list</a>
      </section>

      <section id="fa-content" hidden>
        <header class="fa-header">
          <div>
            <h1 id="fa-page-title">First Aid Box Inspection</h1>
            <p class="fa-sub" id="fa-sub">Inspection ID: <span class="fa-id" id="fa-id">…</span></p>
          </div>
          <div class="fa-header-actions">
            <a href="/app/first-aid" class="fa-link-btn">← Back to list</a>
          </div>
        </header>

        <!-- LAYOUT A: First Aid Box Inspection Checklist (New) -->
        <div id="fa-view-inspection" hidden>
          <section class="fa-card">
            <h2>Inspection Details</h2>
            <div class="fa-grid-2">
              <div><span class="fa-label">Date of Inspection</span><span id="fa-ins-date">…</span></div>
              <div><span class="fa-label">First Aid Box ID</span><span id="fa-ins-boxid">…</span></div>
              <div class="fa-grid-full"><span class="fa-label">Location</span><span id="fa-ins-location">…</span></div>
              <div><span class="fa-label">Company</span><span id="fa-ins-company">…</span></div>
              <div><span class="fa-label">Department / Section</span><span id="fa-ins-dept">…</span></div>
              <div><span class="fa-label">Inspected By</span><span id="fa-ins-officer">…</span></div>
              <div><span class="fa-label">Position</span><span id="fa-ins-pos">…</span></div>
              <div><span class="fa-label">Box Cleanliness &amp; Condition</span><span id="fa-ins-cleanliness" class="fa-badge">…</span></div>
              <div class="fa-grid-full">
                <span class="fa-label">Cleanliness Remarks</span>
                <span id="fa-ins-cleanremarks">…</span>
              </div>
              <div class="fa-grid-full">
                <span class="fa-label">Findings &amp; Corrective Actions</span>
                <div class="fa-block" id="fa-ins-findings">…</div>
              </div>
            </div>
          </section>

          <section class="fa-card">
            <h2>Checklist Items Status</h2>
            <table class="fa-items-table">
              <thead>
                <tr>
                  <th scope="col">Item Description</th>
                  <th scope="col" style="width: 100px;">Required</th>
                  <th scope="col" class="fa-qty-col" style="width: 120px;">Available Qty</th>
                  <th scope="col" style="width: 120px;">Expiry Date</th>
                  <th scope="col">Remarks / Notes</th>
                </tr>
              </thead>
              <tbody id="fa-ins-checklist-tbody"></tbody>
            </table>
          </section>
        </div>

        <!-- LAYOUT B: Incident / Treatment Log (Fallback for Old Records) -->
        <div id="fa-view-incident" hidden>
          <section class="fa-card">
            <h2>Incident details</h2>
            <div class="fa-grid-2">
              <div><span class="fa-label">Date</span><span id="fa-date">…</span></div>
              <div><span class="fa-label">Time</span><span id="fa-time">…</span></div>
              <div class="fa-grid-full"><span class="fa-label">Location</span><span id="fa-location">…</span></div>
              <div><span class="fa-label">Injured person</span><span id="fa-injured">…</span></div>
              <div><span class="fa-label">Employee ID</span><span id="fa-empid">…</span></div>
              <div class="fa-grid-full"><span class="fa-label">Injury type</span><span id="fa-injury">…</span></div>
              <div class="fa-grid-full">
                <span class="fa-label">Treatment given</span>
                <div class="fa-block" id="fa-treatment">…</div>
              </div>
              <div>
                <span class="fa-label">Referred to hospital</span>
                <span id="fa-referred">…</span>
              </div>
              <div id="fa-hospital-cell" hidden>
                <span class="fa-label">Hospital</span>
                <span id="fa-hospital">…</span>
              </div>
            </div>
          </section>

          <section class="fa-card">
            <h2>Items used</h2>
            <div id="fa-items-empty" class="fa-empty-inline" hidden>No items recorded for this incident.</div>
            <table id="fa-items-table" class="fa-items-table" hidden>
              <thead>
                <tr>
                  <th scope="col">Item description</th>
                  <th scope="col" class="fa-qty-col">Qty</th>
                  <th scope="col">Notes</th>
                </tr>
              </thead>
              <tbody id="fa-items-tbody"></tbody>
            </table>
          </section>
        </div>

        <!-- SHARED: Inventory Refill Deduction Card -->
        <section id="fa-deduct-card" class="fa-card" hidden>
          <h2 id="fa-deduct-card-title">Inventory deduction</h2>
          <div id="fa-deduct-yes" class="fa-banner fa-banner-ok" hidden>
            <span>✓ Inventory deducted automatically.</span>
            <a href="/app/inventory" class="fa-banner-link">View transactions →</a>
          </div>
          <div id="fa-deduct-no" class="fa-banner fa-banner-warn" hidden>
            <span>Shortages refills have not yet been deducted from central cabinet inventory.</span>
            <button type="button" id="fa-deduct-now" class="fa-secondary-btn">Deduct shortages now</button>
          </div>
          <div id="fa-deduct-error" class="fa-error" hidden></div>
        </section>

        <!-- SHARED: Digital Sign-off Card -->
        <section id="fa-sig-card" class="fa-card" hidden>
          <h2>Digital Verification Sign-off</h2>
          <div id="fa-sig-yes" hidden>
            <img id="fa-sig-image" class="fa-sig-display" alt="Reporter signature" />
            <div class="fa-muted" id="fa-sig-uploaded">…</div>
          </div>
          <div id="fa-sig-no" class="fa-empty-inline" hidden>No signature was captured for this record.</div>
        </section>
      </section>
    </div>
  </main>
</AppLayout>

<script>
  import { getSupabase, isSupabaseConfigured } from '../../../lib/supabase';
  import type { FirstAidLog, FirstAidDetail } from '../../../lib/types';

  type Detail = FirstAidDetail;

  const setupWarning = document.getElementById('fa-setup-warning') as HTMLElement;
  const errorEl = document.getElementById('fa-error') as HTMLElement;
  const loadingEl = document.getElementById('fa-loading') as HTMLElement;
  const notFoundEl = document.getElementById('fa-not-found') as HTMLElement;
  const contentEl = document.getElementById('fa-content') as HTMLElement;
  const pageTitleEl = document.getElementById('fa-page-title') as HTMLElement;

  const idEl = document.getElementById('fa-id') as HTMLElement;
  const subEl = document.getElementById('fa-sub') as HTMLElement;

  // Layout A Refs
  const viewInspection = document.getElementById('fa-view-inspection') as HTMLElement;
  const insDateEl = document.getElementById('fa-ins-date') as HTMLElement;
  const insBoxIdEl = document.getElementById('fa-ins-boxid') as HTMLElement;
  const insLocationEl = document.getElementById('fa-ins-location') as HTMLElement;
  const insCompanyEl = document.getElementById('fa-ins-company') as HTMLElement;
  const insDeptEl = document.getElementById('fa-ins-dept') as HTMLElement;
  const insOfficerEl = document.getElementById('fa-ins-officer') as HTMLElement;
  const insPosEl = document.getElementById('fa-ins-pos') as HTMLElement;
  const insCleanlinessEl = document.getElementById('fa-ins-cleanliness') as HTMLElement;
  const insCleanRemarksEl = document.getElementById('fa-ins-cleanremarks') as HTMLElement;
  const insFindingsEl = document.getElementById('fa-ins-findings') as HTMLElement;
  const insChecklistTbody = document.getElementById('fa-ins-checklist-tbody') as HTMLElement;

  // Layout B Refs
  const viewIncident = document.getElementById('fa-view-incident') as HTMLElement;
  const dateEl = document.getElementById('fa-date') as HTMLElement;
  const timeEl = document.getElementById('fa-time') as HTMLElement;
  const locationEl = document.getElementById('fa-location') as HTMLElement;
  const injuredEl = document.getElementById('fa-injured') as HTMLElement;
  const empIdEl = document.getElementById('fa-empid') as HTMLElement;
  const injuryEl = document.getElementById('fa-injury') as HTMLElement;
  const treatmentEl = document.getElementById('fa-treatment') as HTMLElement;
  const referredEl = document.getElementById('fa-referred') as HTMLElement;
  const hospitalCell = document.getElementById('fa-hospital-cell') as HTMLElement;
  const hospitalEl = document.getElementById('fa-hospital') as HTMLElement;
  const itemsEmpty = document.getElementById('fa-items-empty') as HTMLElement;
  const itemsTable = document.getElementById('fa-items-table') as HTMLElement;
  const itemsTbody = document.getElementById('fa-items-tbody') as HTMLElement;

  // Shared Card Refs
  const deductCard = document.getElementById('fa-deduct-card') as HTMLElement;
  const deductCardTitle = document.getElementById('fa-deduct-card-title') as HTMLElement;
  const deductYes = document.getElementById('fa-deduct-yes') as HTMLElement;
  const deductNo = document.getElementById('fa-deduct-no') as HTMLElement;
  const deductNowBtn = document.getElementById('fa-deduct-now') as HTMLButtonElement;
  const deductErrEl = document.getElementById('fa-deduct-error') as HTMLElement;
  const sigCard = document.getElementById('fa-sig-card') as HTMLElement;
  const sigYes = document.getElementById('fa-sig-yes') as HTMLElement;
  const sigNo = document.getElementById('fa-sig-no') as HTMLElement;
  const sigImage = document.getElementById('fa-sig-image') as HTMLImageElement;
  const sigUploaded = document.getElementById('fa-sig-uploaded') as HTMLElement;

  function showError(msg: string): void {
    errorEl.hidden = false;
    errorEl.textContent = msg;
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string);
  }

  function formatDate(iso: string): string {
    const d = new Date(iso + 'T00:00:00');
    if (Number.isNaN(d.getTime())) return iso;
    const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const day = String(d.getDate()).padStart(2, '0');
    return `${day} ${months[d.getMonth()]} ${d.getFullYear()}`;
  }
  function formatDateTime(iso: string): string {
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return iso;
    return d.toLocaleString(undefined, { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  function getLogId(): string {
    const path = window.location.pathname;
    const m = path.match(/\/app\/first-aid\/([^/]+)/);
    return m ? m[1] : '';
  }

  let currentLogId: string | null = null;
  let currentUserId: string | null = null;
  let supabase: ReturnType<typeof getSupabase> | null = null;

  function renderLog(log: FirstAidLog, items: Detail[]): void {
    currentLogId = log.id;
    idEl.textContent = log.id;

    // Check if the record is a serialized checklist JSON
    let isChecklist = false;
    let checklistData: any = null;

    try {
      if (log.treatment_given && log.treatment_given.trim().startsWith('{')) {
        checklistData = JSON.parse(log.treatment_given);
        if (checklistData && Array.isArray(checklistData.checklist)) {
          isChecklist = true;
        }
      }
    } catch {
      isChecklist = false;
    }

    if (isChecklist && checklistData) {
      pageTitleEl.textContent = 'First Aid Box Inspection';
      subEl.textContent = `Completed Inspection Log on ${formatDate(log.incident_date)}`;
      
      // Load Layout A
      viewInspection.hidden = false;
      viewIncident.hidden = true;

      insDateEl.textContent = formatDate(log.incident_date);
      insBoxIdEl.textContent = log.injury_type || '—'; // Mapped Box ID
      insLocationEl.textContent = log.location;
      insCompanyEl.textContent = checklistData.company || '—';
      insDeptEl.textContent = `${checklistData.department || '—'} / ${checklistData.section || '—'}`;
      insOfficerEl.textContent = log.injured_person_name || '—';
      insPosEl.textContent = checklistData.officer_position || 'Safety Officer';
      
      const clean = checklistData.cleanliness || 'Good';
      insCleanlinessEl.textContent = clean;
      insCleanlinessEl.className = 'fa-badge ' + (clean.toLowerCase() === 'good' ? 'fa-badge-yes' : 'fa-badge-no');
      insCleanRemarksEl.textContent = checklistData.cleanliness_remarks || '—';
      insFindingsEl.textContent = checklistData.findings || 'No findings recorded.';

      insChecklistTbody.innerHTML = '';
      checklistData.checklist.forEach((it: any) => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td><strong>${escapeHtml(it.name)}</strong></td>
          <td><span class="fa-badge-no" style="padding: 2px 6px; font-weight: 700;">${it.req}</span></td>
          <td class="fa-qty-col">${it.avail}</td>
          <td>${escapeHtml(it.exp || '—')}</td>
          <td>${escapeHtml(it.remarks || '—')}</td>
        `;
        insChecklistTbody.appendChild(tr);
      });

      if (log.referred_to_hospital) { // Mapped restocked check
        deductCard.hidden = false;
        deductCardTitle.textContent = 'Inventory Auto-Refill Status';
        if (log.deducted_from_inventory) {
          deductYes.hidden = false;
          deductNo.hidden = true;
        } else {
          deductYes.hidden = true;
          deductNo.hidden = false;
        }
      } else {
        deductCard.hidden = true;
      }

    } else {
      // Fallback to Layout B: Treatment/Incident Log
      pageTitleEl.textContent = 'First Aid Incident Log';
      subEl.textContent = `Logged Treatment on ${formatDate(log.incident_date)} at ${(log.incident_time ?? '').slice(0, 5) || '—'}`;

      viewInspection.hidden = true;
      viewIncident.hidden = false;

      dateEl.textContent = formatDate(log.incident_date);
      timeEl.textContent = (log.incident_time ?? '').slice(0, 5) || '—';
      locationEl.textContent = log.location;
      injuredEl.textContent = log.injured_person_name;
      empIdEl.textContent = log.injured_person_id ?? '—';
      injuryEl.textContent = log.injury_type;
      treatmentEl.textContent = log.treatment_given;
      
      if (log.referred_to_hospital) {
        referredEl.textContent = 'Yes';
        hospitalCell.hidden = false;
        hospitalEl.textContent = log.hospital_name ?? '—';
      } else {
        referredEl.textContent = 'No';
        hospitalCell.hidden = true;
      }

      itemsTbody.innerHTML = '';
      if (items.length === 0) {
        itemsEmpty.hidden = false;
        itemsTable.hidden = true;
      } else {
        itemsEmpty.hidden = true;
        itemsTable.hidden = false;
        for (const it of items) {
          const tr = document.createElement('tr');
          tr.innerHTML = `
            <td>${escapeHtml(it.item_description)}</td>
            <td class="fa-qty-col">${it.quantity}</td>
            <td>${escapeHtml(it.notes ?? '')}</td>
          `;
          itemsTbody.appendChild(tr);
        }
      }

      if (items.length > 0) {
        deductCard.hidden = false;
        deductCardTitle.textContent = 'Inventory deduction';
        if (log.deducted_from_inventory) {
          deductYes.hidden = false;
          deductNo.hidden = true;
        } else {
          deductYes.hidden = true;
          deductNo.hidden = false;
        }
      } else {
        deductCard.hidden = true;
      }
    }

    sigCard.hidden = false;
    if (log.signature_url) {
      sigYes.hidden = false;
      sigNo.hidden = true;
      sigImage.src = log.signature_url;
      sigUploaded.textContent = log.signature_uploaded_at
        ? `Verified Sign-off ${formatDateTime(log.signature_uploaded_at)}`
        : 'Verified Sign-off';
    } else {
      sigYes.hidden = true;
      sigNo.hidden = false;
    }

    loadingEl.hidden = true;
    contentEl.hidden = false;
  }

  async function load(): Promise<void> {
    if (!supabase) return;
    const id = getLogId();
    if (!id || id === '_') {
      loadingEl.hidden = true;
      notFoundEl.hidden = false;
      return;
    }

    try {
      const { data: log, error: logErr } = await supabase
        .from('first_aid_logs')
        .select('*')
        .eq('id', id)
        .single<FirstAidLog>();
      if (logErr || !log) {
        loadingEl.hidden = true;
        notFoundEl.hidden = false;
        return;
      }

      const { data: items, error: itemsErr } = await supabase
        .from('first_aid_details')
        .select('*')
        .eq('first_aid_log_id', id)
        .order('created_at');
      if (itemsErr) throw itemsErr;

      renderLog(log, (items ?? []) as Detail[]);
    } catch (e) {
      loadingEl.hidden = true;
      showError(e instanceof Error ? e.message : 'Failed to load first aid record.');
    }
  }

  if (!isSupabaseConfigured()) {
    setupWarning.hidden = false;
  } else {
    supabase = getSupabase();
    (async () => {
      const { data: userData, error: userErr } = await supabase.auth.getUser();
      if (userErr || !userData.user) {
        window.location.replace('/login');
        return;
      }
      currentUserId = userData.user.id;
      await load();
    })().catch(() => {
      showError('Failed to initialise page.');
    });

    deductNowBtn.addEventListener('click', () => {
      if (!currentLogId || !currentUserId) return;
      deductNowBtn.disabled = true;
      const original = deductNowBtn.textContent;
      deductNowBtn.textContent = 'Deducting…';
      clearError();
      deductErrEl.hidden = true;

      (async () => {
        try {
          const { error } = await supabase!.rpc('deduct_inventory_for_first_aid', {
            p_first_aid_log_id: currentLogId,
            p_actor_id: currentUserId,
          });
          if (error) {
            const m = error.message;
            if (/No matching inventory item for:/i.test(m)) {
              const detail = m.replace(/^No matching inventory item for:\s*/i, '').trim();
              const itemName = detail.split(',')[0]?.trim() ?? detail;
              throw new Error(`Item "${itemName}" not found in central inventory.`);
            }
            if (/Insufficient stock:/i.test(m)) {
              throw new Error('Insufficient stock in central cabinet inventory.');
            }
            throw error;
          }
          deductYes.hidden = false;
          deductNo.hidden = true;
        } catch (e) {
          deductErrEl.hidden = false;
          deductErrEl.textContent = e instanceof Error ? e.message : 'Deduction failed.';
          deductNowBtn.disabled = false;
          deductNowBtn.textContent = original;
        }
      })();
    });
  }
</script>

<style>
  .fa-detail-page { padding: 32px 0 64px; }
  .fa-warning,
  .fa-error {
    padding: 14px 18px;
    margin-bottom: 24px;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .fa-warning { background: #FFF7E6; border: 1px solid #E58E1A; color: #6A4A0F; }
  .fa-warning code { background: rgba(0,0,0,0.06); padding: 1px 4px; font-size: 0.85rem; }
  .fa-error { background: #FDECEC; border: 1px solid #C0392B; color: #8B1A1A; }

  .fa-loading {
    display: grid;
    gap: 12px;
    padding: 40px 0;
  }
  .skel-row {
    height: 32px;
    background: linear-gradient(90deg, #F4F4F4 0%, #ECECEC 50%, #F4F4F4 100%);
    background-size: 200% 100%;
    animation: skel-shimmer 1.4s infinite;
  }
  @keyframes skel-shimmer { from { background-position: 200% 0; } to { background-position: -200% 0; } }

  .fa-not-found {
    background: var(--color-bg, #fff);
    border: 1px solid var(--color-border, #E0E0E0);
    padding: 48px;
    text-align: center;
  }
  .fa-not-found h1 { font-size: 1.6rem; font-weight: 900; margin-bottom: 12px; }
  .fa-not-found p { font-size: 0.95rem; color: var(--color-text-muted, #6A6A69); margin-bottom: 24px; }

  .fa-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }
  .fa-header h1 { font-size: 1.8rem; font-weight: 900; margin-bottom: 4px; }
  .fa-id { color: var(--color-primary, #E58E1A); font-weight: 700; }
  .fa-sub { color: var(--color-text-muted, #6A6A69); font-size: 0.9rem; }
  .fa-link-btn {
    background: transparent;
    border: 1px solid var(--color-border, #E0E0E0);
    color: var(--color-text, #1E1E1D);
    padding: 9px 14px;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }
  .fa-link-btn:hover { color: var(--color-primary, #E58E1A); border-color: var(--color-primary, #E58E1A); }

  .fa-status-badge {
    display: inline-block;
    padding: 6px 14px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.5px;
  }
  .fa-status-open { background: #FFF7E6; color: #D07D12; border: 1px solid #FFE7BA; }
  .fa-status-closed { background: #E8F5E9; color: #1F7A4D; border: 1px solid #C8E6C9; }

  .fa-card {
    background: var(--color-bg, #fff);
    border: 1px solid var(--color-border, #E0E0E0);
    padding: 24px 28px;
    margin-bottom: 20px;
  }
  .fa-card h2 {
    font-size: 1.05rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 16px;
    color: var(--color-text, #1E1E1D);
  }
  .fa-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    row-gap: 16px;
    column-gap: 24px;
  }
  .fa-grid-full { grid-column: 1 / span 2; }
  @media (max-width: 768px) {
    .fa-grid-2 { grid-template-columns: 1fr; }
    .fa-grid-full { grid-column: auto; }
  }
  .fa-label {
    display: block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-text-muted, #6A6A69);
    margin-bottom: 4px;
  }
  .fa-block {
    background: var(--color-bg-grey, #F4F4F4);
    border: 1px solid var(--color-border, #E0E0E0);
    padding: 12px 16px;
    font-size: 0.92rem;
    line-height: 1.6;
    white-space: pre-wrap;
    margin-top: 4px;
  }
  .fa-badge {
    display: inline-block;
    padding: 2px 8px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .fa-badge-yes { background: #E8F5E9; color: #1F7A4D; }
  .fa-badge-no { background: #FFF1F0; color: #CF1322; }

