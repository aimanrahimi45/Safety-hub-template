---
import AppLayout from '../../../layouts/AppLayout.astro';
---
<AppLayout title="First Aid Box Inspection - AmerisPro">
  <main class="fa-new-page">
    <div class="container">
      <div id="fa-setup-warning" class="fa-warning" hidden>
        <strong>Setup required.</strong>
        <span>
          Supabase environment variables are not configured. Copy
          <code>.env.example</code> to <code>.env</code>, fill in your
          Supabase credentials, then restart the dev server.
        </span>
      </div>

      <div id="fa-error" class="fa-error" hidden></div>

      <header class="fa-header">
        <div>
          <h1>First Aid Box Inspection</h1>
          <p class="fa-sub">Monthly box compliance checklist and inventory restock log.</p>
        </div>
        <a href="/app/first-aid" class="fa-link-btn">← Back to list</a>
      </header>

      <form id="fa-form" novalidate>
        <!-- Section A: Metadata -->
        <fieldset class="fa-fieldset">
          <legend>A. Inspection Metadata</legend>

          <div class="fa-row-2">
            <label class="field">
              <span class="field-label">Date of Inspection <em>*</em></span>
              <input type="date" name="inspect_date" id="fa-inspect-date" required />
            </label>
            <label class="field">
              <span class="field-label">Company <em>*</em></span>
              <input type="text" name="company" id="fa-company" required placeholder="e.g. AmerisPro Safety" />
            </label>
          </div>

          <div class="fa-row-3">
            <label class="field">
              <span class="field-label">Department <em>*</em></span>
              <input type="text" name="department" id="fa-dept" required placeholder="e.g. Production" />
            </label>
            <label class="field">
              <span class="field-label">Section <em>*</em></span>
              <input type="text" name="section" id="fa-section" required placeholder="e.g. Main Plant" />
            </label>
            <label class="field">
              <span class="field-label">First Aid Box ID <em>*</em></span>
              <input type="text" name="box_id" id="fa-box-id" required placeholder="e.g. Box A" />
            </label>
          </div>

          <label class="field">
            <span class="field-label">Location <em>*</em></span>
            <input type="text" name="location" id="fa-location" required placeholder="e.g. Office / Warehouse" />
          </label>
        </fieldset>

        <!-- Section B: Cleanliness -->
        <fieldset class="fa-fieldset">
          <legend>B. Box Condition &amp; Cleanliness</legend>

          <div class="fa-row-2">
            <label class="field">
              <span class="field-label">Box Cleanliness &amp; Condition <em>*</em></span>
              <select name="cleanliness" id="fa-cleanliness" required>
                <option value="Good" selected>Good</option>
                <option value="Fair">Fair</option>
                <option value="Poor">Poor</option>
              </select>
            </label>
            <label class="field">
              <span class="field-label">Cleanliness Remarks</span>
              <input type="text" name="cleanliness_remarks" id="fa-cleanliness-remarks" placeholder="Optional notes on cleanliness..." />
            </label>
          </div>
        </fieldset>

        <!-- Section C: Checklist Items -->
        <fieldset class="fa-fieldset">
          <legend>C. Checklist Items</legend>
          <div class="fa-autofill-bar">
            <span>ISO 45001 standard quantities check.</span>
            <button type="button" id="fa-quickfill-btn" class="fa-secondary-btn">⚡ Autofill Standard Quantities</button>
          </div>

          <table class="fa-items-table" aria-label="First aid box items checked">
            <thead>
              <tr>
                <th scope="col">Item Description</th>
                <th scope="col" style="width: 100px;">Required</th>
                <th scope="col" class="fa-qty-col" style="width: 120px;">Available Qty</th>
                <th scope="col" style="width: 130px;">Expiry Date</th>
                <th scope="col">Remarks / Notes</th>
              </tr>
            </thead>
            <tbody id="fa-checklist-tbody">
              <tr>
                <td colspan="5" style="text-align:center; padding: 20px; color: var(--color-text-muted);">
                  Loading checklist items...
                </td>
              </tr>
            </tbody>
          </table>
        </fieldset>

        <!-- Section D: Sign-off -->
        <fieldset class="fa-fieldset">
          <legend>D. Inspection Findings &amp; Digital Sign-off</legend>

          <label class="field">
            <span class="field-label">Inspection Findings / Corrective Action (If any)</span>
            <textarea name="findings" id="fa-findings" rows="3" placeholder="Describe any corrective actions needed or taken..."></textarea>
          </label>

          <div class="fa-row-2">
            <label class="field">
              <span class="field-label">Inspected By (Name) <em>*</em></span>
              <input type="text" name="officer_name" id="fa-officer-name" required placeholder="e.g. Safety Inspector" />
            </label>
            <label class="field">
              <span class="field-label">Position <em>*</em></span>
              <input type="text" name="officer_position" id="fa-officer-position" required value="Safety Officer" />
            </label>
          </div>

          <div class="fa-field" id="fa-sig-pad-fieldset">
            <span class="field-label">Digital Verification Sign-off <em>*</em></span>
            <p class="fa-hint">ISO 45001 Compliance requires a safety inspection signature before submission.</p>
            <div class="fa-sig-controls">
              <button type="button" id="fa-sig-clear" class="fa-secondary-btn">Clear Signature</button>
            </div>
            <div class="fa-sig-pad-wrap">
              <canvas id="fa-sig-pad" class="fa-sig-pad" width="600" height="180" aria-label="Signature pad"></canvas>
            </div>
            <input type="hidden" name="signature_url" id="fa-sig-data" />
          </div>

          <label class="field-check fa-restock-check">
            <input type="checkbox" name="instant_restock" id="fa-instant-restock" />
            <span><strong>Instant Restock:</strong> Deduct shortages from central inventory automatically on submit</span>
          </label>
        </fieldset>

        <div class="fa-form-actions">
          <a href="/app/first-aid" class="fa-secondary-btn">Cancel</a>
          <button type="submit" id="fa-submit" class="fa-primary-btn">Submit Inspection Log</button>
        </div>
      </form>
    </div>
  </main>

  <!-- Deduction prompt modal -->
  <div id="fa-deduct-modal" class="fa-modal" hidden role="dialog" aria-modal="true" aria-labelledby="fa-deduct-title">
    <div class="fa-modal-card">
      <header class="fa-modal-head">
        <h2 id="fa-deduct-title">Deduct shortages from inventory?</h2>
        <button type="button" class="fa-modal-close" id="fa-deduct-close" aria-label="Close">×</button>
      </header>
      <div class="fa-modal-body">
        <p>Shortages dispatched for refill:</p>
        <ul id="fa-deduct-list" class="fa-deduct-list"></ul>
        <p>Deduct these quantities from your central cabinet inventory now?</p>
      </div>
      <div id="fa-deduct-error" class="fa-error" hidden></div>
      <div class="fa-modal-actions">
        <button type="button" class="fa-secondary-btn" id="fa-deduct-skip">No, skip</button>
        <button type="button" class="fa-primary-btn" id="fa-deduct-go">Yes, deduct</button>
      </div>
    </div>
  </div>
</AppLayout>

<script>
  import { getSupabase, isSupabaseConfigured } from '../../../lib/supabase';
  import { resizeImage } from '../../../lib/imageResize';
  import { uploadToStorage } from '../../../lib/storage';
  import type { FirstAidLog, FirstAidDetail } from '../../../lib/types';

  const setupWarning = document.getElementById('fa-setup-warning') as HTMLElement;
  const errorEl = document.getElementById('fa-error') as HTMLElement;
  const formEl = document.getElementById('fa-form') as HTMLFormElement;
  const submitBtn = document.getElementById('fa-submit') as HTMLButtonElement;

  const dateEl = document.getElementById('fa-inspect-date') as HTMLInputElement;
  const companyEl = document.getElementById('fa-company') as HTMLInputElement;
  const deptEl = document.getElementById('fa-dept') as HTMLInputElement;
  const sectionEl = document.getElementById('fa-section') as HTMLInputElement;
  const boxIdEl = document.getElementById('fa-box-id') as HTMLInputElement;
  const locationEl = document.getElementById('fa-location') as HTMLInputElement;
  const cleanlinessEl = document.getElementById('fa-cleanliness') as HTMLSelectElement;
  const cleanlinessRemarksEl = document.getElementById('fa-cleanliness-remarks') as HTMLInputElement;
  const findingsEl = document.getElementById('fa-findings') as HTMLTextAreaElement;
  const officerNameEl = document.getElementById('fa-officer-name') as HTMLInputElement;
  const officerPosEl = document.getElementById('fa-officer-position') as HTMLInputElement;
  const restockCheckEl = document.getElementById('fa-instant-restock') as HTMLInputElement;
  const quickfillBtn = document.getElementById('fa-quickfill-btn') as HTMLButtonElement;

  const checklistTbody = document.getElementById('fa-checklist-tbody') as HTMLElement;
  const sigClear = document.getElementById('fa-sig-clear') as HTMLButtonElement;
  const sigPad = document.getElementById('fa-sig-pad') as HTMLCanvasElement;
  const sigData = document.getElementById('fa-sig-data') as HTMLInputElement;

  const deductModal = document.getElementById('fa-deduct-modal') as HTMLElement;
  const deductList = document.getElementById('fa-deduct-list') as HTMLElement;
  const deductError = document.getElementById('fa-deduct-error') as HTMLElement;
  const deductClose = document.getElementById('fa-deduct-close') as HTMLButtonElement;
  const deductSkip = document.getElementById('fa-deduct-skip') as HTMLButtonElement;
  const deductGo = document.getElementById('fa-deduct-go') as HTMLButtonElement;

  let activeTenantId: string | null = null;
  let savedLogId: string | null = null;
  let authUserId: string | null = null;
  let supabase: ReturnType<typeof getSupabase> | null = null;
  let checklistItems: Array<{ id: string | number; name: string; req: string | number; unit: string; exp?: string }> = [];

  const DEFAULT_CHECKLIST_ITEMS = [
    { id: 1, name: "Triangular Bandage 100cm", req: 5, unit: "pcs" },
    { id: 2, name: "Eye Dressing No 16", req: 3, unit: "pkt" },
    { id: 3, name: "Sterile Gamgee Pad 25cm", req: 3, unit: "pkt" },
    { id: 4, name: "Sterile Gauze Pad 7.5cm", req: 6, unit: "pkt" },
    { id: 5, name: "Sterile Gauze Pad 10cm", req: 6, unit: "pkt" },
    { id: 6, name: "Elastic Bandage", req: 3, unit: "pkt" },
    { id: 7, name: "W.O.W Bandage 2.5cm", req: 8, unit: "pcs" },
    { id: 8, name: "W.O.W Bandage 5.0cm", req: 8, unit: "pcs" },
    { id: 9, name: "W.O.W Bandage 7.5cm", req: 8, unit: "pcs" },
    { id: 10, name: "Instant Ice Pack", req: 6, unit: "pkt" },
    { id: 11, name: "Sterile Non-Adherent Pad", req: 6, unit: "pkt" },
    { id: 12, name: "Pair of Glove", req: 6, unit: "pkt" },
    { id: 13, name: "Scissors", req: 1, unit: "pcs" },
    { id: 14, name: "Adhesive Tape", req: 1, unit: "pcs" },
    { id: 15, name: "Bactigras", req: 2, unit: "pcs" },
    { id: 16, name: "Yellow Antiseptic Liquid", req: 1, unit: "pcs" },
    { id: 17, name: "Cotton Bud 100pcs", req: 1, unit: "pkt" },
    { id: 18, name: "CPR Face Shield", req: 3, unit: "pcs" },
    { id: 19, name: "Adhesive Plaster", req: 60, unit: "pcs" },
    { id: 20, name: "Safety Pin", req: 36, unit: "pcs" },
    { id: 21, name: "Thermometer", req: 1, unit: "pcs" },
    { id: 22, name: "Waste Bag", req: 3, unit: "pcs" },
    { id: 23, name: "First Aid Manual", req: 1, unit: "pcs" }
  ];

  function showError(msg: string): void {
    errorEl.hidden = false;
    errorEl.textContent = msg;
    errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
  function clearError(): void { errorEl.hidden = true; errorEl.textContent = ''; }
  function showDeductError(msg: string): void { deductError.hidden = false; deductError.textContent = msg; }
  function clearDeductError(): void { deductError.hidden = true; deductError.textContent = ''; }

  function today(): string {
    const d = new Date();
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  }

  // --- Render Dynamic Checklist ---
  function renderChecklist(): void {
    checklistTbody.innerHTML = '';
    checklistItems.forEach((item) => {
      const tr = document.createElement('tr');
      tr.className = 'item-row';
      tr.innerHTML = `
        <td><strong class="item-name">${item.name}</strong></td>
        <td><span class="fa-badge-no" style="padding: 2px 6px; font-weight: 700;">${item.req} ${item.unit}</span></td>
        <td class="fa-qty-col">
          <input type="number" class="fa-item-avail" data-id="${item.id}" data-req="${item.req}" min="0" value="${item.req}" required style="width: 80px; padding: 6px;" />
        </td>
        <td>
          <input type="text" class="fa-item-exp" data-id="${item.id}" placeholder="MM/YY" value="${item.exp || ''}" style="width: 100px; padding: 6px;" />
        </td>
        <td>
          <input type="text" class="fa-item-remarks" data-id="${item.id}" placeholder="Optional notes" style="width: 100%; padding: 6px;" />
        </td>
      `;
      checklistTbody.appendChild(tr);
    });
  }

  // --- Signature Pad Binding ---
  let drawing = false;
  let sigDrawn = false;
  function getCtx(): CanvasRenderingContext2D | null { return sigPad.getContext('2d'); }
  function clearCanvas(): void {
    const ctx = getCtx();
    if (ctx) ctx.clearRect(0, 0, sigPad.width, sigPad.height);
    sigDrawn = false;
  }
  function pos(ev: MouseEvent | TouchEvent): { x: number; y: number } {
    const rect = sigPad.getBoundingClientRect();
    const scaleX = sigPad.width / rect.width;
    const scaleY = sigPad.height / rect.height;
    if (ev instanceof TouchEvent) {
      const t = ev.touches[0] ?? ev.changedTouches[0];
      return { x: (t.clientX - rect.left) * scaleX, y: (t.clientY - rect.top) * scaleY };
    }
    return { x: (ev.clientX - rect.left) * scaleX, y: (ev.clientY - rect.top) * scaleY };
  }
  function bindPad(): void {
    const ctx = getCtx();
    if (!ctx) return;
    ctx.lineWidth = 3;
    ctx.lineCap = 'round';
    ctx.strokeStyle = '#2B2D42';

    sigPad.addEventListener('mousedown', (e) => { drawing = true; const p = pos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); });
    sigPad.addEventListener('mousemove', (e) => { if (!drawing) return; const p = pos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); sigDrawn = true; });
    sigPad.addEventListener('mouseup', () => { drawing = false; });
    sigPad.addEventListener('mouseleave', () => { drawing = false; });
    sigPad.addEventListener('touchstart', (e) => { e.preventDefault(); drawing = true; const p = pos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); }, { passive: false });
    sigPad.addEventListener('touchmove', (e) => { e.preventDefault(); if (!drawing) return; const p = pos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); sigDrawn = true; }, { passive: false });
    sigPad.addEventListener('touchend', () => { drawing = false; });
  }

  // --- Boot ---
  if (!isSupabaseConfigured()) {
    setupWarning.hidden = false;
    submitBtn.disabled = true;
  } else {
    supabase = getSupabase();
    dateEl.value = today();
    bindPad();

    (async () => {
      const { data: userData, error: userErr } = await supabase.auth.getUser();
      if (userErr || !userData.user) {
        window.location.replace('/login');
        return;
      }
      authUserId = userData.user.id;

      // Query active tenant (tries tenant_members, falls back to tenants for solo mode)
      let tenantId = null;

      try {
        const { data: memberData, error: memberErr } = await supabase
          .from('tenant_members')
          .select('tenant_id')
          .eq('user_id', authUserId)
          .eq('is_active', true)
          .limit(1);

        if (!memberErr && memberData && memberData.length > 0) {
          tenantId = memberData[0].tenant_id;
        }
      } catch {
        // tenant_members query might throw if table does not exist
      }

      if (!tenantId) {
        // Fallback to tenants table (Solo-SHO mode)
        const { data: tenantData, error: tenantErr } = await supabase
          .from('tenants')
          .select('id')
          .eq('owner_user_id', authUserId)
          .limit(1);

        if (!tenantErr && tenantData && tenantData.length > 0) {
          tenantId = tenantData[0].id;
        }
      }

      if (!tenantId) {
        showError('You do not belong to an active tenant workspace.');
        return;
      }
      activeTenantId = tenantId;

      // Load items from central inventory to populate the checklist
      try {
        const { data: invItems, error: invErr } = await supabase
          .from('first_aid_inventory')
          .select('*')
          .eq('is_active', true)
          .order('item_name');
        if (!invErr && invItems && invItems.length > 0) {
          checklistItems = invItems.map((it) => ({
            id: it.id,
            name: it.item_name,
            req: parseInt(it.required_std, 10) || 1,
            unit: it.unit || 'pcs'
          }));
        } else {
          checklistItems = JSON.parse(JSON.stringify(DEFAULT_CHECKLIST_ITEMS));
        }
      } catch {
        checklistItems = JSON.parse(JSON.stringify(DEFAULT_CHECKLIST_ITEMS));
      }
      renderChecklist();
    })().catch(() => {
      showError('Failed to initialise checklist.');
    });
  }

  // Quick fill handler
  quickfillBtn.addEventListener('click', () => {
    const inputs = checklistTbody.querySelectorAll<HTMLInputElement>('input.fa-item-avail');
    inputs.forEach((input) => {
      const req = input.dataset.req || '0';
      input.value = req;
    });
  });

  sigClear.addEventListener('click', () => clearCanvas());

  function openDeductPrompt(logId: string, items: Array<{ item_description: string; quantity: number }>): void {
    savedLogId = logId;
    deductList.innerHTML = '';
    for (const it of items) {
      const li = document.createElement('li');
      li.textContent = `${it.quantity} × ${it.item_description}`;
      deductList.appendChild(li);
    }
    clearDeductError();
    deductModal.hidden = false;
  }
  deductClose.addEventListener('click', () => { window.location.href = savedLogId ? `/app/first-aid/${savedLogId}` : '/app/first-aid'; });
  deductSkip.addEventListener('click', () => { window.location.href = savedLogId ? `/app/first-aid/${savedLogId}` : '/app/first-aid'; });
  deductGo.addEventListener('click', () => {
    if (!savedLogId || !authUserId) return;
    clearDeductError();
    deductGo.disabled = true;
    const original = deductGo.textContent;
    deductGo.textContent = 'Deducting…';
    (async () => {
      try {
        const { error } = await supabase!.rpc('deduct_inventory_for_first_aid', {
          p_first_aid_log_id: savedLogId,
          p_actor_id: authUserId,
        });
        if (error) {
          const m = error.message;
          if (/No matching inventory item for:/i.test(m)) {
            const detail = m.replace(/^No matching inventory item for:\s*/i, '').trim();
            const itemName = detail.split(',')[0]?.trim() ?? detail;
            throw new Error(`Item "${itemName}" not found in central inventory. Add it in Inventory first, or skip and restock manually.`);
          }
          if (/Insufficient stock:/i.test(m)) {
            throw new Error('Insufficient central stock. Please restock your central inventory before executing auto-restock.');
          }
          throw error;
        }
        window.location.href = `/app/first-aid/${savedLogId}`;
      } catch (e) {
        showDeductError(e instanceof Error ? e.message : 'Deduction failed.');
        deductGo.disabled = false;
        deductGo.textContent = original;
      }
    })();
  });

  formEl.addEventListener('submit', (ev) => {
    ev.preventDefault();
    if (!supabase) return;
    clearError();

    const inspectDate = dateEl.value;
    const company = companyEl.value.trim();
    const dept = deptEl.value.trim();
    const section = sectionEl.value.trim();
    const boxId = boxIdEl.value.trim();
    const location = locationEl.value.trim();
    const cleanliness = cleanlinessEl.value;
    const cleanlinessRemarks = cleanlinessRemarksEl.value.trim();
    const findings = findingsEl.value.trim();
    const officerName = officerNameEl.value.trim();
    const officerPos = officerPosEl.value.trim();
    const instantRestock = restockCheckEl.checked;

    if (!inspectDate || !company || !dept || !section || !boxId || !location || !officerName || !officerPos) {
      showError('Please fill in all required fields.');
      return;
    }

    if (!sigDrawn) {
      showError('ISO 45001 Compliance requires a safety inspector signature before submission.');
      return;
    }

    submitBtn.disabled = true;
    const original = submitBtn.textContent;
    submitBtn.textContent = 'Submitting…';

    (async () => {
      try {
        // 1. Upload Signature
        let signatureUrl: string | null = null;
        let signatureUploadedAt: string | null = null;
        
        const sigLocalDataUrl = sigPad.toDataURL('image/png');
        const sigBlob = await (await fetch(sigLocalDataUrl)).blob();
        const resized = await resizeImage(sigBlob, {
          maxWidth: 600,
          maxHeight: 200,
          quality: 0.7,
          outputType: 'image/png',
        });
        const uploaded = await uploadToStorage('signatures', resized.blob, 'sig_fa', 'png');
        if (uploaded.error) {
          throw new Error(`Signature upload failed: ${uploaded.error}`);
        }
        signatureUrl = uploaded.url;
        signatureUploadedAt = new Date().toISOString();

        // 2. Gather Checklist details and serialize as JSON for treatment_given
        const itemsList: Array<{ name: string; req: number; avail: number; exp: string; remarks: string }> = [];
        const shortages: Array<{ item_description: string; quantity: number }> = [];

        const rows = checklistTbody.querySelectorAll<HTMLTableRowElement>('tr.item-row');
        rows.forEach((row) => {
          const name = row.querySelector('.item-name')?.textContent || '';
          const availInput = row.querySelector<HTMLInputElement>('input.fa-item-avail');
          const expInput = row.querySelector<HTMLInputElement>('input.fa-item-exp');
          const remarksInput = row.querySelector<HTMLInputElement>('input.fa-item-remarks');

          if (!availInput) return;
          const req = parseInt(availInput.dataset.req || '0', 10);
          const avail = parseInt(availInput.value, 10) || 0;
          const exp = expInput?.value.trim() || '—';
          const remarks = remarksInput?.value.trim() || '—';

          itemsList.push({ name, req, avail, exp, remarks });

          // Calculate shortages to save for inventory transaction logs if restock is checked
          if (avail < req) {
            shortages.push({
              item_description: name,
              quantity: req - avail
            });
          }
        });

        const checklistJson = JSON.stringify({
          company,
          department: dept,
          section,
          box_id: boxId,
          cleanliness,
          cleanliness_remarks: cleanlinessRemarks || '-',
          findings: findings || '-',
          officer_name: officerName,
          officer_position: officerPos,
          checklist: itemsList
        });

        // 3. Insert Inspection Log Payload
        if (!activeTenantId || !authUserId) {
          throw new Error('Active session could not be resolved. Please reload the page.');
        }

        const insertPayload = {
          tenant_id: activeTenantId,
          reported_by: authUserId,
          incident_date: inspectDate,
          incident_time: '12:00:00', // Default placeholder time
          location,
          injured_person_name: officerName, // mapped to officer name
          injured_person_id: cleanliness, // mapped to cleanliness
          injury_type: boxId, // mapped to box ID
          treatment_given: checklistJson, // Mapped to serialized checklist JSON!
          referred_to_hospital: instantRestock, // mapped to instant restock flag
          hospital_name: instantRestock ? 'Refill Dispatch' : null,
          signature_url: signatureUrl,
          signature_uploaded_at: signatureUploadedAt,
        };

        const { data: created, error: createErr } = await supabase!
          .from('first_aid_logs')
          .insert(insertPayload)
          .select('id')
          .single<{ id: string }>();
        if (createErr) throw createErr;
        const logId = created.id;

        // 4. Save shortages to first_aid_details if they checked instantRestock
        if (instantRestock && shortages.length > 0) {
          const detailRows: Array<Omit<FirstAidDetail, 'id' | 'created_at'>> = shortages.map((s) => ({
            first_aid_log_id: logId,
            item_description: s.item_description,
            quantity: s.quantity,
            notes: 'Restock refill dispatch'
          }));
          const { error: detailErr } = await supabase!.from('first_aid_details').insert(detailRows);
          if (detailErr) throw detailErr;
          
          openDeductPrompt(logId, shortages);
        } else {
          window.location.href = `/app/first-aid/${logId}`;
        }
      } catch (e) {
        showError(e instanceof Error ? e.message : 'Failed to save inspection.');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = original;
      }
    })();
  });
</script>

