---
// Workplace Inspections — single page with 3 tabs: Conduct, Manage, History.
//
// * Conduct: picks a template, fills out the checklist (Yes/No/Dropdown/
//   Text/Number/Pass-Fail inputs), captures a signature, and writes
//   one inspections row + N inspection_items rows on submit. Audit
//   code ("INS-XXXXX") is generated by the next_audit_code() RPC.
//   Signature is resized to 600x200 PNG q0.7 and uploaded to the
//   `signatures` bucket.
// * Manage: Excel import for checklist templates. Uses the generic
//   Import Wizard with `enableSectionHeaders: true` so the user can
//   mark category rows. The onComplete handler writes a new
//   inspection_templates row (version = max+1) plus its items.
// * History: lists completed inspections (15/page) with search +
//   date filter; View link goes to /app/inspections/<id>.
//
// All security is via RLS (the RLS policies from
// 20260712_phase1a_solo_sho.sql + 20260712_phase2_inspections_rebuild.sql);
// no PIN gates, no manual tenant filtering.
import AppLayout from '../../../layouts/AppLayout.astro';
---
<AppLayout title="Workplace Inspections - AmerisPro">
  <main class="ins-page">
    <div class="container">
      <div id="ins-setup-warning" class="ins-warning" hidden>
        <strong>Setup required.</strong>
        <span>
          Supabase environment variables are not configured. Copy
          <code>.env.example</code> to <code>.env</code>, fill in your
          Supabase credentials, then restart the dev server.
        </span>
      </div>

      <div id="ins-error" class="ins-error" hidden></div>

      <header class="ins-header">
        <div>
          <h1>Workplace Inspections</h1>
          <p class="ins-sub">Conduct safety audits, manage checklist templates, and track compliance history.</p>
        </div>
      </header>

      <nav class="ins-tabs" role="tablist" aria-label="Inspections tabs">
        <button type="button" class="ins-tab-btn active" data-tab="conduct" role="tab" aria-selected="true" id="ins-tab-conduct">📝 Conduct Inspection</button>
        <button type="button" class="ins-tab-btn" data-tab="manage" role="tab" aria-selected="false" id="ins-tab-manage">📋 Manage Checklists</button>
        <button type="button" class="ins-tab-btn" data-tab="history" role="tab" aria-selected="false" id="ins-tab-history">🗂️ History Logs</button>
      </nav>

      <!-- ====================== TAB: CONDUCT ====================== -->
      <section id="ins-panel-conduct" class="ins-panel active" role="tabpanel" aria-labelledby="ins-tab-conduct">
        <form id="ins-form" novalidate>
          <!-- A. Auditor & Area metadata -->
          <fieldset class="ins-fieldset">
            <legend>A. Auditor &amp; area metadata</legend>
            <div class="ins-row-2">
              <label class="field">
                <span class="field-label">Date of Inspection <em>*</em></span>
                <input type="date" name="inspect_date" id="ins-date" required />
              </label>
              <label class="field">
                <span class="field-label">Checklist Template <em>*</em></span>
                <select name="checklist_id" id="ins-checklist" required>
                  <option value="" disabled selected>Select checklist…</option>
                </select>
              </label>
            </div>
            <div class="ins-row-2">
              <label class="field">
                <span class="field-label">Auditor Name <em>*</em></span>
                <input type="text" name="auditor_name" id="ins-auditor" required placeholder="e.g. Ahmad bin Ali" />
              </label>
              <label class="field">
                <span class="field-label">Auditor Position <em>*</em></span>
                <input type="text" name="auditor_position" id="ins-position" required value="Safety Officer" />
              </label>
            </div>
            <label class="field">
              <span class="field-label">Department / Area <em>*</em></span>
              <input type="text" name="location" id="ins-area" required placeholder="e.g. Warehouse A, Kitchen Section 3" />
            </label>
          </fieldset>

          <!-- B. Dynamic checklist -->
          <fieldset class="ins-fieldset" id="ins-checklist-card" hidden>
            <legend>B. Checklist</legend>
            <p class="ins-hint" id="ins-checklist-title">Safety Inspection Checklist</p>
            <div id="ins-checklist-container"></div>
          </fieldset>

          <!-- C. Overall review & sign-off -->
          <fieldset class="ins-fieldset" id="ins-signoff-card" hidden>
            <legend>C. Overall review &amp; digital sign-off</legend>
            <label class="field">
              <span class="field-label">Overall Findings / Corrective Action</span>
              <textarea name="overall_notes" id="ins-findings" rows="3" placeholder="Summarize urgent items or general safety compliance findings…"></textarea>
            </label>
            <div class="field">
              <span class="field-label">Auditor Digital Sign-off <em>*</em></span>
              <div class="ins-sig-container">
                <canvas id="ins-sig-pad" class="ins-sig-pad" aria-label="Signature pad"></canvas>
              </div>
              <div class="ins-sig-controls">
                <label class="field-check">
                  <input type="checkbox" id="ins-save-sig" />
                  <span>Save signature on this device</span>
                </label>
                <button type="button" id="ins-sig-clear" class="ins-secondary-btn">Clear Signature</button>
              </div>
            </div>
            <div class="ins-form-actions">
              <button type="submit" id="ins-submit" class="ins-primary-btn">💾 Submit Safety Inspection</button>
            </div>
          </fieldset>
        </form>
      </section>

      <!-- ====================== TAB: MANAGE CHECKLISTS ====================== -->
      <section id="ins-panel-manage" class="ins-panel" role="tabpanel" aria-labelledby="ins-tab-manage" hidden>
        <section class="ins-card">
          <h2 class="ins-card-title">Import Checklist Template</h2>
          <p class="ins-card-desc">
            Customize checklist categories and questions by uploading a standard Excel sheet. Rows marked as
            <strong>Section Headers</strong> set the category for the questions that follow. Imported rows become a
            new template version — existing inspections still reference the version they were created with.
          </p>
          <div id="ins-wiz-upload-zone" class="ins-upload-zone" role="button" tabindex="0">
            <div class="ins-upload-icon" aria-hidden="true">📥</div>
            <h3 class="ins-upload-title">Upload Excel Checklist Template</h3>
            <p class="ins-upload-desc">
              Required Excel headers: <strong>Checklist ID, Question ID, Safety Question, Category, Risk Level</strong>.
              Then mark Section Header rows in the wizard.
            </p>
          </div>
        </section>

        <section class="ins-card">
          <h2 class="ins-card-title">Active Checklist Questions</h2>
          <div class="ins-filters">
            <label class="ins-filter-field ins-filter-grow">
              <span>Search</span>
              <input type="search" id="ins-tmpl-q" placeholder="Question text, ID, or category" />
            </label>
            <label class="ins-filter-field">
              <span>Template</span>
              <select id="ins-tmpl-filter">
                <option value="">All templates</option>
              </select>
            </label>
            <div class="ins-filter-buttons">
              <button type="button" id="ins-tmpl-apply" class="ins-secondary-btn">Apply</button>
              <button type="button" id="ins-tmpl-clear" class="ins-secondary-btn">Clear</button>
            </div>
          </div>
          <div class="ins-table-scroll">
            <table class="ins-table" aria-label="Active checklist questions">
              <thead>
                <tr>
                  <th>Template</th>
                  <th>Question ID</th>
                  <th>Safety Question</th>
                  <th>Category</th>
                  <th>Type</th>
                  <th class="ins-center">Risk</th>
                </tr>
              </thead>
              <tbody id="ins-tmpl-tbody"></tbody>
            </table>
          </div>
          <nav class="ins-pager" aria-label="Template pagination">
            <button type="button" id="ins-tmpl-prev" class="ins-secondary-btn" disabled>← Previous</button>
            <span class="ins-page-info" id="ins-tmpl-page-info">Page 1</span>
            <button type="button" id="ins-tmpl-next" class="ins-secondary-btn" disabled>Next →</button>
          </nav>
        </section>
      </section>

      <!-- ====================== TAB: HISTORY ====================== -->
      <section id="ins-panel-history" class="ins-panel" role="tabpanel" aria-labelledby="ins-tab-history" hidden>
        <section class="ins-card">
          <h2 class="ins-card-title">Inspection Audit History</h2>
          <div class="ins-filters">
            <label class="ins-filter-field ins-filter-grow">
              <span>Search</span>
              <input type="search" id="ins-log-q" placeholder="Audit ID, auditor, area, findings" />
            </label>
            <label class="ins-filter-field">
              <span>Date</span>
              <input type="date" id="ins-log-date" />
            </label>
            <div class="ins-filter-buttons">
              <button type="button" id="ins-log-apply" class="ins-secondary-btn">Apply</button>
              <button type="button" id="ins-log-clear" class="ins-secondary-btn">Clear</button>
              <button type="button" id="ins-log-export-csv" class="ins-secondary-btn">📥 Export CSV</button>
            </div>
          </div>
          <div class="ins-table-scroll">
            <table class="ins-table" aria-label="Completed inspections">
              <thead>
                <tr>
                  <th>Audit ID</th>
                  <th>Date</th>
                  <th>Auditor</th>
                  <th>Area / Dept</th>
                  <th>Overall Findings</th>
                  <th class="ins-center">Action</th>
                </tr>
              </thead>
              <tbody id="ins-log-tbody"></tbody>
            </table>
          </div>
          <nav class="ins-pager" aria-label="History pagination">
            <button type="button" id="ins-log-prev" class="ins-secondary-btn" disabled>← Previous</button>
            <span class="ins-page-info" id="ins-log-page-info">Page 1</span>
            <button type="button" id="ins-log-next" class="ins-secondary-btn" disabled>Next →</button>
          </nav>
          <div id="ins-log-empty" class="ins-empty" hidden>
            <p>No inspection logs yet. Conduct an inspection to see it here.</p>
          </div>
        </section>
      </section>
    </div>
  </main>
</AppLayout>

<script src="https://cdn.jsdelivr.net/npm/signature_pad@4.0.0/dist/signature_pad.umd.min.js"></script>

<script>
  import { getSupabase, isSupabaseConfigured } from '../../../lib/supabase';
  import { openImportWizard } from '../../../lib/importWizard';
  import { resizeImage } from '../../../lib/imageResize';
  import { uploadToStorage } from '../../../lib/storage';
  import type {
    Inspection,
    InspectionTemplate,
    InspectionTemplateItem,
    WizardField,
    WizardMappedRow,
  } from '../../../lib/types';

  // -----------------------------------------------------------------
  // Refs
  // -----------------------------------------------------------------
  const setupWarning = document.getElementById('ins-setup-warning') as HTMLElement;
  const errorEl = document.getElementById('ins-error') as HTMLElement;

  const tabButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.ins-tab-btn'));
  const tabPanels: Record<'conduct' | 'manage' | 'history', HTMLElement> = {
    conduct: document.getElementById('ins-panel-conduct') as HTMLElement,
    manage: document.getElementById('ins-panel-manage') as HTMLElement,
    history: document.getElementById('ins-panel-history') as HTMLElement,
  };

  // Conduct refs
  const form = document.getElementById('ins-form') as HTMLFormElement;
  const dateEl = document.getElementById('ins-date') as HTMLInputElement;
  const checklistEl = document.getElementById('ins-checklist') as HTMLSelectElement;
  const auditorEl = document.getElementById('ins-auditor') as HTMLInputElement;
  const positionEl = document.getElementById('ins-position') as HTMLInputElement;
  const areaEl = document.getElementById('ins-area') as HTMLInputElement;
  const findingsEl = document.getElementById('ins-findings') as HTMLTextAreaElement;
  const checklistCard = document.getElementById('ins-checklist-card') as HTMLElement;
  const checklistTitle = document.getElementById('ins-checklist-title') as HTMLElement;
  const checklistContainer = document.getElementById('ins-checklist-container') as HTMLElement;
  const signoffCard = document.getElementById('ins-signoff-card') as HTMLElement;
  const sigPadEl = document.getElementById('ins-sig-pad') as HTMLCanvasElement;
  const saveSigEl = document.getElementById('ins-save-sig') as HTMLInputElement;
  const sigClearEl = document.getElementById('ins-sig-clear') as HTMLButtonElement;
  const submitBtn = document.getElementById('ins-submit') as HTMLButtonElement;

  // Manage refs
  const wizUploadZone = document.getElementById('ins-wiz-upload-zone') as HTMLElement;
  const tmplQ = document.getElementById('ins-tmpl-q') as HTMLInputElement;
  const tmplFilter = document.getElementById('ins-tmpl-filter') as HTMLSelectElement;
  const tmplApply = document.getElementById('ins-tmpl-apply') as HTMLButtonElement;
  const tmplClear = document.getElementById('ins-tmpl-clear') as HTMLButtonElement;
  const tmplTbody = document.getElementById('ins-tmpl-tbody') as HTMLElement;
  const tmplPrev = document.getElementById('ins-tmpl-prev') as HTMLButtonElement;
  const tmplNext = document.getElementById('ins-tmpl-next') as HTMLButtonElement;
  const tmplPageInfo = document.getElementById('ins-tmpl-page-info') as HTMLElement;

  // History refs
  const logQ = document.getElementById('ins-log-q') as HTMLInputElement;
  const logDate = document.getElementById('ins-log-date') as HTMLInputElement;
  const logApply = document.getElementById('ins-log-apply') as HTMLButtonElement;
  const logClear = document.getElementById('ins-log-clear') as HTMLButtonElement;
  const logTbody = document.getElementById('ins-log-tbody') as HTMLElement;
  const logPrev = document.getElementById('ins-log-prev') as HTMLButtonElement;
  const logNext = document.getElementById('ins-log-next') as HTMLButtonElement;
  const logPageInfo = document.getElementById('ins-log-page-info') as HTMLElement;
  const logEmpty = document.getElementById('ins-log-empty') as HTMLElement;

  // -----------------------------------------------------------------
  // Constants
  // -----------------------------------------------------------------
  const PAGE_SIZE = 15;
  const SIGNATURE_PAD_LOCAL_KEY = 'inspection_saved_sig';
  const TEMPLATE_PAGE_SIZE = 15;

  // -----------------------------------------------------------------
  // State
  // -----------------------------------------------------------------
  let supabase: ReturnType<typeof getSupabase> | null = null;
  let authUserId: string | null = null;
  let authUserEmail: string | null = null;
  let activeTenantId: string | null = null;
  let allTemplateItems: InspectionTemplateItem[] = [];
  let allTemplates: InspectionTemplate[] = [];
  let tmplPage = 1;
  let logPage = 1;

  const tmplPaginator = new (window as any).PaginationHelper({
    prevBtnId: 'ins-tmpl-prev',
    nextBtnId: 'ins-tmpl-next',
    pageInfoId: 'ins-tmpl-page-info',
    pageSize: TEMPLATE_PAGE_SIZE,
    onChange: (newPage: number) => {
      tmplPage = newPage;
      renderTemplatesTable();
    }
  });

  const logPaginator = new (window as any).PaginationHelper({
    prevBtnId: 'ins-log-prev',
    nextBtnId: 'ins-log-next',
    pageInfoId: 'ins-log-page-info',
    pageSize: PAGE_SIZE,
    onChange: (newPage: number) => {
      logPage = newPage;
      void loadHistoryPage(newPage);
    }
  });
  // Map<questionId, { questionId, questionText, responseType, options, section, responseValue, remarks }>
  let answers: Record<string, AnswerEntry> = {};
  let signaturePad: { isEmpty(): boolean; clear(): void; toDataURL(t: string): string; fromDataURL(s: string): void; off?(): void; on?(): void; } | null = null;

  interface AnswerEntry {
    questionId: string;
    questionText: string;
    responseType: 'yes_no' | 'text' | 'number' | 'pass_fail' | 'dropdown';
    options: string[]; // parsed dropdown options
    section: string | null;
    responseValue: string;
    remarks: string;
  }

  // -----------------------------------------------------------------
  // Helpers
  // -----------------------------------------------------------------
  function showError(msg: string): void {
    errorEl.hidden = false;
    errorEl.textContent = msg;
    errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
  function clearError(): void { errorEl.hidden = true; errorEl.textContent = ''; }

  function escapeHtml(s: string | null | undefined): string {
    return (s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string);
  }
  function truncate(s: string, n: number): string {
    if (s.length <= n) return s;
    return s.slice(0, n - 1).trimEnd() + '…';
  }
  function today(): string {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  }
  function parseDropdownOptions(raw: string | null): string[] {
    if (!raw) return [];
    return raw.split(',').map((o) => o.trim()).filter((o) => o.length > 0);
  }
  function responseTypeLabel(t: AnswerEntry['responseType']): string {
    switch (t) {
      case 'yes_no': return 'Yes/No';
      case 'text': return 'Text';
      case 'number': return 'Number';
      case 'pass_fail': return 'Pass/Fail';
      case 'dropdown': return 'Dropdown';
      default: return t;
    }
  }

  // -----------------------------------------------------------------
  // Tab switching
  // -----------------------------------------------------------------
  function switchTab(tab: 'conduct' | 'manage' | 'history'): void {
    for (const btn of tabButtons) {
      const isActive = btn.dataset.tab === tab;
      btn.classList.toggle('active', isActive);
      btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
    }
    for (const [key, el] of Object.entries(tabPanels) as Array<['conduct' | 'manage' | 'history', HTMLElement]>) {
      const isActive = key === tab;
      el.hidden = !isActive;
      el.classList.toggle('active', isActive);
    }
    if (tab === 'manage') {
      void loadTemplatesTab();
    } else if (tab === 'history') {
      void loadHistoryPage(1);
    } else if (tab === 'conduct') {
      // Resize canvas after the panel becomes visible.
      setTimeout(resizeSignatureCanvas, 50);
    }
  }
  for (const btn of tabButtons) {
    btn.addEventListener('click', () => {
      const t = btn.dataset.tab as 'conduct' | 'manage' | 'history';
      switchTab(t);
    });
  }

  // -----------------------------------------------------------------
  // Signature pad (signature_pad@4.0.0 loaded via CDN <script> in
  // the head — exposes the global `SignaturePad`).
  // -----------------------------------------------------------------
  function resizeSignatureCanvas(): void {
    if (!signaturePad) return;
    const ratio = Math.max(window.devicePixelRatio || 1, 1);
    const w = sigPadEl.clientWidth;
    const h = sigPadEl.clientHeight;
    if (w > 0 && h > 0) {
      const targetW = w * ratio;
      const targetH = h * ratio;
      if (sigPadEl.width !== targetW || sigPadEl.height !== targetH) {
        sigPadEl.width = targetW;
        sigPadEl.height = targetH;
        sigPadEl.getContext('2d')?.scale(ratio, ratio);
        signaturePad.clear();
      }
    }
  }
  function initSignature(): void {
    const Ctor = (window as unknown as { SignaturePad?: new (canvas: HTMLCanvasElement, opts?: object) => typeof signaturePad }).SignaturePad;
    if (!Ctor) {
      // CDN failed to load. Disable the submit button; user can still
      // try other tabs.
      submitBtn.disabled = true;
      showError('Signature library failed to load. Reload the page to try again.');
      return;
    }
    signaturePad = new Ctor(sigPadEl, {
      backgroundColor: 'rgb(248, 250, 252)',
      penColor: 'rgb(15, 23, 42)',
    } as object);
    resizeSignatureCanvas();
    window.addEventListener('resize', resizeSignatureCanvas);
    sigPadEl.addEventListener('pointerdown', resizeSignatureCanvas);

    // Load persisted signature if any.
    try {
      const saved = localStorage.getItem(SIGNATURE_PAD_LOCAL_KEY);
      if (saved && signaturePad) {
        setTimeout(() => {
          signaturePad?.fromDataURL(saved);
          saveSigEl.checked = true;
        }, 150);
      }
    } catch {
      // localStorage may be blocked — that's fine, no persistence.
    }
  }
  sigClearEl.addEventListener('click', () => {
    if (signaturePad) signaturePad.clear();
    try { localStorage.removeItem(SIGNATURE_PAD_LOCAL_KEY); } catch { /* ignore */ }
    saveSigEl.checked = false;
  });

  // -----------------------------------------------------------------
  // Conduct tab: load template dropdown + load items when selected
  // -----------------------------------------------------------------
  async function loadTemplatesDropdown(): Promise<void> {
    if (!supabase) return;
    const { data, error } = await supabase
      .from('inspection_templates')
      .select('id, template_name, checklist_id, version')
      .eq('is_active', true)
      .order('checklist_id', { ascending: true })
      .order('version', { ascending: false });
    if (error) {
      showError(error.message);
      return;
    }
    const rows = (data ?? []) as Array<Pick<InspectionTemplate, 'id' | 'template_name' | 'checklist_id' | 'version'>>;
    allTemplates = rows.map((r) => ({
      id: r.id,
      tenant_id: '',
      checklist_id: r.checklist_id,
      template_name: r.template_name,
      description: null,
      is_active: true,
      version: r.version,
      created_by: '',
      created_at: '',
      updated_at: '',
    }));

    // Group by checklist_id; pick the latest version for each.
    const latestByChecklist = new Map<string, { id: string; label: string }>();
    for (const t of rows) {
      if (!latestByChecklist.has(t.checklist_id)) {
        latestByChecklist.set(t.checklist_id, { id: t.id, label: `${t.checklist_id} (${t.template_name}, v${t.version})` });
      }
    }
    checklistEl.innerHTML = '<option value="" disabled selected>Select checklist…</option>';
    for (const { id, label } of latestByChecklist.values()) {
      const opt = document.createElement('option');
      opt.value = id;
      opt.textContent = label;
      checklistEl.appendChild(opt);
    }
  }

  async function loadTemplateItems(templateId: string): Promise<void> {
    if (!supabase) return;
    const { data, error } = await supabase
      .from('inspection_template_items')
      .select('*')
      .eq('template_id', templateId)
      .order('display_order', { ascending: true });
    if (error) {
      showError(error.message);
      return;
    }
    allTemplateItems = (data ?? []) as InspectionTemplateItem[];
    renderChecklist();
  }

  function renderChecklist(): void {
    console.log('[DEBUG] renderChecklist called — all buttons will be recreated, state lost');
    console.trace('[DEBUG] renderChecklist stack trace');
    checklistContainer.innerHTML = '';
    answers = {};

    if (allTemplateItems.length === 0) {
      checklistCard.hidden = true;
      signoffCard.hidden = true;
      return;
    }

    // Group by section. Items without a section fall into "General Safety".
    const grouped = new Map<string, InspectionTemplateItem[]>();
    for (const item of allTemplateItems) {
      const sec = item.section || 'General Safety';
      if (!grouped.has(sec)) grouped.set(sec, []);
      grouped.get(sec)!.push(item);
    }

    for (const [section, items] of grouped) {
      const secEl = document.createElement('div');
      secEl.className = 'ins-category-section';
      secEl.innerHTML = `<div class="ins-category-title">📂 ${escapeHtml(section)}</div>`;
      for (const item of items) {
        const optsList = parseDropdownOptions(item.options);
        const entry: AnswerEntry = {
          questionId: item.question_id,
          questionText: item.question_text,
          responseType: item.response_type,
          options: optsList,
          section: item.section,
          responseValue: '',
          remarks: '',
        };
        answers[item.question_id] = entry;

        const risk = (item.risk_level || 'Medium').toString();
        const riskClass = risk.toLowerCase();
        let actionHtml = '';
        if (item.response_type === 'dropdown' && optsList.length > 0) {
          const optsHtml = ['<option value="">— Choose option —</option>']
            .concat(optsList.map((o) => `<option value="${escapeHtml(o)}">${escapeHtml(o)}</option>`))
            .join('');
          actionHtml = `<select class="ins-q-input" data-q="${escapeHtml(item.question_id)}" data-kind="dropdown">${optsHtml}</select>`;
        } else if (item.response_type === 'text') {
          actionHtml = `<input type="text" class="ins-q-input" data-q="${escapeHtml(item.question_id)}" data-kind="text" placeholder="Write answer here…" />`;
        } else if (item.response_type === 'number') {
          actionHtml = `<input type="number" class="ins-q-input" data-q="${escapeHtml(item.question_id)}" data-kind="number" placeholder="Enter number…" />`;
        } else if (item.response_type === 'pass_fail') {
          actionHtml = `
            <div class="ins-choice-row">
              <button type="button" class="ins-choice-btn" data-q="${escapeHtml(item.question_id)}" data-val="Pass">Pass</button>
              <button type="button" class="ins-choice-btn" data-q="${escapeHtml(item.question_id)}" data-val="Fail">Fail</button>
            </div>
          `;
        } else {
          // yes_no (default).
          actionHtml = `
            <div class="ins-choice-row">
              <button type="button" class="ins-choice-btn" data-q="${escapeHtml(item.question_id)}" data-val="Yes">Yes</button>
              <button type="button" class="ins-choice-btn" data-q="${escapeHtml(item.question_id)}" data-val="No">No</button>
              <button type="button" class="ins-choice-btn" data-q="${escapeHtml(item.question_id)}" data-val="N/A">N/A</button>
            </div>
          `;
        }

        const itemEl = document.createElement('div');
        itemEl.className = 'ins-question-item';
        itemEl.innerHTML = `
          <div class="ins-question-header">
            <span class="ins-question-text"><strong>${escapeHtml(item.question_id)}:</strong> ${escapeHtml(item.question_text)}</span>
            <span class="ins-risk-badge ins-risk-${escapeHtml(riskClass)}">${escapeHtml(risk)}</span>
          </div>
          <div class="ins-question-actions">${actionHtml}</div>
          <input type="text" class="ins-q-input ins-q-remarks" data-q="${escapeHtml(item.question_id)}" data-kind="remarks" placeholder="Remarks / Corrective Action (optional)" />
        `;
        secEl.appendChild(itemEl);
      }
      checklistContainer.appendChild(secEl);
    }

    // Wire up choice buttons + input listeners via event delegation.
    checklistContainer.querySelectorAll<HTMLButtonElement>('.ins-choice-btn').forEach((b) => {
      b.addEventListener('click', () => {
        const q = b.dataset.q ?? '';
        const v = b.dataset.val ?? '';
        console.log(`[DEBUG] Button clicked: q="${q}", val="${v}"`);
        const entry = answers[q];
        if (!entry) { console.log(`[DEBUG] No answer entry for q="${q}"`); return; }
        entry.responseValue = v;
        // Visually mark only this question's buttons — apply styles
        // directly because Astro-scoped CSS doesn't reach dynamically
        // created elements (innerHTML in JS). Use DOM styling so the
        // highlight always renders regardless of scoping attributes.
        // appearance: 'none' is required to override the browser's native
        // button rendering which otherwise blocks custom background-color.
        checklistContainer.querySelectorAll<HTMLButtonElement>('.ins-choice-btn').forEach((sib) => {
          if (sib.dataset.q === q) {
            console.log(`[DEBUG] Removing ins-active from: q="${sib.dataset.q}", val="${sib.dataset.val}"`);
            sib.classList.remove('ins-active');
            sib.style.background = '';
            sib.style.color = '';
            sib.style.borderColor = '';
            sib.style.appearance = '';
          }
        });
        b.classList.add('ins-active');
        b.style.appearance = 'none';
        b.style.background = '#8B5CF6';
        b.style.color = '#fff';
        b.style.borderColor = '#8B5CF6';
        console.log(`[DEBUG] Added ins-active to: q="${q}", val="${v}"`);
      });
    });
    checklistContainer.querySelectorAll<HTMLInputElement | HTMLSelectElement>('.ins-q-input').forEach((inp) => {
      inp.addEventListener('input', () => {
        const q = inp.dataset.q ?? '';
        const kind = inp.dataset.kind ?? '';
        const entry = answers[q];
        if (!entry) return;
        if (kind === 'remarks') entry.remarks = inp.value;
        else entry.responseValue = inp.value;
      });
    });

    checklistTitle.textContent = `Safety Inspection Checklist — ${checklistEl.options[checklistEl.selectedIndex]?.text ?? ''}`;
    checklistCard.hidden = false;
    signoffCard.hidden = false;
    setTimeout(resizeSignatureCanvas, 50);
  }

  checklistEl.addEventListener('change', () => {
    console.log('[DEBUG] checklistEl.change fired — template dropdown changed');
    const tplId = checklistEl.value;
    if (tplId) void loadTemplateItems(tplId);
  });

  // -----------------------------------------------------------------
  // Submit handler
  // -----------------------------------------------------------------
  form.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    if (!supabase || !authUserId || !activeTenantId) {
      if (!activeTenantId) showError('Tenant information not yet loaded. Please wait and try again.');
      return;
    }
    clearError();

    const inspectDate = dateEl.value;
    const templateId = checklistEl.value;
    const auditorName = auditorEl.value.trim();
    const auditorPosition = positionEl.value.trim();
    const location = areaEl.value.trim();
    const overallNotes = findingsEl.value.trim() || null;

    if (!inspectDate) { showError('Date of Inspection is required.'); return; }
    if (!templateId) { showError('Please choose a checklist template.'); return; }
    if (!auditorName) { showError('Auditor Name is required.'); return; }
    if (!auditorPosition) { showError('Auditor Position is required.'); return; }
    if (!location) { showError('Department / Area is required.'); return; }

    // Validate every question has an answer.
    const unanswered = Object.values(answers).filter((a) => !a.responseValue || a.responseValue.trim() === '');
    if (unanswered.length > 0) {
      showError(`Please answer all checklist questions (${unanswered.length} remaining).`);
      return;
    }

    // Validate signature.
    if (!signaturePad || signaturePad.isEmpty()) {
      showError('Please provide a digital signature before submitting.');
      return;
    }

    submitBtn.disabled = true;
    const original = submitBtn.textContent ?? 'Submit';
    submitBtn.textContent = '⏳ Saving audit…';

    try {
      // 1) Upload signature (resize to 600x200 PNG q0.7 — matches the
      //    Phase 2.3 storage helpers used by first-aid & contractor
      //    inductions).
      const sigDataUrl = signaturePad.toDataURL('image/png');
      const sigResized = await resizeImage(sigDataUrl, {
        maxWidth: 600,
        maxHeight: 200,
        quality: 0.7,
        outputType: 'image/png',
      });
      const sigUpload = await uploadToStorage('signatures', sigResized.blob, 'inspection-sig', 'png');
      if (sigUpload.error) throw new Error(`Signature upload failed: ${sigUpload.error}`);

      // 2) Generate the audit code.
      const { data: codeData, error: codeErr } = await supabase.rpc('next_audit_code');
      if (codeErr) throw new Error(`Failed to generate audit code: ${codeErr.message}`);
      const auditCode = String(codeData ?? '').trim();
      if (!/^INS-\d{5}$/.test(auditCode)) {
        throw new Error(`Unexpected audit code from server: ${auditCode}`);
      }

      // 3) Insert the inspections row.
      const insInsert: Omit<Inspection, 'id' | 'created_at' | 'updated_at' | 'status'> & { status: string } = {
        tenant_id: activeTenantId!,
        template_id: templateId,
        inspection_type: 'safety_audit',
        scheduled_date: inspectDate,
        completed_date: inspectDate,
        location,
        inspector_id: authUserId,
        status: 'completed',
        overall_notes: overallNotes,
        audit_code: auditCode,
        auditor_name: auditorName,
        auditor_position: auditorPosition,
        signature_url: sigUpload.url,
        signature_uploaded_at: new Date().toISOString(),
      };
      const { data: insRow, error: insErr } = await supabase
        .from('inspections')
        .insert(insInsert)
        .select('id')
        .single();
      if (insErr) throw insErr;
      const inspectionId = (insRow as { id: string } | null)?.id;
      if (!inspectionId) throw new Error('Failed to capture inspection id.');

      // 4) Bulk insert the inspection_items rows.
      const items = Object.values(answers).map((a) => ({
        inspection_id: inspectionId,
        item_description: a.questionText,
        question_id: a.questionId,
        response_value: a.responseValue,
        // status is kept for backward compat with the Phase 1A column;
        // new code reads response_value. Map the answer to a legacy
        // value when it looks like Pass/Fail; otherwise store as-is.
        status: mapAnswerToLegacyStatus(a.responseValue),
        notes: a.remarks || null,
        photo_url: null,
      }));
      const { error: itemsErr } = await supabase.from('inspection_items').insert(items);
      if (itemsErr) throw itemsErr;

      // 5) Signature persistence preference.
      try {
        if (saveSigEl.checked) {
          localStorage.setItem(SIGNATURE_PAD_LOCAL_KEY, sigDataUrl);
        } else {
          localStorage.removeItem(SIGNATURE_PAD_LOCAL_KEY);
        }
      } catch { /* ignore */ }

      // 6) Reset form & notify.
      window.alert(`🎉 Audit ${auditCode} saved successfully.`);
      form.reset();
      dateEl.value = today();
      checklistEl.value = '';
      checklistCard.hidden = true;
      signoffCard.hidden = true;
      checklistContainer.innerHTML = '';
      answers = {};
      if (signaturePad) signaturePad.clear();

      // 7) Switch to history so the SHO sees the new row.
      switchTab('history');
    } catch (e) {
      showError(e instanceof Error ? e.message : 'Failed to save audit.');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = original;
    }
  });

  function mapAnswerToLegacyStatus(v: string): string {
    const s = v.trim().toLowerCase();
    if (s === 'pass') return 'pass';
    if (s === 'fail') return 'fail';
    if (s === 'n/a' || s === 'na') return 'na';
    // Yes / No / free text / number / dropdown value — keep as-is.
    return v.trim();
  }

  // -----------------------------------------------------------------
  // Manage tab
  // -----------------------------------------------------------------
  async function loadTemplatesTab(): Promise<void> {
    if (!supabase) return;
    // Fetch templates (for the filter dropdown) + items (for the table).
    const [{ data: tpls, error: tErr }, { data: items, error: iErr }] = await Promise.all([
      supabase
        .from('inspection_templates')
        .select('id, checklist_id, template_name, version, is_active')
        .eq('is_active', true)
        .order('checklist_id', { ascending: true })
        .order('version', { ascending: false }),
      supabase
        .from('inspection_template_items')
        .select('*')
        .order('template_id', { ascending: true })
        .order('display_order', { ascending: true }),
    ]);
    if (tErr) { showError(tErr.message); return; }
    if (iErr) { showError(iErr.message); return; }

    allTemplates = (tpls ?? []) as InspectionTemplate[];
    allTemplateItems = (items ?? []) as InspectionTemplateItem[];

    // Populate the filter dropdown (all distinct template ids).
    tmplFilter.innerHTML = '<option value="">All templates</option>';
    for (const t of allTemplates) {
      const opt = document.createElement('option');
      opt.value = t.id;
      opt.textContent = `${t.checklist_id} (v${t.version})`;
      tmplFilter.appendChild(opt);
    }

    void renderTemplatesTable();
  }

  function filteredTemplates(): Array<{ item: InspectionTemplateItem; tpl: InspectionTemplate | null }> {
    const q = tmplQ.value.trim().toLowerCase();
    const tplId = tmplFilter.value;
    const tplById = new Map(allTemplates.map((t) => [t.id, t]));
    return allTemplateItems
      .filter((it) => (tplId ? it.template_id === tplId : true))
      .filter((it) => {
        if (!q) return true;
        const tpl = tplById.get(it.template_id);
        const hay = `${it.question_id} ${it.question_text} ${it.section ?? ''} ${tpl?.checklist_id ?? ''}`.toLowerCase();
        return hay.includes(q);
      })
      .map((it) => ({ item: it, tpl: tplById.get(it.template_id) ?? null }));
  }

  function renderTemplatesTable(): void {
    const rows = filteredTemplates();
    const total = rows.length;
    const maxPage = Math.max(1, Math.ceil(total / TEMPLATE_PAGE_SIZE));
    if (tmplPage > maxPage) tmplPage = maxPage;
    const start = (tmplPage - 1) * TEMPLATE_PAGE_SIZE;
    const pageRows = rows.slice(start, start + TEMPLATE_PAGE_SIZE);

    tmplTbody.innerHTML = '';
    if (pageRows.length === 0) {
      const tr = document.createElement('tr');
      tr.innerHTML = `<td colspan="6" class="ins-empty-cell">No matching questions found.</td>`;
      tmplTbody.appendChild(tr);
    } else {
      for (const { item, tpl } of pageRows) {
        const tr = document.createElement('tr');
        const tplLabel = tpl ? `${escapeHtml(tpl.checklist_id)} v${tpl.version}` : '—';
        tr.innerHTML = `
          <td class="ins-mono">${tplLabel}</td>
          <td class="ins-mono">${escapeHtml(item.question_id)}</td>
          <td>${escapeHtml(item.question_text)}</td>
          <td class="ins-muted">${escapeHtml(item.section ?? '—')}</td>
          <td>
            <strong>${escapeHtml(responseTypeLabel(item.response_type))}</strong>
            ${item.response_type === 'dropdown' && item.options ? `<div class="ins-muted ins-small">${escapeHtml(item.options)}</div>` : ''}
          </td>
          <td class="ins-center">
            <span class="ins-risk-badge ins-risk-${escapeHtml((item.risk_level || 'Medium').toLowerCase())}">${escapeHtml(item.risk_level || 'Medium')}</span>
          </td>
        `;
        tmplTbody.appendChild(tr);
      }
    }
    tmplPaginator.update(tmplPage, total);
  }

  tmplApply.addEventListener('click', () => { tmplPage = 1; renderTemplatesTable(); });
  tmplClear.addEventListener('click', () => {
    tmplQ.value = '';
    tmplFilter.value = '';
    tmplPage = 1;
    renderTemplatesTable();
  });

  // -----------------------------------------------------------------
  // Manage tab: import wizard
  // -----------------------------------------------------------------
  const TEMPLATE_FIELDS: WizardField[] = [
    { id: 'Question ID', label: 'Question ID / No.', required: false, autoMatches: ['no', 'no.', 'id', 'question id', 'question_id'] },
    { id: 'Safety Question', label: 'Safety Question / Description', required: true, autoMatches: ['description', 'safety question', 'question', 'soal', 'soalan', 'item'] },
    { id: 'Input Field', label: 'Checklist Answer Field', required: false, enableCustomType: true, autoMatches: ['comply', 'compliance', 'yes/no', 'status', 'result'] },
  ];

  async function handleTemplateImport(mappedRows: WizardMappedRow[]): Promise<void> {
    if (!supabase || !activeTenantId) {
      throw new Error('Tenant information not yet loaded. Please wait and try again.');
    }
    // Walk the mapped rows. Section headers (r.isSectionHeader === true)
    // update currentCategory. Question rows are pushed as items.
    let currentCategory = 'General Safety';
    const finalQuestions: Array<{
      question_id: string;
      question_text: string;
      section: string;
      response_type: 'yes_no' | 'text' | 'number' | 'pass_fail' | 'dropdown';
      options: string | null;
      risk_level: 'High' | 'Medium' | 'Low';
    }> = [];
    let questionCounter = 1;
    for (const r of mappedRows) {
      const descVal = String(r['Safety Question'] ?? '').trim();
      if (r.isSectionHeader) {
        if (descVal) currentCategory = descVal;
        continue;
      }
      if (!descVal) continue;
      const qId = 'Q-' + String(questionCounter++).padStart(2, '0');
      const typeRaw = String(r['Field Type'] ?? 'Yes/No').trim();
      const optionsRaw = String(r['Options'] ?? '').trim();
      const { responseType, options } = normalizeFieldType(typeRaw, optionsRaw);
      finalQuestions.push({
        question_id: qId,
        question_text: descVal,
        section: currentCategory,
        response_type: responseType,
        options: options,
        risk_level: 'Medium',
      });
    }

    if (finalQuestions.length === 0) {
      throw new Error('No safety questions detected. Ensure you map the Safety Question column and that at least one row has content.');
    }

    // Create a new inspection_templates row (checklist_id = "CL-01",
    // version = max(version) + 1 for that checklist — defaults to 1).
    const checklistId = 'CL-01';
    const { data: maxRow } = await supabase
      .from('inspection_templates')
      .select('version')
      .eq('checklist_id', checklistId)
      .order('version', { ascending: false })
      .limit(1)
      .maybeSingle<{ version: number }>();
    const nextVersion = (maxRow?.version ?? 0) + 1;
    const templateName = `${checklistId} Inspection (v${nextVersion})`;

    const { data: newTpl, error: tplErr } = await supabase
      .from('inspection_templates')
      .insert({
        tenant_id: activeTenantId!,
        checklist_id: checklistId,
        template_name: templateName,
        description: null,
        is_active: true,
        version: nextVersion,
        created_by: authUserId!,
      })
      .select('id')
      .single();
    if (tplErr) throw tplErr;
    const templateId = (newTpl as { id: string } | null)?.id;
    if (!templateId) throw new Error('Failed to capture new template id.');

    // Bulk insert items.
    const itemsToInsert = finalQuestions.map((q, idx) => ({
      tenant_id: activeTenantId!,
      template_id: templateId,
      question_id: q.question_id,
      display_order: idx + 1,
      section: q.section,
      question_text: q.question_text,
      response_type: q.response_type,
      options: q.options,
      risk_level: q.risk_level,
      is_required: true,
    }));
    // Batch in groups of 500 (Supabase's hard cap is 1000/request).
    const BATCH = 500;
    for (let i = 0; i < itemsToInsert.length; i += BATCH) {
      const batch = itemsToInsert.slice(i, i + BATCH);
      const { error: itemsErr } = await supabase.from('inspection_template_items').insert(batch);
      if (itemsErr) {
        // Best-effort: try to roll back the template we just created.
        await supabase.from('inspection_templates').delete().eq('id', templateId);
        throw new Error(`Insert batch failed: ${itemsErr.message}`);
      }
    }

    // Notify + refresh.
    window.setTimeout(() => {
      window.alert(`Imported ${finalQuestions.length} checklist question${finalQuestions.length === 1 ? '' : 's'} into ${templateName}.`);
      void loadTemplatesTab();
    }, 50);
  }

  function normalizeFieldType(typeRaw: string, optionsRaw: string): { responseType: 'yes_no' | 'text' | 'number' | 'pass_fail' | 'dropdown'; options: string | null } {
    const t = typeRaw.toLowerCase().replace(/[^a-z0-9_/]/g, '').trim();
    if (t === 'dropdown' || t === 'select') {
      const opts = optionsRaw.split(',').map((o) => o.trim()).filter((o) => o.length > 0).join(', ');
      return { responseType: 'dropdown', options: opts || null };
    }
    if (t === 'text') return { responseType: 'text', options: null };
    if (t === 'number' || t === 'numeric') return { responseType: 'number', options: null };
    if (t === 'pass' || t === 'pass/fail' || t === 'passfail' || t === 'pass_fail') return { responseType: 'pass_fail', options: null };
    // Default: yes_no
    return { responseType: 'yes_no', options: null };
  }

  function launchWizard(): void {
    openImportWizard({
      title: 'Import Checklist Template',
      enableSectionHeaders: true,
      fields: TEMPLATE_FIELDS,
      onComplete: (rows) => handleTemplateImport(rows),
    });
  }
  wizUploadZone.addEventListener('click', launchWizard);
  wizUploadZone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      launchWizard();
    }
  });

  // -----------------------------------------------------------------
  // History tab
  // -----------------------------------------------------------------
  async function loadHistoryPage(page: number): Promise<void> {
    if (!supabase) return;
    logPage = page;
    logTbody.innerHTML = `<tr><td colspan="6" class="ins-empty-cell">Loading…</td></tr>`;
    logEmpty.hidden = true;

    const q = logQ.value.trim();
    const date = logDate.value;
    const offset = (page - 1) * PAGE_SIZE;
    const offsetEnd = offset + PAGE_SIZE - 1;

    let query = supabase
      .from('inspections')
      .select('id, audit_code, scheduled_date, auditor_name, location, overall_notes, completed_date, created_at', { count: 'estimated' })
      .not('completed_date', 'is', null)
      .order('created_at', { ascending: false });
    if (q) {
      query = query.or(
        `audit_code.ilike.%${q}%,auditor_name.ilike.%${q}%,location.ilike.%${q}%,overall_notes.ilike.%${q}%`,
      );
    }
    if (date) {
      query = query.eq('scheduled_date', date);
    }
    query = query.range(offset, offsetEnd);

    try {
      const { data, error, count } = await query;
      if (error) throw error;
      const rows = (data ?? []) as Array<Pick<Inspection, 'id' | 'audit_code' | 'scheduled_date' | 'auditor_name' | 'location' | 'overall_notes' | 'completed_date' | 'created_at'>>;
      logTbody.innerHTML = '';
      if (rows.length === 0) {
        logEmpty.hidden = false;
        logPaginator.update(logPage, 0);
        return;
      }
      logEmpty.hidden = true;
      for (const r of rows) {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td class="ins-mono">${escapeHtml(r.audit_code ?? '—')}</td>
          <td>${escapeHtml(r.scheduled_date ?? '—')}</td>
          <td><strong>${escapeHtml(r.auditor_name ?? '—')}</strong></td>
          <td>${escapeHtml(r.location ?? '—')}</td>
          <td class="ins-muted">${escapeHtml(r.overall_notes ? truncate(r.overall_notes, 60) : '—')}</td>
          <td class="ins-center">
            <a href="/app/inspections/${encodeURIComponent(r.id)}" class="ins-secondary-btn ins-btn-link">👁️ View</a>
          </td>
        `;
        logTbody.appendChild(tr);
      }
      const total = count ?? null;
      logPaginator.update(logPage, total || 0);
    } catch (e) {
      logTbody.innerHTML = `<tr><td colspan="6" class="ins-empty-cell">❌ ${escapeHtml(e instanceof Error ? e.message : 'Failed to load history.')}</td></tr>`;
    }
  }
  logApply.addEventListener('click', () => loadHistoryPage(1));
  logClear.addEventListener('click', () => {
    logQ.value = '';
    logDate.value = '';
    void loadHistoryPage(1);
  });

  const logExportBtn = document.getElementById('ins-log-export-csv') as HTMLButtonElement;
  logExportBtn.addEventListener('click', () => {
    const params = new URLSearchParams();
    const q = logQ.value.trim();
    if (q) params.set('q', q);
    if (logDate.value) {
      params.set('from', logDate.value);
      params.set('to', logDate.value);
    }
    const qs = params.toString();
    window.location.href = `/api/export/inspections.csv${qs ? '?' + qs : ''}`;
  });

  // -----------------------------------------------------------------
  // Bootstrap
  // -----------------------------------------------------------------
  if (!isSupabaseConfigured()) {
    setupWarning.hidden = false;
    submitBtn.disabled = true;
    wizUploadZone.setAttribute('aria-disabled', 'true');
    wizUploadZone.style.opacity = '0.5';
    wizUploadZone.style.cursor = 'not-allowed';
  } else {
    supabase = getSupabase();
    dateEl.value = today();
    // Set up signature pad right away (the canvas is in the
    // always-rendered Conduct tab, so it's always in the DOM).
    initSignature();

    (async () => {
      const { data: userData, error: userErr } = await supabase.auth.getUser();
      if (userErr || !userData.user) {
        window.location.replace('/login');
        return;
      }
      authUserId = userData.user.id;
      authUserEmail = userData.user.email ?? null;
      // Query active tenant
      const { data: tenantData, error: tenantErr } = await supabase!
        .from('tenants')
        .select('id')
        .eq('owner_user_id', authUserId)
        .limit(1);
      if (tenantErr || !tenantData || tenantData.length === 0) {
        showError('You do not belong to an active tenant workspace.');
        return;
      }
      activeTenantId = tenantData[0].id;
      if (authUserEmail && !auditorEl.value) auditorEl.value = authUserEmail;
      // Preload the conduct tab's template dropdown.
      await loadTemplatesDropdown();
    })().catch(() => {
      showError('Failed to initialise inspections page.');
    });
  }
</script>

<style>
  .ins-page { padding: 32px 0 64px; }
  .ins-warning, .ins-error {
    padding: 14px 18px;
    margin-bottom: 24px;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .ins-warning { background: #FFF7E6; border: 1px solid #E58E1A; color: #6A4A0F; }
  .ins-warning code { background: rgba(0,0,0,0.06); padding: 1px 4px; font-size: 0.85rem; }
  .ins-error { background: #FDECEC; border: 1px solid #C0392B; color: #8B1A1A; }

  .ins-header { margin-bottom: 20px; }
  .ins-header h1 { font-size: 1.8rem; font-weight: 900; margin-bottom: 4px; }
  .ins-sub { color: var(--color-text-muted, #6A6A69); font-size: 0.9rem; }

  /* Tabs */
  .ins-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 20px;
    border-bottom: 2px solid var(--color-border, #E0E0E0);
    flex-wrap: wrap;
  }
  .ins-tab-btn {
    background: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    padding: 10px 18px;
    font-family: inherit;
    font-size: 0.82rem;
    font-weight: 700;
