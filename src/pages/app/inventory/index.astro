---
import AppLayout from '../../../layouts/AppLayout.astro';
---
<AppLayout title="First Aid Inventory - AmerisPro">
  <main class="inv-page">
    <div class="container">
      <div id="inv-setup-warning" class="inv-warning" hidden>
        <strong>Setup required.</strong>
        <span>
          Supabase environment variables are not configured. Copy
          <code>.env.example</code> to <code>.env</code>, fill in your
          Supabase credentials, then restart the dev server.
        </span>
      </div>

      <div id="inv-error" class="inv-error" hidden></div>

      <header class="inv-header">
        <div>
          <h1>First Aid Inventory</h1>
          <p class="inv-sub" id="inv-sub">…</p>
        </div>
        <div class="inv-header-actions">
          <a href="/app/first-aid" class="inv-link-btn">← Back to First Aid</a>
          <button type="button" id="inv-add-btn" class="inv-primary-btn">+ Add item</button>
        </div>
      </header>

      <section class="inv-toolbar">
        <input
          type="search"
          id="inv-search"
          class="inv-search"
          placeholder="Search by name or code…"
          aria-label="Search inventory"
        />
      </section>

      <section id="inv-seed-banner" class="inv-seed-banner" hidden>
        <div>
          <strong>Your inventory is empty.</strong>
          <p>Seed the standard 23 first-aid items to get started, or add your own.</p>
        </div>
        <button type="button" id="inv-seed-btn" class="inv-primary-btn">Seed default 23 items</button>
      </section>

      <section id="inv-skeleton" class="inv-skeleton" hidden>
        <div class="skel-card"></div>
        <div class="skel-card"></div>
        <div class="skel-card"></div>
        <div class="skel-card"></div>
      </section>

      <section id="inv-table-wrap" hidden>
        <div class="inventory-grid" id="inv-tbody"></div>

        <!-- Pagination Controls -->
        <nav class="ins-pager" id="inv-pagination-controls" style="display: flex; justify-content: space-between; align-items: center; margin-top: 15px; gap: 10px;">
          <div style="font-size: 0.85rem; color: var(--color-text-muted);">
            Showing <span id="inv-pag-start">0</span>-<span id="inv-pag-end">0</span> of <span id="inv-pag-total">0</span> items
          </div>
          <div style="display: flex; align-items: center; gap: 8px;">
            <button type="button" class="btn" id="inv-prev" style="padding: 6px 12px; font-size: 0.75rem;">← Prev</button>
            <span id="inv-page-info" style="font-size: 0.85rem; font-weight: 700; color: var(--color-text);">Page 1 of 1</span>
            <button type="button" class="btn" id="inv-next" style="padding: 6px 12px; font-size: 0.75rem;">Next →</button>
          </div>
        </nav>
      </section>

      <section id="inv-empty" class="inv-empty" hidden>
        <p>No inventory items yet. Click "Add item" to add your first.</p>
      </section>
    </div>
  </main>

  <!-- Add/Edit modal -->
  <div id="inv-modal" class="inv-modal" hidden role="dialog" aria-modal="true" aria-labelledby="inv-modal-title">
    <div class="inv-modal-card">
      <header class="inv-modal-head">
        <h2 id="inv-modal-title">Add item</h2>
        <button type="button" class="inv-modal-close" id="inv-modal-close" aria-label="Close">×</button>
      </header>
      <form id="inv-form" novalidate>
        <input type="hidden" name="id" id="inv-form-id" />
        <div id="inv-form-error" class="inv-error" hidden></div>
        <label class="field">
          <span class="field-label">Item code <em>*</em></span>
          <input type="text" name="item_code" id="inv-form-code" required placeholder="e.g. FA-24" />
        </label>
        <label class="field">
          <span class="field-label">Item name <em>*</em></span>
          <input type="text" name="item_name" id="inv-form-name" required placeholder="e.g. Antiseptic Wipes" />
        </label>
        <label class="field">
          <span class="field-label">Unit <em>*</em></span>
          <select name="unit" id="inv-form-unit" required>
            <option value="pcs">pcs</option>
            <option value="pkt">pkt</option>
            <option value="box">box</option>
            <option value="set">set</option>
            <option value="bottle">bottle</option>
            <option value="other">other</option>
          </select>
        </label>
        <div class="field-row">
          <label class="field">
            <span class="field-label">Current stock <em>*</em></span>
            <input type="number" name="current_stock" id="inv-form-stock" required min="0" value="0" />
          </label>
          <label class="field">
            <span class="field-label">Min alert level <em>*</em></span>
            <input type="number" name="min_alert_level" id="inv-form-min" required min="0" value="0" />
          </label>
        </div>
        <label class="field">
          <span class="field-label">Required standard</span>
          <input type="text" name="required_std" id="inv-form-std" placeholder="e.g. 5pcs per 50 workers" />
        </label>
        <label class="field">
          <span class="field-label">Category group</span>
          <input type="number" name="category_group" id="inv-form-cat" min="1" placeholder="e.g. 1" />
          <span class="field-hint">Optional. Used to group items in UI.</span>
        </label>
        <label class="field-check">
          <input type="checkbox" name="is_active" id="inv-form-active" checked />
          <span>Active</span>
        </label>
        <div class="inv-modal-actions">
          <button type="button" class="inv-secondary-btn" id="inv-form-cancel">Cancel</button>
          <button type="submit" class="inv-primary-btn" id="inv-form-save">Save</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Restock modal -->
  <div id="inv-restock-modal" class="inv-modal" hidden role="dialog" aria-modal="true" aria-labelledby="inv-restock-title">
    <div class="inv-modal-card">
      <header class="inv-modal-head">
        <h2 id="inv-restock-title">Restock item</h2>
        <button type="button" class="inv-modal-close" id="inv-restock-close" aria-label="Close">×</button>
      </header>
      <form id="inv-restock-form" novalidate>
        <p class="inv-restock-name" id="inv-restock-name"></p>
        <div id="inv-restock-error" class="inv-error" hidden></div>
        <label class="field">
          <span class="field-label">Quantity to add <em>*</em></span>
          <input type="number" name="quantity" id="inv-restock-qty" required min="1" value="1" />
        </label>
        <label class="field">
          <span class="field-label">Notes</span>
          <textarea name="notes" id="inv-restock-notes" rows="3" placeholder="e.g. PO #1234, supplier ABC"></textarea>
        </label>
        <div class="inv-modal-actions">
          <button type="button" class="inv-secondary-btn" id="inv-restock-cancel">Cancel</button>
          <button type="submit" class="inv-primary-btn" id="inv-restock-save">Restock</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Manual adjust modal -->
  <div id="inv-adjust-modal" class="inv-modal" hidden role="dialog" aria-modal="true" aria-labelledby="inv-adjust-title">
    <div class="inv-modal-card">
      <header class="inv-modal-head">
        <h2 id="inv-adjust-title">Manual adjust</h2>
        <button type="button" class="inv-modal-close" id="inv-adjust-close" aria-label="Close">×</button>
      </header>
      <form id="inv-adjust-form" novalidate>
        <p class="inv-restock-name" id="inv-adjust-name"></p>
        <div id="inv-adjust-error" class="inv-error" hidden></div>
        <label class="field">
          <span class="field-label">Quantity delta <em>*</em></span>
          <input type="number" name="delta" id="inv-adjust-delta" required placeholder="e.g. -2 or 5" />
          <span class="field-hint">Use a negative number to subtract. Cannot go below zero.</span>
        </label>
        <label class="field">
          <span class="field-label">Notes <em>*</em></span>
          <textarea name="notes" id="inv-adjust-notes" rows="3" required placeholder="Reason for adjustment"></textarea>
        </label>
        <div class="inv-modal-actions">
          <button type="button" class="inv-secondary-btn" id="inv-adjust-cancel">Cancel</button>
          <button type="submit" class="inv-primary-btn" id="inv-adjust-save">Adjust</button>
        </div>
      </form>
    </div>
  </div>
</AppLayout>

<script>
  import { getSupabase, isSupabaseConfigured } from '../../../lib/supabase';
  import { DEFAULT_FIRST_AID_ITEMS } from '../../../lib/defaults/firstAidItems';
  import type { FirstAidInventory } from '../../../lib/types';

  type InventoryRow = FirstAidInventory;

  const setupWarning = document.getElementById('inv-setup-warning') as HTMLElement;
  const errorBanner = document.getElementById('inv-error') as HTMLElement;
  const subEl = document.getElementById('inv-sub') as HTMLElement;
  const searchEl = document.getElementById('inv-search') as HTMLInputElement;
  const addBtn = document.getElementById('inv-add-btn') as HTMLButtonElement;
  const seedBanner = document.getElementById('inv-seed-banner') as HTMLElement;
  const seedBtn = document.getElementById('inv-seed-btn') as HTMLButtonElement;
  const skelEl = document.getElementById('inv-skeleton') as HTMLElement;
  const tableWrap = document.getElementById('inv-table-wrap') as HTMLElement;
  const tbody = document.getElementById('inv-tbody') as HTMLElement;
  const emptyEl = document.getElementById('inv-empty') as HTMLElement;

  const formModal = document.getElementById('inv-modal') as HTMLElement;
  const formEl = document.getElementById('inv-form') as HTMLFormElement;
  const formId = document.getElementById('inv-form-id') as HTMLInputElement;
  const formCode = document.getElementById('inv-form-code') as HTMLInputElement;
  const formName = document.getElementById('inv-form-name') as HTMLInputElement;
  const formUnit = document.getElementById('inv-form-unit') as HTMLSelectElement;
  const formStock = document.getElementById('inv-form-stock') as HTMLInputElement;
  const formMin = document.getElementById('inv-form-min') as HTMLInputElement;
  const formStd = document.getElementById('inv-form-std') as HTMLInputElement;
  const formCat = document.getElementById('inv-form-cat') as HTMLInputElement;
  const formActive = document.getElementById('inv-form-active') as HTMLInputElement;
  const formTitle = document.getElementById('inv-modal-title') as HTMLElement;
  const formError = document.getElementById('inv-form-error') as HTMLElement;
  const formClose = document.getElementById('inv-modal-close') as HTMLButtonElement;
  const formCancel = document.getElementById('inv-form-cancel') as HTMLButtonElement;
  const formSave = document.getElementById('inv-form-save') as HTMLButtonElement;

  const restockModal = document.getElementById('inv-restock-modal') as HTMLElement;
  const restockForm = document.getElementById('inv-restock-form') as HTMLFormElement;
  const restockName = document.getElementById('inv-restock-name') as HTMLElement;
  const restockQty = document.getElementById('inv-restock-qty') as HTMLInputElement;
  const restockNotes = document.getElementById('inv-restock-notes') as HTMLTextAreaElement;
  const restockError = document.getElementById('inv-restock-error') as HTMLElement;
  const restockClose = document.getElementById('inv-restock-close') as HTMLButtonElement;
  const restockCancel = document.getElementById('inv-restock-cancel') as HTMLButtonElement;
  const restockSave = document.getElementById('inv-restock-save') as HTMLButtonElement;

  const adjustModal = document.getElementById('inv-adjust-modal') as HTMLElement;
  const adjustForm = document.getElementById('inv-adjust-form') as HTMLFormElement;
  const adjustName = document.getElementById('inv-adjust-name') as HTMLElement;
  const adjustDelta = document.getElementById('inv-adjust-delta') as HTMLInputElement;
  const adjustNotes = document.getElementById('inv-adjust-notes') as HTMLTextAreaElement;
  const adjustError = document.getElementById('inv-adjust-error') as HTMLElement;
  const adjustClose = document.getElementById('inv-adjust-close') as HTMLButtonElement;
  const adjustCancel = document.getElementById('inv-adjust-cancel') as HTMLButtonElement;
  const adjustSave = document.getElementById('inv-adjust-save') as HTMLButtonElement;

  let activeTenantId: string | null = null;
  let activeUserRole: string | null = null;
  let allRows: InventoryRow[] = [];
  let activeRow: InventoryRow | null = null;
  let authUserId: string | null = null;
  let currentPage = 1;

  const paginator = new (window as any).PaginationHelper({
    prevBtnId: 'inv-prev',
    nextBtnId: 'inv-next',
    pageInfoId: 'inv-page-info',
    startId: 'inv-pag-start',
    endId: 'inv-pag-end',
    totalId: 'inv-pag-total',
    controlsContainerId: 'inv-pagination-controls',
    pageSize: 10,
    onChange: (newPage: number) => {
      currentPage = newPage;
      renderTable();
    }
  });

  function showError(msg: string): void {
    errorBanner.hidden = false;
    errorBanner.textContent = msg;
  }

  function showFormError(msg: string): void {
    formError.hidden = false; formError.textContent = msg;
  }
  function clearFormError(): void { formError.hidden = true; formError.textContent = ''; }

  function showRestockError(msg: string): void {
    restockError.hidden = false; restockError.textContent = msg;
  }
  function clearRestockError(): void { restockError.hidden = true; restockError.textContent = ''; }

  function showAdjustError(msg: string): void {
    adjustError.hidden = false; adjustError.textContent = msg;
  }
  function clearAdjustError(): void { adjustError.hidden = true; adjustError.textContent = ''; }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string);
  }

  function formatDate(iso: string | null | undefined): string {
    if (!iso) return '—';
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '—';
    return d.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });
  }

  function renderTable(): void {
    tbody.innerHTML = '';
    const q = searchEl.value.trim().toLowerCase();
    const filtered = allRows.filter((r) => {
      if (!q) return true;
      return r.item_name.toLowerCase().includes(q) || r.item_code.toLowerCase().includes(q);
    });

    if (filtered.length === 0) {
      tableWrap.hidden = true;
      emptyEl.hidden = false;
      paginator.update(currentPage, 0);
      return;
    }
    emptyEl.hidden = true;
    tableWrap.hidden = false;

    const startIdx = (currentPage - 1) * 10;
    const endIdx = startIdx + 10;
    const pageRows = filtered.slice(startIdx, endIdx);

    for (const row of pageRows) {
      const card = document.createElement('div');
      card.className = 'inv-card';
      const lowStock = row.current_stock < row.min_alert_level;
      const badgeClass = lowStock ? 'badge-alert' : 'badge-ok';
      const statusText = lowStock 
        ? `<span class="inv-warning-text">⚠️ Below Min (${row.min_alert_level})</span>` 
        : '<span class="inv-healthy-text">🟢 Level Healthy</span>';

      card.innerHTML = `
        <div class="inv-card-header">
          <span class="inv-code">${escapeHtml(row.item_code)}</span>
          ${row.category_group ? `<span class="inv-group-badge">Group ${row.category_group}</span>` : ''}
          ${!row.is_active ? `<span class="inv-inactive">Inactive</span>` : ''}
          <div class="inv-menu-wrap">
            <button type="button" class="inv-menu-trigger" aria-label="Actions">⋮</button>
            <div class="inv-menu-dropdown">
              <button type="button" class="inv-dropdown-item" data-action="restock" data-id="${row.id}">➕ Restock</button>
              <button type="button" class="inv-dropdown-item" data-action="adjust" data-id="${row.id}">🔧 Adjust</button>
              <button type="button" class="inv-dropdown-item" data-action="edit" data-id="${row.id}">✏️ Edit</button>
              <button type="button" class="inv-dropdown-item btn-danger" data-action="delete" data-id="${row.id}">❌ Delete</button>
            </div>
          </div>
        </div>

        <div class="inv-card-body">
          <div class="inv-info">
            <span class="inv-name" title="${escapeHtml(row.item_name)}">${escapeHtml(row.item_name)}</span>
            ${statusText}
            ${row.required_std ? `<span class="inv-std">Std: ${escapeHtml(row.required_std)}</span>` : ''}
            <span class="inv-updated">Updated: ${formatDate(row.last_updated)}</span>
          </div>
          <div class="inv-stock-badge ${badgeClass}">
            <span class="badge-stock-val">${row.current_stock}</span>
            <span class="badge-unit">${escapeHtml(row.unit)}</span>
          </div>
        </div>
      `;
      tbody.appendChild(card);
    }
    paginator.update(currentPage, filtered.length);
  }

  function updateSub(): void {
    const active = allRows.filter((r) => r.is_active);
    const below = active.filter((r) => r.current_stock < r.min_alert_level).length;
    subEl.textContent = `${active.length} active item${active.length === 1 ? '' : 's'} • ${below} below minimum stock`;
  }

  async function load(): Promise<void> {
    if (!supabase) return;
    skelEl.hidden = false;
    tableWrap.hidden = true;
    emptyEl.hidden = true;
    seedBanner.hidden = true;
    try {
      const { data, error } = await supabase
        .from('first_aid_inventory')
        .select('*')
        .order('category_group', { ascending: true, nullsFirst: false })
        .order('item_name', { ascending: true });
      if (error) throw error;
      allRows = (data ?? []) as InventoryRow[];
      skelEl.hidden = true;
      updateSub();
      if (allRows.length === 0) {
        seedBanner.hidden = false;
        emptyEl.hidden = true;
        tableWrap.hidden = true;
      } else {
        renderTable();
      }
    } catch (e) {
      skelEl.hidden = true;
      showError(e instanceof Error ? e.message : 'Failed to load inventory.');
    }
  }

  function openForm(row: InventoryRow | null): void {
    clearFormError();
    if (row) {
      formTitle.textContent = 'Edit item';
      formId.value = row.id;
      formCode.value = row.item_code;
      formCode.disabled = false;
      formName.value = row.item_name;
      formUnit.value = row.unit;
      formStock.value = String(row.current_stock);
      formMin.value = String(row.min_alert_level);
      formStd.value = row.required_std ?? '';
      formCat.value = row.category_group != null ? String(row.category_group) : '';
      formActive.checked = row.is_active;
    } else {
      formTitle.textContent = 'Add item';
      formEl.reset();
      formId.value = '';
      formCode.disabled = false;
      formActive.checked = true;
    }
    formModal.hidden = false;
    setTimeout(() => formCode.focus(), 30);
  }

  function closeForm(): void { formModal.hidden = true; }

  function openRestock(row: InventoryRow): void {
    activeRow = row;
    clearRestockError();
    restockName.textContent = `${row.item_name} (${row.item_code}) — current: ${row.current_stock} ${row.unit}`;
    restockForm.reset();
    restockQty.value = '1';
    restockModal.hidden = false;
    setTimeout(() => restockQty.focus(), 30);
  }
  function closeRestock(): void { restockModal.hidden = true; activeRow = null; }

  function openAdjust(row: InventoryRow): void {
    activeRow = row;
    clearAdjustError();
    adjustName.textContent = `${row.item_name} (${row.item_code}) — current: ${row.current_stock} ${row.unit}`;
    adjustForm.reset();
    adjustModal.hidden = false;
    setTimeout(() => adjustDelta.focus(), 30);
  }
  function closeAdjust(): void { adjustModal.hidden = true; activeRow = null; }

  let supabase: ReturnType<typeof getSupabase> | null = null;

  if (!isSupabaseConfigured()) {
    setupWarning.hidden = false;
  } else {
    supabase = getSupabase();

    (async () => {
      const { data: userData, error: userErr } = await supabase!.auth.getUser();
      if (userErr || !userData.user) {
        window.location.replace('/login');
        return;
      }
      authUserId = userData.user.id;

      // Query active tenant from tenants table (Solo-SHO mode)
      const { data: tenantData, error: tenantErr } = await supabase!
        .from('tenants')
        .select('id')
        .eq('owner_user_id', authUserId)
        .limit(1);

      if (tenantErr || !tenantData || tenantData.length === 0) {
        showError('You do not belong to an active tenant workspace.');
        return;
      }
      activeTenantId = tenantData[0].id;
      activeUserRole = 'admin'; // Always admin in Solo-SHO mode

      await load();
    })().catch(() => {
      showError('Failed to initialise inventory page.');
    });

    searchEl.addEventListener('input', () => {
      currentPage = 1;
      renderTable();
    });

    // Handle wobbly actions dropdown toggle & click-away to close
    document.addEventListener('click', (ev) => {
      const target = ev.target as HTMLElement;
      const trigger = target.closest('.inv-menu-trigger');
      const dropdowns = document.querySelectorAll('.inv-menu-dropdown');
      
      dropdowns.forEach((d) => {
        if (!trigger || d !== trigger.nextElementSibling) {
          d.classList.remove('show');
        }
      });
      
      if (trigger) {
        ev.stopPropagation();
        const menu = trigger.nextElementSibling as HTMLElement;
        menu.classList.toggle('show');
      }
    });

    addBtn.addEventListener('click', () => openForm(null));
    formClose.addEventListener('click', closeForm);
    formCancel.addEventListener('click', closeForm);
    restockClose.addEventListener('click', closeRestock);
    restockCancel.addEventListener('click', closeRestock);
    adjustClose.addEventListener('click', closeAdjust);
    adjustCancel.addEventListener('click', closeAdjust);

    tbody.addEventListener('click', (ev) => {
      const t = ev.target as HTMLElement;
      const action = t.getAttribute('data-action');
      const id = t.getAttribute('data-id');
      if (!action || !id) return;
      const row = allRows.find((r) => r.id === id);
      if (!row) return;
      if (action === 'edit') openForm(row);
      else if (action === 'restock') openRestock(row);
      else if (action === 'adjust') openAdjust(row);
      else if (action === 'delete') {
        if (window.confirm(`Delete "${row.item_name}" (${row.item_code})? Past transaction history will be retained.`)) {
          (async () => {
            try {
              const { error } = await supabase!
                .from('first_aid_inventory')
                .delete()
                .eq('id', id);
              if (error) {
                if (/transaction history|foreign key/i.test(error.message)) {
                  showError('Cannot delete: this item has transaction history. Mark it inactive instead.');
                } else {
                  showError(error.message);
                }
                return;
              }
              await load();
            } catch (e) {
              showError(e instanceof Error ? e.message : 'Delete failed.');
            }
          })();
        }
      }
    });

    seedBtn.addEventListener('click', () => {
      if (!activeTenantId) {
        showError('Active tenant session not found. Please reload the page.');
        return;
      }
      if (activeUserRole !== 'supervisor' && activeUserRole !== 'admin') {
        showError('Forbidden: You must be an Admin or Supervisor to seed default items.');
        return;
      }
      seedBtn.disabled = true;
      seedBtn.textContent = 'Seeding…';
      (async () => {
        try {
          const rows = DEFAULT_FIRST_AID_ITEMS.map((it) => ({
            tenant_id: activeTenantId,
            item_code: it.item_code,
            item_name: it.item_name,
            unit: it.unit,
            current_stock: it.current_stock,
            min_alert_level: it.min_alert_level,
            required_std: it.required_std,
            category_group: it.category_group,
            is_active: true,
          }));
          const { error } = await supabase!
            .from('first_aid_inventory')
            .insert(rows);
          if (error) throw error;
          await load();
        } catch (e) {
          showError(e instanceof Error ? e.message : 'Failed to seed default items.');
        } finally {
          seedBtn.disabled = false;
          seedBtn.textContent = 'Seed default 23 items';
        }
      })();
    });

    formEl.addEventListener('submit', (ev) => {
      ev.preventDefault();
      clearFormError();
      const id = formId.value;
      const itemCode = formCode.value.trim();
      const itemName = formName.value.trim();
      const unit = formUnit.value;
      const currentStock = Number(formStock.value);
      const minAlert = Number(formMin.value);
      const requiredStd = formStd.value.trim() || null;
      const categoryGroup = formCat.value ? Number(formCat.value) : null;
      const isActive = formActive.checked;

      if (!itemCode || !itemName || !unit) {
        showFormError('Item code, name, and unit are required.');
        return;
      }
      if (!Number.isFinite(currentStock) || currentStock < 0) {
        showFormError('Current stock must be a non-negative number.');
        return;
      }
      if (!Number.isFinite(minAlert) || minAlert < 0) {
        showFormError('Min alert level must be a non-negative number.');
        return;
      }
      if (categoryGroup !== null && (!Number.isFinite(categoryGroup) || categoryGroup < 1)) {
        showFormError('Category group must be 1 or greater.');
        return;
      }

      formSave.disabled = true;
      const originalLabel = formSave.textContent;
      formSave.textContent = 'Saving…';

      (async () => {
        try {
          if (id) {
            const { error } = await supabase!
              .from('first_aid_inventory')
              .update({
                item_code: itemCode,
                item_name: itemName,
                unit,
                current_stock: currentStock,
                min_alert_level: minAlert,
                required_std: requiredStd,
                category_group: categoryGroup,
                is_active: isActive,
              })
              .eq('id', id);
            if (error) throw error;
          } else {
            if (!activeTenantId) {
              throw new Error('Active tenant session not found. Please reload the page.');
            }
            if (activeUserRole !== 'supervisor' && activeUserRole !== 'admin') {
              throw new Error('Forbidden: You must be an Admin or Supervisor to add items.');
            }
            const { error } = await supabase!
              .from('first_aid_inventory')
              .insert({
                tenant_id: activeTenantId,
                item_code: itemCode,
                item_name: itemName,
                unit,
                current_stock: currentStock,
                min_alert_level: minAlert,
                required_std: requiredStd,
                category_group: categoryGroup,
                is_active: isActive,
              });
            if (error) {
              if (/duplicate key|unique/i.test(error.message)) {
                throw new Error(`Item code "${itemCode}" is already in use.`);
              }
              throw error;
            }
          }
          closeForm();
          await load();
        } catch (e: any) {
          const msg = e?.message || (typeof e === 'string' ? e : 'Save failed.');
          if (/duplicate key|unique/i.test(msg)) {
            showFormError(`Item code "${itemCode}" is already in use.`);
          } else {
            showFormError(msg);
          }
        } finally {
          formSave.disabled = false;
          formSave.textContent = originalLabel;
        }
      })();
    });

    restockForm.addEventListener('submit', (ev) => {
      ev.preventDefault();
      if (!activeRow || !authUserId) return;
      clearRestockError();
      const qty = Number(restockQty.value);
      const notes = restockNotes.value.trim() || null;
      if (!Number.isFinite(qty) || qty <= 0) {
        showRestockError('Quantity must be a positive number.');
        return;
      }
      restockSave.disabled = true;
      const original = restockSave.textContent;
      restockSave.textContent = 'Restocking…';
      (async () => {
        try {
          const { data, error } = await supabase!.rpc('restock_inventory', {
            p_item_id: activeRow!.id,
            p_quantity: qty,
            p_actor_id: authUserId,
            p_notes: notes,
          });
          if (error) throw error;
          closeRestock();
          await load();
          const tx = Array.isArray(data) ? data[0] : data;
          const bal = tx && typeof tx === 'object' && 'balance_after' in tx ? (tx as { balance_after: number }).balance_after : null;
          if (bal !== null) {
            window.alert(`Restocked. New balance: ${bal}`);
          }
        } catch (e) {
          showRestockError(e instanceof Error ? e.message : 'Restock failed.');
        } finally {
          restockSave.disabled = false;
          restockSave.textContent = original;
        }
      })();
    });

    adjustForm.addEventListener('submit', (ev) => {
      ev.preventDefault();
      if (!activeRow || !authUserId) return;
      clearAdjustError();
      const delta = Number(adjustDelta.value);
      const notes = adjustNotes.value.trim();
      if (!Number.isFinite(delta) || delta === 0) {
        showAdjustError('Delta must be a non-zero number.');
        return;
      }
      if (!notes) {
        showAdjustError('Notes are required.');
        return;
      }
      adjustSave.disabled = true;
      const original = adjustSave.textContent;
      adjustSave.textContent = 'Adjusting…';
      (async () => {
        try {
          const { data, error } = await supabase!.rpc('adjust_inventory_manual', {
            p_item_id: activeRow!.id,
            p_delta: delta,
            p_actor_id: authUserId,
            p_notes: notes,
          });
          if (error) throw error;
          closeAdjust();
          await load();
          const tx = Array.isArray(data) ? data[0] : data;
          const bal = tx && typeof tx === 'object' && 'balance_after' in tx ? (tx as { balance_after: number }).balance_after : null;
          if (bal !== null) {
            window.alert(`Adjusted. New balance: ${bal}`);
          }
        } catch (e) {
          showAdjustError(e instanceof Error ? e.message : 'Adjustment failed.');
        } finally {
          adjustSave.disabled = false;
          adjustSave.textContent = original;
        }
      })();
    });
  }
</script>

