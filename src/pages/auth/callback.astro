---
import { createSupabaseServerClient } from '../../lib/supabaseServer';

const code = Astro.url.searchParams.get('code');
const errorParam = Astro.url.searchParams.get('error_description') || Astro.url.searchParams.get('error');

if (errorParam) {
  return Astro.redirect(`/login?error=${encodeURIComponent(errorParam)}`);
}

if (code) {
  const supabase = createSupabaseServerClient(Astro);
  if (supabase) {
    const { error } = await supabase.auth.exchangeCodeForSession(code);
    if (!error) {
      // Successfully authenticated and cookies set. Redirect to dashboard.
      return Astro.redirect('/app/dashboard');
    } else {
      return Astro.redirect(`/login?error=${encodeURIComponent(error.message)}`);
    }
  }
}

return Astro.redirect('/login?error=Authentication+failed.+No+code+provided.');
---
