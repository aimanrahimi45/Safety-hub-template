---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Modules from '../components/Modules.astro';
import Onboarding from '../components/Onboarding.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="AmerisPro - Modern OSH Safety Management Platform">
    <Header />
    <main>
        <Hero />
        <Modules />
        <Onboarding />
        <Features />
        <Testimonials />
        <section id="waiting-list" style="padding:4rem 1rem;max-width:700px;margin:0 auto;text-align:center">
          <h2 style="font-size:2rem;font-weight:800;margin-bottom:0.5rem">Aku baru abis bina compliance system untuk Safety — nak try?</h2>
          <p style="color:var(--text-muted);margin-bottom:1.5rem;line-height:1.6">
            Free je. Fokus dekat lone ranger safety. Ade few form mcm incident, PPE, legal register, contractor, first aid.<br><br>
            Yg best, data semua user sendiri simpan. Takde login² tenancy bagai. Connect dgn Google Sheet korang, terus auto create form dkt Google Drive korang.
          </p>
          <form id="waiting-form" style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;max-width:500px;margin:0 auto">
            <input name="name" placeholder="Nama" style="flex:1;min-width:140px;padding:12px;border-radius:10px;border:2px solid var(--border);background:var(--bg);color:var(--text);font-size:1rem">
            <input name="email" type="email" required placeholder="Email" style="flex:1;min-width:200px;padding:12px;border-radius:10px;border:2px solid var(--border);background:var(--bg);color:var(--text);font-size:1rem">
            <button type="submit" style="padding:12px 28px;border-radius:10px;background:var(--accent,#2563eb);color:#fff;border:none;font-size:1rem;font-weight:600;cursor:pointer">Hantar</button>
          </form>
          <div id="waiting-msg" style="margin-top:12px;font-weight:600;min-height:2em"></div>
        </section>
        <script is:inline>
          const GAS_URL = "https://script.google.com/macros/s/AKfycbxkqvl5E03H0IN2igM0RXRcQY0C-lOXpkxlkz9bVcwEQ9hGAUdKnyt7Mw5K9UDVk45juA/exec";
          document.getElementById('waiting-form').onsubmit = async function(e) {
            e.preventDefault();
            const msg = document.getElementById('waiting-msg');
            msg.innerHTML = '⏳ Menghantar...';
            try {
              const q = 'action=waitingList&email=' + encodeURIComponent(this.email.value) + '&name=' + encodeURIComponent(this.name.value);
              const res = await fetch(GAS_URL + '?' + q);
              const data = await res.json();
              msg.innerHTML = data.message || '✅ Terima kasih!';
              if (data.status === 'SUCCESS') { this.email.value = ''; this.name.value = ''; }
            } catch(e) {
              msg.innerHTML = '❌ Ralat. Cuba refresh dan hantar semula.';
            }
          };
        </script>
        <Contact />
    </main>
    <Footer />
</Layout>