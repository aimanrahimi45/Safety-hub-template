---
import Layout from '../layouts/Layout.astro';
const GAS_URL = "https://script.google.com/macros/s/AKfycbxkqvl5E03H0IN2igM0RXRcQY0C-lOXpkxlkz9bVcwEQ9hGAUdKnyt7Mw5K9UDVk45juA/exec";
---

<Layout title="AmerisPro - Modern OSH Safety Management Platform">

  <!-- ===== Navigation (Icon-driven, CASE CE style) ===== -->
  <header class="site-header">
    <nav class="main-nav">
      <div class="container">
        <a href="/" class="header-logo">
          <img src="/amerispro.png" alt="AmerisPro">
          <span>AMERISPRO</span>
        </a>
        <ul class="icon-nav">
          <li>
            <a href="#modules" class="icon-nav-item">
              <span class="icon-nav-icon">📦</span>
              <span class="icon-nav-label">Modules</span>
            </a>
          </li>
          <li>
            <a href="app/" class="icon-nav-item">
              <span class="icon-nav-icon">⚙️</span>
              <span class="icon-nav-label">Console</span>
            </a>
          </li>
          <li>
            <a href="#waiting-list" class="icon-nav-item">
              <span class="icon-nav-icon">✉️</span>
              <span class="icon-nav-label">Contact</span>
            </a>
          </li>
        </ul>
      </div>
    </nav>
  </header>

  <!-- ===== Hero ===== -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content reveal">
        <span class="hero-badge">Next-Gen OSH Compliance</span>
        <h1>The Modern Way to Manage Site Safety</h1>
        <p>Streamline inspections, incident reporting, legal compliance, contractor management, and first aid inventory in one centralized platform — powered by your own Google Drive.</p>
        <div class="hero-actions">
          <a href="app/" class="btn btn-primary">Launch Console</a>
          <a href="index.html#modules" class="btn btn-outline">Explore Modules</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Explore Our Modules (CASE CE Equipment style) ===== -->
  <section id="modules" class="section reveal">
    <div class="container">
      <div class="section-header row">
        <div>
          <h2>Explore Our Modules</h2>
          <p>Integrated OSH tools designed to simplify site compliance and safety management.</p>
        </div>
        <a href="app/" class="header-link">VIEW ALL &rsaquo;</a>
      </div>

      <!-- Category Icon Row -->
      <div class="category-row">
        <a href="#inspection" class="category-item active">
          <span class="category-icon">🔍</span>
          <span class="category-label">Inspections</span>
        </a>
        <a href="#legal" class="category-item">
          <span class="category-icon">📋</span>
          <span class="category-label">Legal Register</span>
        </a>
        <a href="#incident" class="category-item">
          <span class="category-icon">🛡️</span>
          <span class="category-label">Incident Report</span>
        </a>
        <a href="#ppe" class="category-item">
          <span class="category-icon"></span>
          <span class="category-label">First Aid & PPE</span>
        </a>
        <a href="#contractor" class="category-item">
          <span class="category-icon">👷</span>
          <span class="category-label">Contractors</span>
        </a>
        <a href="#staff" class="category-item">
          <span class="category-icon">👥</span>
          <span class="category-label">Staff Roster</span>
        </a>
      </div>

      <!-- Module Cards (2-column) -->
      <div class="module-cards">
        <div class="module-card">
          <div class="module-card-img">
            <span class="module-badge">AmerisPro</span>
            <div class="img-placeholder">🔍</div>
          </div>
          <div class="module-card-body">
            <h3>Inspection Builder</h3>
            <p>Custom templates with Excel import, digital signatures, and audit trails. Build inspections that match your site requirements.</p>
            <a href="app/#inspection" class="btn-card">VIEW ALL FEATURES</a>
          </div>
          <div class="card-accent"></div>
        </div>
        <div class="module-card">
          <div class="module-card-img">
            <span class="module-badge">AmerisPro</span>
            <div class="img-placeholder">📋</div>
          </div>
          <div class="module-card-body">
            <h3>Legal Register</h3>
            <p>OSH compliance checklist with smart questionnaire filtering. Answer yes/no/skip to auto-filter your compliance requirements.</p>
            <a href="compliance.html" class="btn-card">VIEW ALL FEATURES</a>
          </div>
          <div class="card-accent"></div>
        </div>
      </div>

      <div class="prior-link">
        <a href="app/">PRIOR MODELS &rsaquo;</a>
      </div>
    </div>
  </section>

  <!-- ===== Service Solutions (CASE CE style) ===== -->
  <section class="section section-grey reveal">
    <div class="container">
      <div class="section-header row">
        <div>
          <h2>Explore Our Service Solutions</h2>
        </div>
        <a href="app/" class="header-link">VIEW ALL &rsaquo;</a>
      </div>
      <div class="service-solutions">
        <div class="service-item">
          <span class="service-icon">⚡</span>
          <h3>AmerisPro Cloud</h3>
          <p>Reduce your Total Cost of Ownership by increased connectivity resulting in more efficient safety management.</p>
          <a href="app/" class="service-link">DISCOVER AMERISPRO CLOUD &rsaquo;</a>
        </div>
        <div class="service-item">
          <span class="service-icon">🤖</span>
          <h3>AI Legal Search</h3>
          <p>Semantic search over indexed OSH legislation. Ask natural language questions and get clause-level answers instantly.</p>
          <a href="app/" class="service-link">DISCOVER AI SEARCH &rsaquo;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Latest Updates (CASE CE style) ===== -->
  <section id="updates" class="section section-grey reveal">
    <div class="container">
      <div class="updates-header">
        <div class="updates-header-left">
          <h2>Latest Updates</h2>
          <p>Get all the latest updates from AmerisPro, as they happen.</p>
          <a href="index.html#waiting-list" class="header-link">VIEW ALL &rsaquo;</a>
        </div>
        <div class="updates-social">
          <a href="#" class="social-icon" aria-label="Facebook">f</a>
          <a href="#" class="social-icon" aria-label="LinkedIn">in</a>
          <a href="#" class="social-icon" aria-label="YouTube">&#9654;</a>
        </div>
      </div>
      <div class="updates-grid stagger-children">
        <div class="update-card">
          <div class="update-card-img">
            <div class="img-placeholder">🤖</div>
          </div>
          <div class="update-card-body">
            <div class="update-date">Jul 2026</div>
            <h3>AI Legal Search</h3>
            <p>Vector-powered semantic search over indexed OSH legislation with AI-generated clause summaries. Ask natural language questions and get instant, accurate answers.</p>
            <a href="app/" class="read-more">READ MORE &rsaquo;</a>
          </div>
        </div>
        <div class="update-card">
          <div class="update-card-img">
            <div class="img-placeholder"></div>
          </div>
          <div class="update-card-body">
            <div class="update-date">Jul 2026</div>
            <h3>Legal Register Profiler</h3>
            <p>Automatically generate your Legal Register based on a smart questionnaire. Answer industry and role-specific questions to auto-build your compliance checklist.</p>
            <a href="compliance.html" class="read-more">READ MORE &rsaquo;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Support / Keep in Touch ===== -->
  <section class="section support-grid reveal" style="padding:80px 32px;max-width:1680px;margin:0 auto">
    <div class="support-content">
      <h2>Do you need support?</h2>
      <p>For the fastest response, launch the console and check the settings sidebar inside your Google Sheet. For all other inquiries, join the waiting list and we'll get back to you.</p>
      <a href="index.html#waiting-list" class="btn btn-primary">Contact Us</a>
    </div>
    <div class="support-content" style="text-align:right">
      <h2>Get started today</h2>
      <p>Connect your Google Sheet and start managing site safety in minutes. No servers, no subscriptions — your data stays yours.</p>
      <a href="app/" class="btn btn-outline" style="border-color:var(--color-text);color:var(--color-text)">Launch Console</a>
    </div>
  </section>

  <!-- ===== Waiting List ===== -->
  <section id="waiting-list" class="section section-grey reveal">
    <div class="container" style="text-align:center;max-width:600px;margin:0 auto">
      <div class="section-header centered">
        <h2>Early Access</h2>
        <p>Join the waiting list — we'll notify you when it's ready.</p>
      </div>
      <form id="waiting-form" style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:32px">
        <input name="name" placeholder="Your Name" style="flex:1;min-width:160px;padding:12px 18px;border:1px solid var(--color-border);font-family:var(--font-family);font-size:0.95rem;font-weight:500">
        <input name="email" type="email" required placeholder="Email Address" style="flex:1;min-width:220px;padding:12px 18px;border:1px solid var(--color-border);font-family:var(--font-family);font-size:0.95rem;font-weight:500">
        <button type="submit" class="btn btn-primary" style="padding:12px 32px">Join</button>
      </form>
      <div id="waiting-msg" style="margin-top:12px;font-weight:600;min-height:2em"></div>
    </div>
  </section>

  <!-- ===== Floating Quick Links (Mobile) ===== -->
  <div class="quick-links">
    <a href="app/" class="ql-item">
      <span class="ql-icon">👤</span>
      <span class="ql-label">Console</span>
    </a>
    <a href="compliance.html" class="ql-item">
      <span class="ql-icon">📋</span>
      <span class="ql-label">Register</span>
    </a>
    <a href="app/#incident" class="ql-item">
      <span class="ql-icon">🛡️</span>
      <span class="ql-label">Incident</span>
    </a>
    <a href="app/#contractor" class="ql-item">
      <span class="ql-icon">👷</span>
      <span class="ql-label">Contractor</span>
    </a>
    <a href="index.html#waiting-list" class="ql-item">
      <span class="ql-icon">✉️</span>
      <span class="ql-label">Contact</span>
    </a>
  </div>

  <!-- ===== Footer ===== -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Modules</h4>
          <a href="app/#inspection">Inspections</a>
          <a href="compliance.html">Legal Register</a>
          <a href="app/#incident">Incident Report</a>
          <a href="app/">First Aid & PPE</a>
          <a href="app/#contractor">Contractors</a>
          <a href="app/#staff">Staff Roster</a>
        </div>
        <div class="footer-col">
          <h4>Resources</h4>
          <a href="privacy.html">Privacy Policy</a>
          <a href="terms.html">Terms of Service</a>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <a href="index.html">Home</a>
          <a href="index.html#modules">Features</a>
          <a href="index.html#waiting-list">Early Access</a>
        </div>
        <div class="footer-col">
          <h4>Connect</h4>
          <a href="mailto:support@amerispro.com">support@amerispro.com</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; 2026 AmerisPro Safety Tech. All rights reserved.</span>
        <div>
          <a href="privacy.html">Privacy</a>
          <a href="terms.html">Terms</a>
        </div>
      </div>
    </div>
  </footer>

  <script is:inline>
    document.getElementById('waiting-form').onsubmit = async function(e) {
      e.preventDefault();
      const msg = document.getElementById('waiting-msg');
      msg.innerHTML = '⏳ Sending...';
      try {
        const q = 'action=waitingList&email=' + encodeURIComponent(this.email.value) + '&name=' + encodeURIComponent(this.name.value);
        const res = await fetch(GAS_URL + '?' + q);
        const data = await res.json();
        msg.innerHTML = data.message || '✅ Thank you!';
        if (data.status === 'SUCCESS') { this.email.value = ''; this.name.value = ''; }
      } catch(e) {
        msg.innerHTML = '❌ Error. Please refresh and try again.';
      }
    };
  </script>

</Layout>
