---
import Layout from '../layouts/Layout.astro';
const GAS_URL = "https://script.google.com/macros/s/AKfycbxkqvl5E03H0IN2igM0RXRcQY0C-lOXpkxlkz9bVcwEQ9hGAUdKnyt7Mw5K9UDVk45juA/exec";
---

<Layout title="AmerisPro - Modern OSH Safety Management Platform">

  <!-- ===== Navigation Header ===== -->
  <header class="site-header">
    <nav class="main-nav">
      <div class="container nav-container">
        <a href="/" class="header-logo">
          <img src="/amerispro.png" alt="AmerisPro">
          <span>AMERISPRO</span>
        </a>
        <div class="header-nav-group">
          <a href="#modules" class="nav-pill-link">
            <span class="pill-icon">📦</span>
            <span class="pill-text">Modules</span>
          </a>
          <a href="/login" class="nav-pill-link nav-signin-link">
            <span class="pill-icon">🔑</span>
            <span class="pill-text">Sign In</span>
          </a>
          <a href="/login" class="nav-cta-btn">
            <span class="cta-icon">🚀</span>
            <span class="cta-text">Console</span>
          </a>
        </div>
      </div>
    </nav>
  </header>

  <!-- ===== Hero with Looping Carousel ===== -->
  <section class="hero">
    <div class="hero-slides">
      <div class="hero-slide hero-slide-1">
        <img src="/images/pagehero-1.png" alt="Construction site safety">
      </div>
      <div class="hero-slide hero-slide-2">
        <img src="/images/pagehero-2.png" alt="Digital safety inspection">
      </div>
    </div>
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content reveal">
        <span class="hero-badge">Next-Gen OSH Compliance</span>
        <h1>The Modern Way to Manage Site Safety</h1>
        <p>Streamline inspections, incident reporting, legal compliance, contractor management, and first aid inventory in one centralized platform — powered by your own Google Drive.</p>
        <div class="hero-actions">
          <a href="/login" class="btn btn-primary">Launch Console</a>
          <a href="index.html#modules" class="btn btn-outline">Explore Modules</a>
        </div>
      </div>
    </div>
    <div class="hero-indicators">
      <span class="indicator active"></span>
      <span class="indicator"></span>
    </div>
  </section>

  <!-- ===== Explore Our Modules (CASE CE left-list + right-cards layout) ===== -->
  <section id="modules" class="section section-cinematic reveal">
    <div class="container">
      <div class="section-header row">
        <div>
          <h2>Explore Our Modules</h2>
          <p>Integrated OSH tools designed to simplify site compliance and safety management.</p>
        </div>
        <a href="/login" class="header-link">VIEW ALL &rsaquo;</a>
      </div>

      <div class="module-layout">
        <!-- Left: Category List -->
        <div class="module-list">
          <button class="module-list-item active" data-tab="inspection">
            <img class="module-list-icon" src="/images/icon-inspection.png" alt="Inspections">
            <span class="module-list-label">Inspections</span>
          </button>
          <button class="module-list-item" data-tab="legal">
            <img class="module-list-icon" src="/images/icon-legal.png" alt="Legal Register">
            <span class="module-list-label">Legal Register</span>
          </button>
          <button class="module-list-item" data-tab="incident">
            <img class="module-list-icon" src="/images/icon-incident.png" alt="Incident Report">
            <span class="module-list-label">Incident Report</span>
          </button>
          <button class="module-list-item" data-tab="ppe">
            <img class="module-list-icon" src="/images/icon-firstaid.png" alt="First Aid & PPE">
            <span class="module-list-label">First Aid &amp; PPE</span>
          </button>
          <button class="module-list-item" data-tab="contractor">
            <img class="module-list-icon" src="/images/icon-contractors.png" alt="Contractors">
            <span class="module-list-label">Contractors</span>
          </button>
          <button class="module-list-item" data-tab="staff">
            <img class="module-list-icon" src="/images/icon-staff.png" alt="Staff Roster">
            <span class="module-list-label">Staff Roster</span>
          </button>
        </div>

        <!-- Right: Product Cards -->
        <div class="module-cards-wrapper">
          <!-- Inspection -->
          <div class="module-tab active" data-tab="inspection">
            <div class="module-cards">
              <div class="module-card">
                <div class="module-card-img module-card-preview">
                  <img class="card-preview-img" src="/images/inspection-builder.webp" alt="Inspection Builder UI">
                </div>
                <div class="module-card-body">
                  <h3>Inspection Builder</h3>
                  <p>Custom templates with Excel import, digital signatures, and audit trails. Build inspections that match your site requirements.</p>
                  <a href="/app/#inspection" class="btn-card">VIEW ALL FEATURES</a>
                </div>
                <div class="card-accent"></div>
              </div>
              <div class="module-card">
                <div class="module-card-img module-card-preview">
                  <img class="card-preview-img" src="/images/inspection-report.webp" alt="Inspection Reports UI">
                </div>
                <div class="module-card-body">
                  <h3>Inspection Reports</h3>
                  <p>Auto-generated reports with findings, photos, and corrective actions. Export to PDF or share directly with stakeholders.</p>
                  <a href="/app/#inspection" class="btn-card">VIEW ALL FEATURES</a>
                </div>
                <div class="card-accent"></div>
              </div>
            </div>
          </div>

          <!-- Legal Register -->
          <div class="module-tab" data-tab="legal">
            <div class="module-cards">
              <div class="module-card">
                <div class="module-card-img module-card-preview">
                  <img class="card-preview-img" src="/images/legal-register-profiler.png" alt="Legal Register Profiler UI">
                </div>
                <div class="module-card-body">
                  <h3>Legal Register Profiler</h3>
                  <p>Automatically generate your Legal Register based on a smart questionnaire. Answer industry-specific questions to auto-build your compliance checklist.</p>
                  <a href="/login" class="btn-card">VIEW ALL FEATURES</a>
                </div>
                <div class="card-accent"></div>
              </div>
              <div class="module-card">
                <div class="module-card-img module-card-preview">
                  <img class="card-preview-img" src="/images/ai-legal-search.png" alt="AI Legal Search UI">
                </div>
                <div class="module-card-body">
                  <h3>AI Legal Search</h3>
                  <p>Vector-powered semantic search over indexed OSH legislation with AI-generated clause summaries. Ask natural language questions and get instant answers.</p>
                  <a href="/login" class="btn-card">VIEW ALL FEATURES</a>
                </div>
                <div class="card-accent"></div>
              </div>
            </div>
          </div>

          <!-- Incident Report -->
          <div class="module-tab" data-tab="incident">
            <div class="module-cards">
              <div class="module-card">
                <div class="module-card-img module-card-preview">
                  <img class="card-preview-img" src="/images/incident-logger.png" alt="Incident Logger UI">
                </div>
                <div class="module-card-body">
                  <h3>Incident Logger</h3>
                  <p>Digital incident logging with root cause tracking, photo evidence, and staff lookup. Capture incidents in real-time from any device.</p>
                  <a href="/app/#incident" class="btn-card">VIEW ALL FEATURES</a>
                </div>
                <div class="card-accent"></div>
              </div>
              <div class="module-card">
                <div class="module-card-img module-card-preview">
                  <img class="card-preview-img" src="/images/incident-analytics.png" alt="Incident Analytics UI">
                </div>
                <div class="module-card-body">
                  <h3>Incident Analytics</h3>
                  <p>Trend analysis and reporting on incident types, locations, and root causes. Identify patterns before they become serious.</p>
                  <a href="/app/#incident" class="btn-card">VIEW ALL FEATURES</a>
                </div>
                <div class="card-accent"></div>
              </div>
            </div>
          </div>

          <!-- First Aid & PPE -->
          <div class="module-tab" data-tab="ppe">
            <div class="module-cards">
              <div class="module-card">
                <div class="module-card-img module-card-preview">
                  <img class="card-preview-img" src="/images/first-aid-inventory.png" alt="First Aid Inventory UI">
                </div>
                <div class="module-card-body">
                  <h3>First Aid Inventory</h3>
                  <p>Track first aid kit contents, expiry dates, and replenishment schedules. Never run short on critical supplies.</p>
                  <a href="/login" class="btn-card">VIEW ALL FEATURES</a>
                </div>
                <div class="card-accent"></div>
              </div>
              <div class="module-card">
                <div class="module-card-img module-card-preview">
                  <img class="card-preview-img" src="/images/ppe-management.png" alt="PPE Management UI">
                </div>
                <div class="module-card-body">
                  <h3>PPE Management</h3>
                  <p>Issue, track, and audit personal protective equipment. Monitor stock levels and auto-alert when items need replacement.</p>
                  <a href="/login" class="btn-card">VIEW ALL FEATURES</a>
                </div>
                <div class="card-accent"></div>
              </div>
            </div>
          </div>

          <!-- Contractors -->
          <div class="module-tab" data-tab="contractor">
            <div class="module-cards">
              <div class="module-card">
                <div class="module-card-img module-card-preview">
                  <img class="card-preview-img" src="/images/contractor-induction.webp" alt="Contractor Induction UI">
                </div>
                <div class="module-card-body">
                  <h3>Contractor Induction</h3>
                  <p>Digital induction management with certification tracking and worker approval workflows. Ensure every contractor is site-ready.</p>
                  <a href="/app/#contractor" class="btn-card">VIEW ALL FEATURES</a>
                </div>
                <div class="card-accent"></div>
              </div>
              <div class="module-card">
                <div class="module-card-img module-card-preview">
                  <img class="card-preview-img" src="/images/permit-to-work.webp" alt="Permit to Work — coming soon">
                </div>
                <div class="module-card-body">
                  <h3>Permit to Work</h3>
                  <p>Module under construction. Digital permit management for high-risk work is coming soon — approvals, conditions, and expiry linked to your contractor database.</p>
                  <a href="/app/#contractor" class="btn-card">VIEW ALL FEATURES</a>
                </div>
                <div class="card-accent"></div>
              </div>
            </div>
          </div>

          <!-- Staff Roster -->
          <div class="module-tab" data-tab="staff">
            <div class="module-cards">
              <div class="module-card">
                <div class="module-card-img module-card-preview">
                  <img class="card-preview-img" src="/images/staff-directory.webp" alt="Staff Directory">
                </div>
                <div class="module-card-body">
                  <h3>Staff Directory</h3>
                  <p>Central personnel database with department filters, role tracking, and contact details. Find any team member instantly.</p>
                  <a href="/app/#staff" class="btn-card">VIEW ALL FEATURES</a>
                </div>
                <div class="card-accent"></div>
              </div>
              <div class="module-card">
                <div class="module-card-img module-card-preview">
                  <img class="card-preview-img" src="/images/staff-training.webp" alt="Staff Training Database">
                </div>
                <div class="module-card-body">
                  <h3>Staff Training</h3>
                  <p>Track OSH certifications, training records, and attendance per staff member. Instantly see who has not completed required safety training.</p>
                  <a href="/app/#staff" class="btn-card">VIEW ALL FEATURES</a>
                </div>
                <div class="card-accent"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="prior-link">
        <a href="/login">PRIOR MODELS &rsaquo;</a>
      </div>
    </div>
  </section>

  <!-- ===== How AmerisPro Works (data sovereignty + GAS architecture) ===== -->
  <section class="section section-grey reveal">
    <div class="container">
      <div class="section-header">
        <h2>How AmerisPro Works</h2>
        <p>Your safety data stays in your Google Drive. Always. We just give you the tools to manage it.</p>
      </div>
      <div class="how-it-works">
        <div class="how-item how-hero">
          <div class="how-icon">
            <img src="/images/how-data-drive.webp" alt="Your data, your Drive" loading="lazy">
          </div>
          <h3>Your data, your Drive</h3>
          <p>Every record, signature, and audit trail lives in a Google Sheet inside your own Google Drive. AmerisPro never copies, caches, or backs up your data. Delete the sheet and the data is gone. Move it and the data moves with it.</p>
        </div>
        <div class="how-item">
          <div class="how-icon">
            <img src="/images/how-gas-backend.webp" alt="Powered by Google Apps Script" loading="lazy">
          </div>
          <h3>Powered by Google Apps Script</h3>
          <p>The whole backend runs as a Google Apps Script web app deployed to Google's own infrastructure. No servers to maintain, no infrastructure to pay for, no vendor downtime — just the same platform Google uses itself.</p>
        </div>
        <div class="how-item">
          <div class="how-icon">
            <img src="/images/how-google-sheets.webp" alt="Works inside Google Sheets" loading="lazy">
          </div>
          <h3>Works inside Google Sheets</h3>
          <p>Open the sheet, see your safety data. Run the add-on, manage inspections. No new app to learn, no separate login — your team uses the tools they already have.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Latest Updates (CASE CE style) ===== -->
  <section id="updates" class="section section-grey reveal">
    <div class="container">
      <div class="updates-header">
        <div class="updates-header-left">
          <h2>Latest Updates</h2>
          <p>Get all the latest updates from AmerisPro, as they happen.</p>
          <a href="index.html#waiting-list" class="header-link">VIEW ALL &rsaquo;</a>
        </div>
        <div class="updates-social">
          <a href="#" class="social-icon" aria-label="Facebook">f</a>
          <a href="#" class="social-icon" aria-label="LinkedIn">in</a>
          <a href="#" class="social-icon" aria-label="YouTube">&#9654;</a>
        </div>
      </div>
      <div class="updates-grid stagger-children">
        <div class="update-card">
          <div class="update-card-img">
            <img class="card-icon" src="/images/icon-legal.png" alt="AI">
          </div>
          <div class="update-card-body">
            <div class="update-date">Jul 2026</div>
            <h3>AI Legal Search</h3>
            <p>Now indexed: Act 514 (OSH 1994), Act 872 (Gig Workers 2025), Act 302 (Petroleum Safety 1984), and USECHH 2000. More regulations on the way — ask natural language questions and get instant answers with AI-generated clause summaries.</p>
            <a href="/login" class="read-more">READ MORE &rsaquo;</a>
          </div>
        </div>
        <div class="update-card">
          <div class="update-card-img">
            <img class="card-icon" src="/images/icon-inspection.png" alt="Reports">
          </div>
          <div class="update-card-body">
            <div class="update-date">Jul 2026</div>
            <h3>Legal Register Profiler</h3>
            <p>Automatically generate your Legal Register based on a smart questionnaire. Answer industry and role-specific questions to auto-build your compliance checklist.</p>
            <a href="/login" class="read-more">READ MORE &rsaquo;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Support + Launch Console (CASE CE split style) ===== -->
  <section class="support-split reveal">
    <div class="support-split-left">
      <h2>Do you need support?</h2>
      <p>For the fastest response, launch the console and check the settings sidebar inside your Google Sheet. For all other inquiries, please contact us by filling in the form.</p>
      <a href="index.html#waiting-list" class="btn-support">CONTACT US</a>
    </div>
    <div class="support-split-right">
      <h2>Launch Console</h2>
      <p>Connect your Google Sheet and start managing site safety in minutes. No servers, no subscriptions — your data stays yours.</p>
      <a href="/login" class="btn-support">LAUNCH</a>
    </div>
    <div class="support-accent"></div>
  </section>

  <!-- ===== Waiting List ===== -->
  <section id="waiting-list" class="section section-grey reveal">
    <div class="container" style="text-align:center;max-width:600px;margin:0 auto">
      <div class="section-header centered">
        <h2>Early Access</h2>
        <p>Join the waiting list — we'll notify you when it's ready.</p>
      </div>
      <form id="waiting-form" style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:32px">
        <input name="name" placeholder="Your Name" style="flex:1;min-width:160px;padding:12px 18px;border:1px solid var(--color-border);font-family:var(--font-family);font-size:0.95rem;font-weight:500">
        <input name="email" type="email" required placeholder="Email Address" style="flex:1;min-width:220px;padding:12px 18px;border:1px solid var(--color-border);font-family:var(--font-family);font-size:0.95rem;font-weight:500">
        <button type="submit" class="btn btn-primary" style="padding:12px 32px">Join</button>
      </form>
      <div id="waiting-msg" style="margin-top:12px;font-weight:600;min-height:2em"></div>
    </div>
  </section>

  <!-- ===== Floating Quick Links (Mobile) ===== -->
  <div class="quick-links">
    <a href="/login" class="ql-item">
      <span class="ql-icon">👤</span>
      <span class="ql-label">Console</span>
    </a>
    <a href="/login" class="ql-item">
      <span class="ql-icon">📋</span>
      <span class="ql-label">Register</span>
    </a>
    <a href="/app/#incident" class="ql-item">
      <span class="ql-icon">🛡️</span>
      <span class="ql-label">Incident</span>
    </a>
    <a href="/app/#contractor" class="ql-item">
      <span class="ql-icon">👷</span>
      <span class="ql-label">Contractor</span>
    </a>
    <a href="index.html#waiting-list" class="ql-item">
      <span class="ql-icon">✉️</span>
      <span class="ql-label">Contact</span>
    </a>
  </div>

  <!-- ===== Footer ===== -->
  <footer class="site-footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h4>Modules</h4>
          <a href="/app/#inspection">Inspections</a>
          <a href="/login">Legal Register</a>
          <a href="/app/#incident">Incident Report</a>
          <a href="/login">First Aid & PPE</a>
          <a href="/app/#contractor">Contractors</a>
          <a href="/app/#staff">Staff Roster</a>
        </div>
        <div class="footer-col">
          <h4>Resources</h4>
          <a href="privacy.html">Privacy Policy</a>
          <a href="terms.html">Terms of Service</a>
        </div>
        <div class="footer-col">
          <h4>Company</h4>
          <a href="index.html">Home</a>
          <a href="index.html#modules">Features</a>
          <a href="index.html#waiting-list">Early Access</a>
        </div>
      </div>
      <div class="footer-bottom">
        <span>&copy; 2026 AmerisPro Safety Tech. All rights reserved.</span>
        <div>
          <a href="privacy.html">Privacy</a>
          <a href="terms.html">Terms</a>
        </div>
      </div>
    </div>
  </footer>

  <script is:inline>
    document.getElementById('waiting-form').onsubmit = async function(e) {
      e.preventDefault();
      const msg = document.getElementById('waiting-msg');
      msg.innerHTML = '🚀 We\'re now in beta — sign in with Google above to start using AmerisPro!';
      this.email.value = '';
      this.name.value = '';
    };
  </script>

  <script>
    import { getSupabase, isSupabaseConfigured } from '../lib/supabase';

    const params = new URLSearchParams(window.location.search);
    const code = params.get('code');

    if (code && isSupabaseConfigured()) {
      window.location.replace(`/auth/confirmed?code=${encodeURIComponent(code)}`);
    }
  </script>

</Layout>
