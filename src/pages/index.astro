---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Modules from '../components/Modules.astro';
import Onboarding from '../components/Onboarding.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="AmerisPro - Modern OSH Safety Management Platform">
    <Header />
    <main>
        <Hero />
        <Modules />
        <Onboarding />
        <Features />
        <section id="updates" class="reveal" style="padding:4rem 40px;max-width:1100px;margin:0 auto">
          <div class="section-header">
            <h2>Latest Updates</h2>
            <p>What's new with AmerisPro — product updates and improvements.</p>
          </div>
          <div class="updates-grid stagger-children">
            <div class="update-card">
              <div class="update-date">Jul 2026</div>
              <h3>Legal Register Questionnaire</h3>
              <p>Smart filtering with regulation-specific questionnaires. Answer yes/no/skip to auto-filter your compliance checklist.</p>
              <span class="tag weight-mandatory" style="display:inline-block;margin-top:10px;font-size:0.75rem;">NEW</span>
            </div>
            <div class="update-card">
              <div class="update-date">Jun 2026</div>
              <h3>AI Legal Search</h3>
              <p>Semantic search over indexed OSH legislation. Ask natural language questions and get clause-level answers.</p>
              <span class="tag weight-mandatory" style="display:inline-block;margin-top:10px;font-size:0.75rem;">PREMIUM</span>
            </div>
            <div class="update-card">
              <div class="update-date">Jun 2026</div>
              <h3>OSH Legislation Database</h3>
              <p>4 acts fully indexed: OSHA 1994, Gig Workers 2025, Petroleum 1984, USECHH 2000. 1,300+ clauses parsed.</p>
            </div>
          </div>
        </section>
        <section id="waiting-list" class="reveal" style="padding:4rem 1rem;max-width:600px;margin:0 auto;text-align:center">
          <h2 style="font-size:2rem;font-weight:800;margin-bottom:0.5rem">🚀 Early Access</h2>
          <p style="color:var(--text-muted);margin-bottom:2rem">Join the waiting list — we'll notify you when it's ready.</p>
          <form id="waiting-form" style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center">
            <input name="name" placeholder="Your Name" style="flex:1;min-width:160px;padding:12px 18px;border-radius:50px;border:2.5px solid var(--border);background:var(--bg);color:var(--text);font-size:1rem;font-family:var(--font-heading)">
            <input name="email" type="email" required placeholder="Email Address" style="flex:1;min-width:220px;padding:12px 18px;border-radius:50px;border:2.5px solid var(--border);background:var(--bg);color:var(--text);font-size:1rem;font-family:var(--font-heading)">
            <button type="submit" class="btn-pill btn-primary">Join</button>
          </form>
          <div id="waiting-msg" style="margin-top:12px;font-weight:600;min-height:2em"></div>
        </section>
        <script is:inline>
          const GAS_URL = "https://script.google.com/macros/s/AKfycbxkqvl5E03H0IN2igM0RXRcQY0C-lOXpkxlkz9bVcwEQ9hGAUdKnyt7Mw5K9UDVk45juA/exec";
          document.getElementById('waiting-form').onsubmit = async function(e) {
            e.preventDefault();
            const msg = document.getElementById('waiting-msg');
            msg.innerHTML = '⏳ Sending...';
            try {
              const q = 'action=waitingList&email=' + encodeURIComponent(this.email.value) + '&name=' + encodeURIComponent(this.name.value);
              const res = await fetch(GAS_URL + '?' + q);
              const data = await res.json();
              msg.innerHTML = data.message || '✅ Thank you!';
              if (data.status === 'SUCCESS') { this.email.value = ''; this.name.value = ''; }
            } catch(e) {
              msg.innerHTML = '❌ Error. Please refresh and try again.';
            }
          };
        </script>
    </main>
    <Footer />
</Layout>