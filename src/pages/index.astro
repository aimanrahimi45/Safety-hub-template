---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AmerisPro - Modern OSH Safety Management Platform">

  <!-- ===== Navigation ===== -->
  <header class="site-header">
    <nav class="main-nav">
      <div class="container">
        <a href="/" class="header-logo">
          <span style="font-size:1.4rem;font-weight:900">🛡️</span>
          <span>AMERISPRO</span>
        </a>
        <ul class="icon-nav">
          <li>
            <a href="#modules" class="icon-nav-item">
              <span class="icon-nav-icon">📦</span>
              <span class="icon-nav-label">Modules</span>
            </a>
          </li>
          <li>
            <a href="/login" class="icon-nav-item" id="nav-console">
              <span class="icon-nav-icon">⚙️</span>
              <span class="icon-nav-label">Console</span>
            </a>
          </li>
        </ul>
      </div>
    </nav>
  </header>

  <!-- ===== Hero ===== -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <span class="hero-badge">Next-Gen OSH Compliance</span>
        <h1>The Modern Way to Manage Site Safety</h1>
        <p>Streamline inspections, incident reporting, legal compliance, contractor management, and first aid inventory in one centralized platform.</p>
        <div class="hero-actions">
          <a href="/login" class="btn btn-primary" id="hero-console">🚀 Launch Console</a>
        </div>
        <p style="margin-top:12px;font-size:0.85rem;opacity:0.8">Sign in with Google — no separate account needed</p>
      </div>
    </div>
  </section>

  <!-- ===== Modules ===== -->
  <section id="modules" class="section">
    <div class="container">
      <h2>Modules</h2>
      <div class="modules-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;margin-top:24px">
        <a href="/login" class="module-card-link" style="padding:20px;border:1px solid var(--color-border, #e2e8f0);border-radius:8px;text-decoration:none;color:inherit">
          <div style="font-size:2rem;margin-bottom:8px">⛑️</div>
          <h3 style="margin:0 0 4px;font-size:1rem">First Aid</h3>
          <p style="margin:0;font-size:0.85rem;color:var(--color-text-muted, #64748b)">Incidents, inventory, ISO 45001 compliant</p>
        </a>
        <a href="/login" class="module-card-link" style="padding:20px;border:1px solid var(--color-border, #e2e8f0);border-radius:8px;text-decoration:none;color:inherit">
          <div style="font-size:2rem;margin-bottom:8px">🦺</div>
          <h3 style="margin:0 0 4px;font-size:1rem">PPE</h3>
          <p style="margin:0;font-size:0.85rem;color:var(--color-text-muted, #64748b)">Issue &amp; track protective equipment</p>
        </a>
        <a href="/login" class="module-card-link" style="padding:20px;border:1px solid var(--color-border, #e2e8f0);border-radius:8px;text-decoration:none;color:inherit">
          <div style="font-size:2rem;margin-bottom:8px">👷</div>
          <h3 style="margin:0 0 4px;font-size:1rem">Contractors</h3>
          <p style="margin:0;font-size:0.85rem;color:var(--color-text-muted, #64748b)">Inductions &amp; tracking</p>
        </a>
        <a href="/login" class="module-card-link" style="padding:20px;border:1px solid var(--color-border, #e2e8f0);border-radius:8px;text-decoration:none;color:inherit">
          <div style="font-size:2rem;margin-bottom:8px">🚨</div>
          <h3 style="margin:0 0 4px;font-size:1rem">Incidents</h3>
          <p style="margin:0;font-size:0.85rem;color:var(--color-text-muted, #64748b)">Report &amp; investigate</p>
        </a>
        <a href="/login" class="module-card-link" style="padding:20px;border:1px solid var(--color-border, #e2e8f0);border-radius:8px;text-decoration:none;color:inherit">
          <div style="font-size:2rem;margin-bottom:8px">🧑‍💼</div>
          <h3 style="margin:0 0 4px;font-size:1rem">Staff</h3>
          <p style="margin:0;font-size:0.85rem;color:var(--color-text-muted, #64748b)">Roster with Excel import</p>
        </a>
        <a href="/login" class="module-card-link" style="padding:20px;border:1px solid var(--color-border, #e2e8f0);border-radius:8px;text-decoration:none;color:inherit">
          <div style="font-size:2rem;margin-bottom:8px">📋</div>
          <h3 style="margin:0 0 4px;font-size:1rem">Inspections</h3>
          <p style="margin:0;font-size:0.85rem;color:var(--color-text-muted, #64748b)">Templates, signatures, audits</p>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== Footer ===== -->
  <footer class="site-footer">
    <div class="container">
      <p>&copy; 2026 AmerisPro Safety Tech. All rights reserved.</p>
      <p style="margin-top:8px;font-size:0.85rem">
        <a href="/privacy" style="color:inherit;margin-right:16px">Privacy</a>
        <a href="/terms" style="color:inherit;margin-right:16px">Terms</a>
      </p>
    </div>
  </footer>

</Layout>
