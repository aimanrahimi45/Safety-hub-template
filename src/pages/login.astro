---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Sign in - AmerisPro">
  <!-- Minimal Brand Header -->
  <header class="auth-header">
    <div class="container auth-nav-container">
      <a href="/" class="auth-brand-logo">
        <img src="/amerispro.png" alt="AmerisPro">
        <span>AMERISPRO</span>
      </a>
      <a href="/" class="auth-back-link">← Home</a>
    </div>
  </header>

  <main class="auth-page">
    <div class="container auth-container">
      <div class="auth-card">
        <h1>Sign in to AmerisPro</h1>
        <p class="auth-subtitle">
          Access your site safety workspace with your account
        </p>

        <div id="auth-setup-warning" class="auth-warning" hidden>
          <strong>Setup required.</strong>
          <span>
            Supabase credentials missing. Copy <code>.env.example</code> to <code>.env</code> and fill in credentials.
          </span>
        </div>

        <div id="auth-error" class="auth-error" hidden></div>

        <!-- OAuth Sign-In Buttons -->
        <div class="oauth-stack">
          <button type="button" id="google-signin-btn" class="oauth-btn google-btn">
            <span class="oauth-btn-icon google-btn-icon" aria-hidden="true">G</span>
            <span>Sign in with Google</span>
          </button>

          <button type="button" id="linkedin-signin-btn" class="oauth-btn linkedin-btn">
            <span class="oauth-btn-icon linkedin-btn-icon" aria-hidden="true">in</span>
            <span>Sign in with LinkedIn</span>
          </button>
        </div>

        <p class="auth-foot">
          By continuing, you agree to our
          <a href="/terms">Terms of Service</a> and
          <a href="/privacy">Privacy Policy</a>.
        </p>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { getSupabase, isSupabaseConfigured } from '../lib/supabase';

  const setupWarning = document.getElementById('auth-setup-warning') as HTMLElement;
  const errorEl = document.getElementById('auth-error') as HTMLElement;
  const googleBtn = document.getElementById('google-signin-btn') as HTMLButtonElement;
  const linkedinBtn = document.getElementById('linkedin-signin-btn') as HTMLButtonElement;

  const params = new URLSearchParams(window.location.search);
  const nextPath = params.get('next') || '/app/dashboard';
  const errParam = params.get('error');

  if (errParam) {
    errorEl.hidden = false;
    errorEl.textContent = decodeURIComponent(errParam);
  }

  if (!isSupabaseConfigured()) {
    setupWarning.hidden = false;
    googleBtn.disabled = true;
    linkedinBtn.disabled = true;
  } else {
    const supabase = getSupabase();

    supabase.auth.getSession().then(({ data }) => {
      if (data.session) {
        window.location.replace(nextPath);
      }
    });

    // Google Sign-in Handler
    googleBtn.addEventListener('click', async () => {
      googleBtn.disabled = true;
      googleBtn.textContent = 'Redirecting to Google…';
      try {
        const { error } = await supabase.auth.signInWithOAuth({
          provider: 'google',
          options: {
            redirectTo: window.location.origin + '/auth/callback',
          },
        });
        if (error) throw error;
      } catch (e) {
        const message = e instanceof Error ? e.message : 'Google sign-in failed';
        errorEl.hidden = false;
        errorEl.textContent = message;
        googleBtn.disabled = false;
        googleBtn.innerHTML = '<span class="oauth-btn-icon google-btn-icon" aria-hidden="true">G</span><span>Sign in with Google</span>';
      }
    });

    // LinkedIn Sign-in Handler
    linkedinBtn.addEventListener('click', async () => {
      linkedinBtn.disabled = true;
      linkedinBtn.textContent = 'Redirecting to LinkedIn…';
      try {
        const { error } = await supabase.auth.signInWithOAuth({
          provider: 'linkedin_oidc',
          options: {
            redirectTo: window.location.origin + '/auth/callback',
          },
        });
        if (error) throw error;
      } catch (e) {
        const message = e instanceof Error ? e.message : 'LinkedIn sign-in failed';
        errorEl.hidden = false;
        errorEl.textContent = message;
        linkedinBtn.disabled = false;
        linkedinBtn.innerHTML = '<span class="oauth-btn-icon linkedin-btn-icon" aria-hidden="true">in</span><span>Sign in with LinkedIn</span>';
      }
    });
  }
</script>

<style>
  /* Minimal Brand Header for Auth Pages */
  .auth-header {
    background: #FFFFFF;
    border-bottom: 2.5px solid #2B2D42;
    height: 60px;
    display: flex;
    align-items: center;
  }

  .auth-nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .auth-brand-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 900;
    font-size: 1.1rem;
    color: #2B2D42;
    text-decoration: none;
  }

  .auth-brand-logo img {
    height: 30px;
  }

  .auth-back-link {
    font-size: 0.85rem;
    font-weight: 800;
    color: #2B2D42;
    text-decoration: none;
    padding: 6px 12px;
    border: 2px solid #2B2D42;
    border-radius: 16px;
    background: #FFF9EC;
    box-shadow: 2px 2px 0px #2B2D42;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .auth-back-link:hover {
    transform: translateY(-1px);
    box-shadow: 3px 3px 0px #2B2D42;
  }

  /* Hide mobile quick dock & body padding on login page */
  :global(.quick-links) {
    display: none !important;
  }
  :global(body) {
    padding-bottom: 0 !important;
  }

  .auth-page {
    min-height: calc(100vh - 60px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 16px;
    background: #FDFBF7;
    box-sizing: border-box;
  }

  .auth-container {
    display: flex;
    justify-content: center;
  }

  /* Neo-Brutalist Auth Card */
  .auth-card {
    background: #FFFFFF;
    border: 3px solid #2B2D42 !important;
    border-radius: 16px !important;
    box-shadow: 4px 4px 0px #2B2D42 !important;
    padding: 40px 32px;
    max-width: 420px;
    width: 100%;
    text-align: center;
  }

  .auth-card h1 {
    font-size: 1.6rem;
    font-weight: 900;
    color: #2B2D42;
    margin-bottom: 8px;
  }

  .auth-subtitle {
    color: #64748b;
    margin-bottom: 32px;
    font-size: 0.92rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .auth-warning,
  .auth-error {
    text-align: left;
    padding: 12px 14px;
    border-radius: 8px;
    margin-bottom: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.5;
    border: 2px solid #2B2D42;
    box-shadow: 2px 2px 0px #2B2D42;
  }

  .auth-warning {
    background: #FFF7E6;
    color: #6A4A0F;
  }

  .auth-error {
    background: #FFEBEB;
    color: #9B1C1C;
  }

  .oauth-stack {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 24px;
  }

  .oauth-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    width: 100%;
    padding: 14px 20px;
    background: #FFFFFF;
    color: #2B2D42;
    border: 2.5px solid #2B2D42 !important;
    border-radius: 12px !important;
    box-shadow: 3px 3px 0px #2B2D42 !important;
    font-family: inherit;
    font-size: 0.92rem;
    font-weight: 800;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s !important;
  }

  .oauth-btn:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 4px 4px 0px #2B2D42 !important;
  }

  .google-btn:hover:not(:disabled) {
    background: #FFF9EC;
  }

  .linkedin-btn:hover:not(:disabled) {
    background: #EBF3FF;
  }

  .oauth-btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    font-weight: 900;
    font-size: 0.85rem;
  }

  .google-btn-icon {
    background: #FF6B6B;
    color: #FFFFFF;
  }

  .linkedin-btn-icon {
    background: #0A66C2;
    color: #FFFFFF;
    font-family: sans-serif;
    font-style: italic;
    font-weight: 900;
  }

  .auth-foot {
    font-size: 0.78rem;
    color: #64748b;
  }

  .auth-foot a {
    color: #2B2D42;
    font-weight: 800;
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .auth-card {
      padding: 32px 20px;
    }
  }
</style>
