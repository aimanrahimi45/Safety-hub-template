<style>
    .container {
        max-width: 800px;
        margin: 40px auto;
        background: #ffffff;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05), 0 2px 4px -2px rgb(0 0 0 / 0.05);
        border: 1px solid #e2e8f0;
    }
    h1 {
        font-size: 2rem;
        margin-top: 0;
        color: #0f172a;
        border-bottom: 2px solid #e2e8f0;
        padding-bottom: 15px;
    }
    h2 {
        font-size: 1.25rem;
        margin-top: 30px;
        color: #2563eb;
    }
    p, li {
        color: #475569;
        font-size: 0.95rem;
    }
    ul {
        padding-left: 20px;
    }
    .footer {
        margin-top: 40px;
        font-size: 0.8rem;
        color: #475569;
        border-top: 1px solid #e2e8f0;
        padding-top: 20px;
        text-align: center;
    }
</style>
